<!DOCTYPE html>
<html lang="en">
<body style="margin:0;padding:0;background:#f6efe4;font-family:Arial,sans-serif;color:#2c1d0f;">
  <div style="max-width:640px;margin:0 auto;padding:32px 20px;">
    <div style="background:#ffffff;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(44,29,15,0.12);">
      <div style="padding:28px 32px;background:linear-gradient(135deg,#5e3e19,#2c1d0f);color:#fff8ec;">
        <div style="font-size:12px;letter-spacing:0.18em;text-transform:uppercase;opacity:0.8;">BIG 4 Coffee Lounge</div>
        <h1 style="margin:14px 0 0;font-size:30px;line-height:1.1;font-weight:700;">Payment confirmed</h1>
      </div>

      <div style="padding:32px;">
        <p style="margin:0 0 16px;font-size:16px;line-height:1.7;">
          Hello {{ recipientName ?: 'there' }},
        </p>
        <p style="margin:0 0 24px;font-size:16px;line-height:1.7;">
          Your payment for order <strong>#{{ order.orderId }}</strong> has been received successfully.
        </p>

        <div style="background:#fbf6ec;border:1px solid rgba(182,133,27,0.16);border-radius:16px;padding:20px 22px;margin-bottom:24px;">
          <p style="margin:0 0 10px;"><strong>Order type:</strong> {{ order.orderType|replace({'_': ' '}) }}</p>
          <p style="margin:0 0 10px;"><strong>Payment method:</strong> {{ order.paymentMethod == 'CARD' ? 'Credit Card' : (order.paymentMethod ?: 'Card') }}</p>
          <p style="margin:0 0 10px;"><strong>Original total:</strong> {{ paymentSummary.displayAmountWithCurrency }}</p>
          {% if paymentSummary.requiresConversion %}
            <p style="margin:0;"><strong>Stripe card charge:</strong> {{ paymentSummary.chargeAmountWithCurrency }}</p>
          {% else %}
            <p style="margin:0;"><strong>Stripe card charge:</strong> {{ paymentSummary.displayAmountWithCurrency }}</p>
          {% endif %}
        </div>

        {% if cartItems is not empty %}
          <h2 style="margin:0 0 14px;font-size:18px;color:#5e3e19;">Order summary</h2>
          <table style="width:100%;border-collapse:collapse;margin-bottom:24px;">
            <tbody>
            {% for item in cartItems %}
              <tr>
                <td style="padding:10px 0;border-bottom:1px solid #efe4d1;">{{ item.name }}</td>
                <td style="padding:10px 0;border-bottom:1px solid #efe4d1;text-align:right;font-weight:700;">{{ item.price|number_format(2) }} TND</td>
              </tr>
            {% endfor %}
            </tbody>
          </table>
        {% endif %}

        <p style="margin:0;font-size:15px;line-height:1.7;">
          Thank you for choosing BIG 4 Coffee Lounge. We look forward to serving you.
        </p>
      </div>
    </div>
  </div>
</body>
</html>
