{% extends 'backend.html.twig' %}

{% block title %}Add New Vehicle - BIG 4 Admin{% endblock %}

{% block topbar_title %}Add New Vehicle{% endblock %}

{% block body %}
<style>
    .add-vehicle-container {
        max-width: 900px;
        margin: 2rem auto;
        padding: 0 1rem;
    }
    
    .form-header {
        margin-bottom: 2.5rem;
    }
    
    .form-header h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2rem;
        color: var(--espresso);
        margin-bottom: 0.5rem;
        font-weight: 600;
    }
    
    .form-header p {
        color: var(--text-2);
        font-size: 0.95rem;
    }
    
    .form-wrapper {
        background: var(--ivory);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 2.5rem;
        box-shadow: 0 2px 12px var(--shadow);
    }
    
    .form-section {
        margin-bottom: 2.5rem;
    }
    
    .form-section:last-of-type {
        margin-bottom: 0;
    }
    
    .form-section-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.2rem;
        color: var(--espresso);
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid var(--gold-pale);
    }
    
    .form-rows {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.8rem;
        margin-bottom: 1.5rem;
    }
    
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }
    
    .form-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-3);
        font-weight: 600;
    }
    
    .form-input,
    .form-select {
        padding: 0.9rem 1.2rem;
        border: 1.5px solid var(--border-2);
        border-radius: 8px;
        font-family: 'Jost', sans-serif;
        font-size: 0.9rem;
        color: var(--text);
        background: var(--ivory-2);
        transition: all 0.2s ease;
    }
    
    .form-input:focus,
    .form-select:focus {
        outline: none;
        border-color: var(--gold);
        background: var(--ivory);
        box-shadow: 0 0 0 3px rgba(184, 135, 42, 0.08);
    }
    
    .form-input::placeholder {
        color: var(--text-3);
    }
    
    .form-error {
        font-size: 0.75rem;
        color: var(--red);
        margin-top: 0.3rem;
    }
    
    .form-actions {
        display: flex;
        gap: 1rem;
        justify-content: flex-start;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        margin-top: 2rem;
    }
    
    .btn-submit {
        padding: 0.95rem 2.5rem;
        background: var(--gold);
        color: var(--ivory);
        border: none;
        border-radius: 8px;
        font-family: 'Jost', sans-serif;
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
        cursor: pointer;
        transition: all 0.2s ease;
        text-transform: uppercase;
    }
    
    .btn-submit:hover {
        background: var(--gold-2);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(184, 135, 42, 0.25);
    }
    
    .btn-submit:active {
        transform: translateY(0);
    }
    
    .btn-cancel {
        padding: 0.95rem 2.5rem;
        background: transparent;
        color: var(--text-2);
        border: 1.5px solid var(--border-2);
        border-radius: 8px;
        font-family: 'Jost', sans-serif;
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-transform: uppercase;
    }
    
    .btn-cancel:hover {
        border-color: var(--gold);
        color: var(--gold);
        background: var(--gold-wash);
    }
    
    .form-hint {
        font-size: 0.75rem;
        color: var(--text-3);
        margin-top: 0.4rem;
        font-style: italic;
    }
</style>

<div class="add-vehicle-container">
    <div class="form-header">
        <h1>Add New Vehicle</h1>
        <p>Register a new vehicle to your fleet and assign it to a delivery driver.</p>
    </div>
    
    <div class="form-wrapper">
        {{ include('fleet_car/_form.html.twig') }}
    </div>
</div>
{% endblock %}
