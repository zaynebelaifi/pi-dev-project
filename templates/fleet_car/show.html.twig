{% extends 'backend.html.twig' %}

{% block title %}Vehicle Details - BIG 4 Admin{% endblock %}

{% block topbar_title %}Vehicle Details{% endblock %}

{% block body %}
<style>
    .fleet-show-card {
        max-width: 920px;
        margin: 2rem auto;
        background: var(--ivory);
        border: 1px solid var(--border);
        border-radius: 14px;
        box-shadow: 0 2px 18px rgba(92,61,30,0.08);
        padding: 2rem;
    }
    .fleet-show-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 2rem;
    }
    .fleet-show-summary {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }
    .fleet-show-meta {
        background: var(--ivory-2);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.5rem;
    }
    .fleet-show-meta h3 {
        margin-bottom: 0.75rem;
        font-family: 'Cormorant Garamond', serif;
        color: var(--espresso);
        font-size: 1.15rem;
    }
    .fleet-detail-row {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.85rem;
    }
    .fleet-detail-label {
        color: var(--text-3);
        font-size: 0.85rem;
        font-weight: 600;
    }
    .fleet-detail-value {
        color: var(--text);
        font-weight: 700;
    }
    .fleet-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 1.5rem; }
    .fleet-link { padding: 0.85rem 1.4rem; border-radius: 10px; background: var(--gold); color: var(--ivory); text-decoration: none; font-weight: 700; }
    .fleet-link:hover { background: var(--gold-2); }
    .fleet-secondary { background: transparent; border: 1.5px solid var(--border-2); color: var(--text-2); }
    .fleet-secondary:hover { border-color: var(--gold); color: var(--gold); background: var(--gold-wash); }
</style>

<div class="fleet-show-card">
    <div class="fleet-show-grid">
        <div class="fleet-show-summary">
            <div>
                <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 2rem; color: var(--espresso); margin-bottom: 0.5rem;">{{ fleet_car.make }} {{ fleet_car.model }}</h2>
                <p style="color: var(--text-2); font-size: 0.95rem;">Vehicle ID #{{ fleet_car.carId }} — manage assignment, update details, or review current driver.</p>
            </div>

            <div class="fleet-show-meta">
                <h3>Vehicle Overview</h3>
                <div class="fleet-detail-row">
                    <span class="fleet-detail-label">License Plate</span>
                    <span class="fleet-detail-value">{{ fleet_car.licensePlate }}</span>
                </div>
                <div class="fleet-detail-row">
                    <span class="fleet-detail-label">Vehicle Type</span>
                    <span class="fleet-detail-value">{{ fleet_car.vehicleType|capitalize }}</span>
                </div>
                <div class="fleet-detail-row">
                    <span class="fleet-detail-label">Assigned Driver</span>
                    <span class="fleet-detail-value">{{ fleet_car.deliveryManId ? fleet_car.deliveryManId : 'Unassigned' }}</span>
                </div>
            </div>
        </div>

        <div class="fleet-show-meta">
            <h3>Quick Actions</h3>
            <div class="fleet-actions">
                <a href="{{ path('app_fleet_car_edit', {'car_id': fleet_car.car_id}) }}" class="fleet-link">Edit Vehicle</a>
                <a href="{{ path('app_fleet_car_index') }}" class="fleet-link fleet-secondary">Back to Fleet</a>
            </div>
            <div style="margin-top:1rem;">
                {{ include('fleet_car/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
