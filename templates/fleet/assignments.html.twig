{% extends 'backend.html.twig' %}

{% block title %}Fleet Assignments - BIG 4 Admin{% endblock %}
{% block topbar_title %}Fleet Assignments{% endblock %}
{% block topbar_breadcrumb %}BIG 4 · Admin · Fleet Assignments{% endblock %}

{% block body %}
<style>
.assignment-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
}
.assignment-card {
    background: #fff;
    border: 1px solid rgba(184,135,42,.16);
    border-radius: 14px;
    padding: 1rem;
    box-shadow: 0 2px 10px rgba(92,61,30,.08);
}
.assignment-actions {
    display: flex;
    gap: .6rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
}
.btn-action {
    border: 0;
    border-radius: 10px;
    padding: .6rem .9rem;
    color: #fff;
    font-weight: 600;
    cursor: pointer;
}
.btn-auto { background: #2E9E6A; }
.btn-refresh { background: #3A7EC9; }
.btn-create { background: #B8872A; }
.assignment-table {
    width: 100%;
    border-collapse: collapse;
}
.assignment-table th, .assignment-table td {
    padding: .7rem;
    border-bottom: 1px solid rgba(184,135,42,.10);
    text-align: left;
    font-size: .84rem;
}
.assignment-table th {
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #7A5C3A;
}
.status-chip {
    display: inline-flex;
    border-radius: 999px;
    padding: .2rem .55rem;
    font-size: .7rem;
    font-weight: 700;
    text-transform: uppercase;
}
.status-active { background: rgba(46,158,106,.12); color: #2E9E6A; }
.status-completed { background: rgba(58,126,201,.12); color: #3A7EC9; }
.status-cancelled { background: rgba(217,64,64,.12); color: #D94040; }
.feedback {
    min-height: 1.2rem;
    color: #7A5C3A;
    margin-top: .6rem;
}
.form-inline {
    display: flex;
    gap: .5rem;
    flex-wrap: wrap;
    align-items: center;
}
.form-inline input {
    border: 1px solid rgba(184,135,42,.25);
    border-radius: 8px;
    padding: .55rem .7rem;
    width: 160px;
}
@media (max-width: 820px) {
    .assignment-table {
        display: block;
        overflow-x: auto;
    }
}
</style>

<div class="assignment-layout">
    <div class="assignment-card">
        <h2 style="margin:0 0 .8rem;">Assignment Operations</h2>
        <div class="assignment-actions">
            <button type="button" class="btn-action btn-refresh" id="refreshAssignmentsBtn">Refresh</button>
            <button type="button" class="btn-action btn-auto" id="autoAssignBtn">Run Auto Assign</button>
        </div>

        <form id="createAssignmentForm" class="form-inline">
            <input type="number" name="carId" placeholder="Car ID" min="1" required>
            <input type="number" name="deliveryManId" placeholder="Delivery Man ID" min="1" required>
            <input type="text" name="reason" placeholder="Reason (manual)">
            <button type="submit" class="btn-action btn-create">Create Assignment</button>
        </form>
        <p class="feedback" id="assignmentFeedback"></p>
    </div>

    <div class="assignment-card">
        <h2 style="margin:0 0 .8rem;">Recent Assignments</h2>
        <table class="assignment-table" id="assignmentsTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Car</th>
                    <th>Delivery Man</th>
                    <th>Status</th>
                    <th>Assigned At</th>
                </tr>
            </thead>
            <tbody>
                <tr><td colspan="5">Loading...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<script>
(() => {
    const feedback = document.getElementById('assignmentFeedback');
    const tableBody = document.querySelector('#assignmentsTable tbody');
    const createForm = document.getElementById('createAssignmentForm');

    const setFeedback = (text, isError = false) => {
        feedback.textContent = text;
        feedback.style.color = isError ? '#D94040' : '#2E9E6A';
    };

    const renderRows = (rows) => {
        if (!Array.isArray(rows) || rows.length === 0) {
            tableBody.innerHTML = '<tr><td colspan="5">No assignments found.</td></tr>';
            return;
        }

        tableBody.innerHTML = rows.map((row) => {
            const status = String(row.status || '').toLowerCase();
            const statusClass = status === 'active' ? 'status-active' : (status === 'completed' ? 'status-completed' : 'status-cancelled');

            return `<tr>
                <td>${row.id ?? ''}</td>
                <td>${row.carId ?? ''}</td>
                <td>${row.deliveryManId ?? ''}</td>
                <td><span class="status-chip ${statusClass}">${row.status ?? ''}</span></td>
                <td>${row.assignedAt ?? ''}</td>
            </tr>`;
        }).join('');
    };

    const loadAssignments = async () => {
        try {
            const res = await fetch('/api/assignments', { headers: { 'Accept': 'application/json' } });
            const payload = await res.json();
            if (!res.ok || payload.status !== 'ok') {
                throw new Error(payload.message || 'Failed to load assignments.');
            }
            renderRows(payload.data || []);
        } catch (e) {
            tableBody.innerHTML = '<tr><td colspan="5">Unable to load assignments.</td></tr>';
            setFeedback(e.message || 'Unable to load assignments.', true);
        }
    };

    document.getElementById('refreshAssignmentsBtn').addEventListener('click', loadAssignments);

    document.getElementById('autoAssignBtn').addEventListener('click', async () => {
        try {
            const res = await fetch('/api/assignments/auto-assign', {
                method: 'POST',
                headers: { 'Accept': 'application/json' }
            });
            const payload = await res.json();
            if (!res.ok || payload.status !== 'ok') {
                throw new Error(payload.message || 'Auto assign failed.');
            }

            setFeedback(`Auto assign done: ${payload.count || 0} assignment(s).`);
            await loadAssignments();
        } catch (e) {
            setFeedback(e.message || 'Auto assign failed.', true);
        }
    });

    createForm.addEventListener('submit', async (event) => {
        event.preventDefault();

        const fd = new FormData(createForm);
        const body = {
            carId: Number(fd.get('carId')),
            deliveryManId: Number(fd.get('deliveryManId')),
            reason: String(fd.get('reason') || 'manual')
        };

        try {
            const res = await fetch('/api/assignments', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify(body)
            });
            const payload = await res.json();
            if (!res.ok || payload.status !== 'ok') {
                throw new Error(payload.message || 'Assignment creation failed.');
            }

            setFeedback('Assignment created successfully.');
            createForm.reset();
            await loadAssignments();
        } catch (e) {
            setFeedback(e.message || 'Assignment creation failed.', true);
        }
    });

    loadAssignments();
})();
</script>
{% endblock %}
