<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BIG 4 — Ultra Luxury Coffee Lounge</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=Jost:wght@300;400;500;600&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">

  <style>
    :root{
      --ivory:#FAF6EF;
      --ivory-2:#F4EDE1;
      --ivory-3:#EFE5D4;
      --gold:#B8872A;
      --gold-2:#D8A84A;
      --gold-soft:#E9D4A5;
      --gold-pale:#FBF5E9;
      --brown:#5C3D1E;
      --brown-2:#7A5732;
      --espresso:#2C1A0E;
      --text:#2C1A0E;
      --text-2:#6D5338;
      --text-3:#A18463;
      --line:rgba(184,135,42,.16);
      --line-2:rgba(184,135,42,.28);
      --shadow:0 20px 60px rgba(92,61,30,.10);
      --shadow-lg:0 24px 80px rgba(92,61,30,.16);
    }

    *{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      font-family:'Jost',sans-serif;
      background:
        radial-gradient(circle at top left, rgba(184,135,42,.08), transparent 28%),
        radial-gradient(circle at bottom right, rgba(184,135,42,.05), transparent 24%),
        linear-gradient(180deg, #fcf9f3 0%, #f8f2e7 48%, #faf6ef 100%);
      color:var(--text);
      overflow-x:hidden;
    }

    a{text-decoration:none;color:inherit}
    img{max-width:100%;display:block}
    .container{width:min(1240px,92vw);margin:auto}

    /* NAV */
    nav{
      position:fixed;
      top:0;left:0;right:0;
      z-index:999;
      height:82px;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:0 3rem;
      background:rgba(250,246,239,0.94);
      backdrop-filter:blur(18px);
      border-bottom:1px solid rgba(184,135,42,.12);
      box-shadow:0 2px 20px rgba(92,61,30,.08);
      transition:all .35s ease;
    }
    nav.scrolled{
      box-shadow:0 8px 32px rgba(92,61,30,.14);
      background:rgba(250,246,239,0.98);
    }
    .nav-inner{
      width:min(1320px,94vw);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:1rem;
    }
    .brand{display:flex;align-items:center;gap:10px}
    .brand img{height:46px;width:46px;object-fit:contain}
    .brand h1{
      font-family:'Playfair Display',serif;
      font-size:1.2rem;
      font-weight:700;
      color:var(--gold);
      letter-spacing:.08em;
      line-height:1
    }
    .brand span{
      display:block;
      font-size:.52rem;
      letter-spacing:.3em;
      text-transform:uppercase;
      color:var(--text-3);
      margin-top:2px
    }

    .nav-links{
      display:flex;
      align-items:center;
      gap:.35rem;
      list-style:none
    }

    .nav-links a{
      display:block;
      padding:.8rem 1.1rem;
      color:var(--text-2);
      font-size:.72rem;
      font-weight:600;
      letter-spacing:.15em;
      text-transform:uppercase;
      position:relative;
      border-radius:40px;
      overflow:hidden;
      transition:all .35s ease;
      z-index:1;
    }
    .nav-links a::before{
      content:'';
      position:absolute;
      inset:0;
      background:linear-gradient(135deg, rgba(255,255,255,.9), rgba(233,212,165,.95));
      border:1px solid rgba(184,135,42,.28);
      border-radius:40px;
      transform:translateY(12px) scale(.92);
      opacity:0;
      transition:all .35s ease;
      box-shadow:0 10px 28px rgba(184,135,42,.18);
      z-index:-1;
    }
    .nav-links a::after{
      content:'';
      position:absolute;
      width:50%;
      height:140%;
      left:-70%;
      top:-20%;
      background:linear-gradient(90deg, transparent, rgba(255,255,255,.6), transparent);
      transform:skewX(-22deg);
      transition:all .6s ease;
      opacity:0;
    }
    .nav-links a:hover{ color:var(--gold); transform:translateY(-3px); }
    .nav-links a:hover::before{ opacity:1; transform:translateY(0) scale(1); }
    .nav-links a:hover::after{ left:120%; opacity:1; }

    .nav-actions{ display:flex; align-items:center; gap:.8rem; }

    .cart-btn, .profile-btn, .nav-btn{
      display:flex;
      align-items:center;
      justify-content:center;
      gap:.5rem;
      padding:.78rem 1.3rem;
      border:1px solid var(--gold);
      border-radius:40px;
      color:var(--gold);
      font-size:.68rem;
      font-weight:600;
      letter-spacing:.14em;
      text-transform:uppercase;
      transition:all .3s;
      background:linear-gradient(180deg,#fff8eb,#f2e2bb);
      box-shadow:0 8px 0 #c39134,0 14px 28px rgba(184,135,42,.20);
      cursor:pointer;
    }
    .cart-btn:hover, .profile-btn:hover, .nav-btn:hover{
      transform:translateY(2px);
      box-shadow:0 5px 0 #c39134,0 10px 20px rgba(184,135,42,.18);
      background:linear-gradient(180deg,#fffaf1,#ecd49c);
      color:var(--brown);
    }

    .cart-badge{
      background:var(--gold);
      color:#fff;
      min-width:22px;
      height:22px;
      border-radius:50%;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      font-size:.7rem;
      padding:0 6px;
      font-weight:700;
      box-shadow:0 6px 14px rgba(184,135,42,.28);
    }

    /* HERO */
    .hero{
      min-height:100vh;
      padding:130px 0 80px;
      display:grid;
      align-items:center;
      position:relative;
      overflow:hidden;
      isolation:isolate;
    }
    .hero::before{
      content:'';
      position:absolute;inset:0;
      background:
        linear-gradient(90deg, rgba(250,246,239,.90) 0%, rgba(250,246,239,.72) 42%, rgba(250,246,239,.30) 70%, rgba(250,246,239,.84) 100%),
        url('https://images.unsplash.com/photo-1559339352-11d035aa65de?auto=format&fit=crop&w=1800&q=80') center/cover no-repeat;
      z-index:-2;
      transform:scale(1.02);
    }
    .hero::after{
      content:'';
      position:absolute;inset:0;
      background:
        radial-gradient(circle at 75% 28%, rgba(184,135,42,.12), transparent 18%),
        linear-gradient(to top, rgba(250,246,239,.72), rgba(250,246,239,.02));
      z-index:-1;
    }

    .hero-grid{ display:grid; grid-template-columns:1.18fr .82fr; align-items:center; gap:2.5rem }

    .eyebrow{
      display:inline-flex;
      align-items:center;
      gap:1rem;
      font-size:.62rem;
      letter-spacing:.4em;
      text-transform:uppercase;
      color:var(--gold-2);
      margin-bottom:1.6rem
    }
    .eyebrow::before,.eyebrow::after{ content:''; width:34px; height:1px; background:var(--gold-2); opacity:.65 }

    .hero h2{
      font-family:'Cormorant Garamond',serif;
      font-size:clamp(4rem,8vw,7.2rem);
      font-weight:300;
      line-height:.92;
      letter-spacing:-.02em;
      color:var(--espresso);
      margin-bottom:.65rem
    }
    .hero h2 em{font-style:italic;color:var(--gold)}
    .hero-sub{ font-size:.68rem; letter-spacing:.38em; text-transform:uppercase; color:var(--text-3); margin-bottom:1.4rem }
    .hero p.lead{ max-width:620px; color:var(--text-2); font-size:1rem; line-height:2; margin-bottom:2.6rem }
    .hero-actions{display:flex;gap:1rem;flex-wrap:wrap}

    .btn-primary,.btn-secondary,.add-cart-btn{
      display:inline-block;
      padding:1rem 1.6rem;
      border-radius:50px;
      position:relative;
      top:0;
      transition:.28s ease;
      border:1px solid rgba(92,61,30,.14);
      background:linear-gradient(180deg,#ffffff,#f2eadc);
      color:var(--brown);
      box-shadow:0 10px 0 #d7c8ad,0 18px 34px rgba(92,61,30,.10)
    }
    .btn-primary,.add-cart-btn{
      background:linear-gradient(180deg,#e7bd63 0%, #d8a84a 50%, #b8872a 100%);
      color:#fff;
      box-shadow:0 10px 0 #8f651d,0 18px 38px rgba(184,135,42,.28);
      border:1px solid rgba(255,255,255,.25);
      cursor:pointer;
    }
    .btn-primary:hover,.add-cart-btn:hover{ top:3px; box-shadow:0 7px 0 #8f651d,0 12px 24px rgba(184,135,42,.22) }
    .btn-secondary{ border:1px solid rgba(92,61,30,.18); background:rgba(255,255,255,.45); color:var(--brown) }
    .btn-secondary:hover{ top:3px; box-shadow:0 7px 0 #d7c8ad,0 12px 22px rgba(92,61,30,.10); border-color:var(--gold); color:var(--gold) }

    .hero-card{
      justify-self:end;
      width:min(350px,100%);
      background:rgba(255,255,255,.58);
      backdrop-filter:blur(16px);
      border:1px solid rgba(184,135,42,.16);
      padding:2rem;
      box-shadow:var(--shadow-lg);
      position:relative;
      overflow:hidden;
      border-radius:28px;
    }
    .hero-card::before{
      content:'';
      position:absolute;
      inset:0;
      border:1px solid rgba(184,135,42,.08);
      margin:12px;
      pointer-events:none;
      border-radius:20px;
    }
    .hero-card small{ display:block; color:var(--text-3); font-size:.72rem; letter-spacing:.25em; text-transform:uppercase; margin-bottom:1rem }
    .hero-card h3{ font-family:'Cormorant Garamond',serif; font-size:1.8rem; color:var(--espresso); font-weight:500; margin-bottom:1rem }
    .hero-card p{ color:var(--text-2); line-height:1.9; font-size:.95rem; margin-bottom:1.6rem }

    .hero-stats{ display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; padding-top:1.2rem; border-top:1px solid rgba(184,135,42,.14) }
    .hero-stats div strong{ display:block; font-family:'Cormorant Garamond',serif; font-size:2rem; color:var(--gold); font-weight:600 }
    .hero-stats div span{ font-size:.72rem; letter-spacing:.12em; text-transform:uppercase; color:var(--text-3) }

    section{padding:7rem 0}
    .section-head{ display:flex; justify-content:space-between; align-items:end; gap:2rem; margin-bottom:3rem }
    .section-head small{ font-size:.65rem; letter-spacing:.34em; text-transform:uppercase; color:var(--gold) }
    .section-head h3{ font-family:'Cormorant Garamond',serif; font-size:clamp(2.4rem,5vw,4rem); font-weight:300; color:var(--espresso) }
    .section-head h3 em{font-style:italic;color:var(--gold)}
    .section-head p{max-width:520px;line-height:1.95;color:var(--text-2)}

    .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center}
    .about-image{ position:relative; height:620px; overflow:hidden; border:1px solid var(--line); box-shadow:var(--shadow); border-radius:28px; }
    .about-image img{width:100%;height:100%;object-fit:cover;filter:brightness(.94) contrast(1.02)}
    .about-image::after{content:'';position:absolute;inset:0;background:linear-gradient(to top, rgba(250,246,239,.18), transparent 38%)}
    .about-panel{ background:rgba(255,255,255,.72); border:1px solid var(--line); padding:3rem; box-shadow:var(--shadow); border-radius:28px; }
    .about-panel p{line-height:2;color:var(--text-2);font-size:1rem;margin:1.2rem 0 2rem}
    .stats-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem}
    .stat{ padding:1.4rem; background:rgba(255,255,255,.7); border:1px solid rgba(184,135,42,.10); border-radius:20px; box-shadow:0 10px 0 #e8dcc9,0 18px 28px rgba(92,61,30,.05); }
    .stat strong{display:block;font-family:'Cormorant Garamond',serif;font-size:2.4rem;color:var(--gold)}
    .stat span{font-size:.76rem;letter-spacing:.14em;text-transform:uppercase;color:var(--text-3)}

    .features{background:linear-gradient(180deg, rgba(255,255,255,.45), rgba(244,237,225,.75))}
    .cards{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
    .card{ padding:2rem; background:linear-gradient(180deg,rgba(255,255,255,.92),rgba(248,242,231,.95)); border:1px solid var(--line); transition:.35s ease; position:relative; overflow:hidden; box-shadow:0 12px 0 #e7dcc7,0 22px 34px rgba(92,61,30,.08); border-radius:20px }
    .card::before{ content:''; position:absolute; inset:0; background:radial-gradient(circle at top right, rgba(184,135,42,.10), transparent 24%); opacity:0; transition:.35s ease }
    .card:hover{ transform:translateY(4px); box-shadow:0 8px 0 #e7dcc7,0 14px 24px rgba(92,61,30,.08); border-color:var(--line-2) }
    .card:hover::before{opacity:1}
    .card .number{font-family:'Cormorant Garamond',serif;font-size:4rem;color:rgba(184,135,42,.10);margin-bottom:1rem}
    .card h4{font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:var(--espresso);margin-bottom:.8rem;font-weight:500}
    .card p{line-height:1.95;color:var(--text-2)}

    .menu-grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:1.4rem; }
    .menu-card{ background:linear-gradient(180deg, rgba(255,255,255,.95), rgba(247,240,228,.96)); border:1px solid var(--line); border-radius:24px; overflow:hidden; box-shadow:0 12px 0 #e7dcc7,0 22px 34px rgba(92,61,30,.08); transition:.35s ease; position:relative; }
    .menu-card:hover{ transform:translateY(5px); box-shadow:0 8px 0 #e7dcc7,0 14px 24px rgba(92,61,30,.08); }
    .menu-card img{ width:100%; height:220px; object-fit:cover; }
    .menu-card-content{padding:1.6rem}
    .menu-card h4{ font-family:'Cormorant Garamond',serif; font-size:2rem; color:var(--espresso); margin-bottom:.5rem; }
    .menu-card p{ color:var(--text-2); line-height:1.9; margin-bottom:1rem; min-height:96px; }
    .price{ color:var(--gold); font-weight:700; letter-spacing:.08em; font-size:.95rem; text-transform:uppercase; margin-bottom:1rem; display:block; }

    .gallery-grid{ display:grid; grid-template-columns:1fr 1fr 1fr; grid-auto-rows:170px; gap:1rem }
    .gallery-item{ position:relative; overflow:hidden; border:1px solid var(--line); box-shadow:var(--shadow); border-radius:22px; }
    .gallery-item img{ width:100%; height:100%; object-fit:cover; transition:transform .8s ease, filter .4s ease; filter:brightness(.92) }
    .gallery-item:hover img{transform:scale(1.06);filter:brightness(1)}
    .gallery-item::after{ content:''; position:absolute; inset:0; background:linear-gradient(to top, rgba(44,26,14,.50), transparent 42%) }
    .gallery-item span{ position:absolute; left:1.3rem; bottom:1.2rem; z-index:2; font-family:'Cormorant Garamond',serif; font-size:1.2rem; color:var(--ivory) }

    .event-list{display:grid;gap:1rem}
    .event{ display:grid; grid-template-columns:120px 1fr auto; gap:2rem; align-items:center; padding:1.6rem 1.4rem; border:1px solid var(--line); background:rgba(255,255,255,.72); transition:.3s ease; border-radius:22px; box-shadow:0 12px 28px rgba(92,61,30,.05); }
    .event:hover{ transform:translateX(6px); border-color:var(--line-2); background:var(--gold-pale) }
    .date strong{display:block;font-family:'Cormorant Garamond',serif;font-size:3rem;color:var(--gold);line-height:1}
    .date span{font-size:.72rem;letter-spacing:.24em;text-transform:uppercase;color:var(--text-3)}
    .event h5{font-family:'Cormorant Garamond',serif;font-size:1.7rem;color:var(--espresso);font-weight:500;margin-bottom:.35rem}
    .event p{color:var(--text-2);line-height:1.85}
    .badge{ padding:.75rem 1rem; border:1px solid rgba(184,135,42,.18); font-size:.7rem; letter-spacing:.18em; text-transform:uppercase; color:var(--gold); background:rgba(255,255,255,.7); border-radius:999px; }

    .cta{padding:7rem 0 8rem}
    .cta-box{ position:relative; overflow:hidden; border:1px solid var(--line); padding:4rem 2rem; text-align:center; background:linear-gradient(135deg, rgba(184,135,42,.10), rgba(255,255,255,.75) 35%, rgba(255,255,255,.6)); box-shadow:var(--shadow); border-radius:32px; }
    .cta-box::before{ content:'BIG 4'; position:absolute; inset:auto 0 0 0; text-align:center; font-family:'Cormorant Garamond',serif; font-size:18vw; color:rgba(184,135,42,.05); font-weight:700; line-height:.8; pointer-events:none }
    .cta-box h3{ font-family:'Cormorant Garamond',serif; font-size:clamp(2.5rem,5vw,4.4rem); font-weight:300; position:relative; z-index:1; color:var(--espresso) }
    .cta-box p{ max-width:720px; margin:1rem auto 2rem; line-height:1.95; color:var(--text-2); position:relative; z-index:1 }

    footer{ padding:5rem 0 2rem; border-top:1px solid var(--line); background:linear-gradient(180deg, #f5efe3 0%, #efe5d4 100%) }
    .footer-grid{display:grid;grid-template-columns:1.3fr 1fr 1fr 1fr;gap:2rem}
    .footer-brand p,.footer-col a,.footer-col address{color:var(--text-2);line-height:2}
    .footer-brand h4{font-family:'Cormorant Garamond',serif;font-size:2rem;color:var(--gold);margin:.8rem 0}
    .footer-col h6{font-size:.72rem;letter-spacing:.28em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem}
    .footer-bottom{ margin-top:3rem; padding-top:1.4rem; border-top:1px solid rgba(184,135,42,.12); display:flex; justify-content:space-between; gap:1rem; color:var(--text-3); font-size:.85rem }

    .reveal{ opacity:0; transform:translateY(60px) scale(.96); filter:blur(8px); transition:all 1.1s cubic-bezier(.2,.8,.2,1); will-change:transform, opacity, filter; }
    .reveal.show{ opacity:1; transform:translateY(0) scale(1); filter:blur(0); }
    .reveal-left{ opacity:0; transform:translateX(-60px) scale(.97); filter:blur(8px); transition:all 1s cubic-bezier(.2,.8,.2,1); }
    .reveal-right{ opacity:0; transform:translateX(60px) scale(.97); filter:blur(8px); transition:all 1s cubic-bezier(.2,.8,.2,1); }
    .reveal-left.show,.reveal-right.show{ opacity:1; transform:translateX(0) scale(1); filter:blur(0); }

    /* BOOKING POPUP */
    .popup-overlay, .cart-overlay, .profile-overlay{
      position:fixed; inset:0; background:rgba(34,20,10,.55); backdrop-filter:blur(8px);
      display:flex; align-items:center; justify-content:center; z-index:2000;
      opacity:0; pointer-events:none; transition:.35s ease; padding:1rem;
    }
    .popup-overlay.active, .cart-overlay.active, .profile-overlay.active{ opacity:1; pointer-events:auto; }
    .popup-box, .profile-box{
      width:min(560px,95vw);
      background:linear-gradient(180deg, rgba(255,255,255,.98), rgba(247,240,228,.98));
      border:1px solid rgba(184,135,42,.22); border-radius:30px; padding:2rem;
      box-shadow:0 30px 80px rgba(44,26,14,.22);
      transform:translateY(30px) scale(.96); transition:.35s ease; position:relative;
    }
    .popup-overlay.active .popup-box, .profile-overlay.active .profile-box{ transform:translateY(0) scale(1); }
    .close-popup{ position:absolute; top:16px; right:16px; width:42px; height:42px; border:none; border-radius:50%; background:rgba(184,135,42,.10); color:var(--gold); font-size:1.3rem; cursor:pointer; }
    .popup-box h3, .profile-box h3{ font-family:'Cormorant Garamond',serif; font-size:2.6rem; font-weight:400; color:var(--espresso); margin-bottom:.5rem; }
    .popup-box p, .profile-box p{ color:var(--text-2); margin-bottom:1.5rem; line-height:1.9; }

    .booking-form{ display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
    .booking-form .full{grid-column:1/-1}
    .booking-form input,.booking-form select{
      width:100%; padding:1rem 1.1rem; border-radius:18px; border:1px solid rgba(184,135,42,.18);
      background:rgba(255,255,255,.9); outline:none; font-family:'Jost',sans-serif;
      font-size:.95rem; color:var(--brown); transition:.25s ease;
    }
    .booking-form input:focus,.booking-form select:focus{ border-color:var(--gold); box-shadow:0 0 0 4px rgba(184,135,42,.10); }

    /* TABLE PICKER */
    .table-pick-grid{ display:grid; grid-template-columns:repeat(auto-fill,minmax(110px,1fr)); gap:.75rem; margin-bottom:1rem; }
    .table-pick-label{ cursor:pointer; }
    .table-pick-label input[type=radio]{ display:none; }
    .table-pick-card{ border:1.5px solid rgba(184,135,42,.22); border-radius:16px; padding:1rem .75rem; text-align:center; background:rgba(255,255,255,.75); transition:.25s ease; position:relative; }
    .table-pick-card:hover{ border-color:var(--gold-2); background:rgba(251,245,233,.9); }
    .table-pick-label input[type=radio]:checked + .table-pick-card{ border-color:var(--gold); background:var(--gold-pale); box-shadow:0 0 0 3px rgba(184,135,42,.18); }
    .table-pick-num{ font-family:'Cormorant Garamond',serif; font-size:2rem; color:var(--gold); line-height:1; }
    .table-pick-lbl{ font-size:.62rem; letter-spacing:.14em; text-transform:uppercase; color:var(--text-3); margin-top:.2rem; }
    .table-pick-seats{ font-size:.78rem; color:var(--brown); margin-top:.35rem; font-weight:600; }
    .table-pick-dot{ position:absolute; top:8px; right:8px; width:7px; height:7px; border-radius:50%; background:#2E9E6A; }

    .cart-overlay{ justify-content:flex-end; padding:0; }
    .cart-drawer{
      width:min(430px,100%); height:100vh;
      background:linear-gradient(180deg, rgba(255,255,255,.98), rgba(247,240,228,.98));
      border-left:1px solid rgba(184,135,42,.16); box-shadow:-20px 0 60px rgba(44,26,14,.18);
      padding:2rem; transform:translateX(100%); transition:.4s ease; overflow-y:auto; position:relative;
    }
    .cart-overlay.active .cart-drawer{ transform:translateX(0); }

    .checkout-overlay{
      position:fixed; inset:0; background:rgba(34,20,10,.65); backdrop-filter:blur(10px);
      display:flex; align-items:center; justify-content:center; z-index:3000;
      opacity:0; pointer-events:none; transition:.35s ease; padding:1rem;
    }
    .checkout-overlay.active{ opacity:1; pointer-events:auto; }
    .checkout-box{
      width:min(600px,100%);
      background:linear-gradient(180deg, rgba(255,255,255,.98), rgba(247,240,228,.98));
      border:1px solid rgba(184,135,42,.22); border-radius:30px; padding:2rem;
      box-shadow:0 30px 80px rgba(44,26,14,.22);
      transform:translateY(30px) scale(.96); transition:.35s ease; position:relative;
    }
    .checkout-overlay.active .checkout-box{ transform:translateY(0) scale(1); }
    .checkout-box h3{ font-family:'Cormorant Garamond',serif; font-size:2.3rem; color:var(--espresso); margin-bottom:.5rem; }
    .checkout-box p{ color:var(--text-2); margin-bottom:1rem; line-height:1.8; }
    .checkout-summary{ display:grid; gap:1rem; margin-bottom:1.5rem; border:1px solid rgba(184,135,42,.14); border-radius:22px; padding:1.5rem; background:rgba(255,255,255,.85); }
    .checkout-item{ display:flex; justify-content:space-between; gap:1rem; color:var(--brown); font-weight:600; }
    .checkout-total{ display:flex; justify-content:space-between; gap:1rem; font-size:1rem; color:var(--brown); font-weight:700; }
    .checkout-field{ display:grid; gap:.75rem; margin-bottom:1rem; }
    .checkout-field input, .checkout-field textarea{ width:100%; border:1px solid rgba(184,135,42,.18); border-radius:18px; padding:1rem 1rem; font-family:'Jost',sans-serif; font-size:.95rem; outline:none; background:rgba(255,255,255,.95); }
    .checkout-field textarea{resize:vertical;min-height:100px}
    .checkout-field input:focus, .checkout-field textarea:focus{ border-color:var(--gold); box-shadow:0 0 0 4px rgba(184,135,42,.10); }
    .cart-header{ display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; }
    .cart-header h3{ font-family:'Cormorant Garamond',serif; font-size:2.3rem; color:var(--espresso); font-weight:500; }
    .cart-items{ display:flex; flex-direction:column; gap:1rem; margin-bottom:1.8rem; }
    .cart-item{ display:flex; justify-content:space-between; gap:1rem; background:rgba(255,255,255,.75); border:1px solid rgba(184,135,42,.12); border-radius:20px; padding:1rem; box-shadow:0 10px 22px rgba(92,61,30,.05); }
    .cart-item h4{ font-family:'Cormorant Garamond',serif; font-size:1.4rem; color:var(--espresso); margin-bottom:.2rem; }
    .cart-item p{ color:var(--text-3); font-size:.9rem; }
    .remove-btn{ border:none; background:rgba(184,135,42,.08); color:var(--gold); padding:.6rem .9rem; border-radius:14px; cursor:pointer; font-weight:600; transition:.25s ease; }
    .remove-btn:hover{ background:rgba(184,135,42,.14); }
    .cart-footer{ border-top:1px solid rgba(184,135,42,.14); padding-top:1.5rem; }
    .cart-total{ display:flex; justify-content:space-between; align-items:center; margin-bottom:1.2rem; font-size:1.05rem; color:var(--brown); font-weight:600; }
    .cart-total strong{ color:var(--gold); font-size:1.3rem; }
    .empty-cart{ text-align:center; color:var(--text-3); padding:2rem 0; font-size:1rem; }

    @media (max-width:1080px){
      .hero-grid,.about-grid,.footer-grid,.section-head{grid-template-columns:1fr;display:grid}
      .cards,.gallery-grid,.menu-grid{grid-template-columns:1fr}
      .hero-card{justify-self:start}
      .nav-links{display:none}
      .event{grid-template-columns:1fr}
      .badge{justify-self:start}
      nav{padding:0 1rem}
      .nav-actions{ gap:.5rem; flex-wrap:wrap; justify-content:flex-end; }
      .cart-btn, .profile-btn, .nav-btn{ padding:.72rem 1rem; font-size:.62rem; }
    }
    @media (max-width:640px){
      nav{height:82px}
      .brand h1{font-size:1.05rem}
      .hero h2{font-size:3.4rem}
      .hero-actions{flex-direction:column;align-items:stretch}
      .btn-primary,.btn-secondary,.nav-btn,.cart-btn,.profile-btn,.add-cart-btn{width:100%;text-align:center}
      .hero-card,.about-panel{padding:1.5rem}
      .about-image{height:420px}
      section{padding:5rem 0}
      .footer-bottom{flex-direction:column;text-align:center}
      .booking-form{grid-template-columns:1fr}
      .cart-drawer{width:100%}
    }
  </style>
</head>
