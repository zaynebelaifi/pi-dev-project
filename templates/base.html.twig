              <span class="price">--</span>
            </div>
          </div>
        </div>
      {% endif %}
    </div>
  </section>

  <!-- GALLERY -->
  <section id="gallery">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <small>Visual Atmosphere</small>
          <h3>Inside the <em>BIG 4</em> Experience</h3>
        </div>
        <p>Elegant interiors, signature drinks, and warm lighting - a destination designed to feel cinematic and unforgettable.</p>
      </div>
      <div class="gallery-grid">
        <div class="gallery-item reveal"><img src="https://images.unsplash.com/photo-1552566626-52f8b828add9?auto=format&fit=crop&w=1200&q=80" alt="Luxury lounge interior"><span>Elegant Lounge Ambience</span></div>
        <div class="gallery-item reveal"><img src="https://images.unsplash.com/photo-1509042239860-f550ce710b93?auto=format&fit=crop&w=900&q=80" alt="Coffee presentation"><span>Signature Coffee</span></div>
        <div class="gallery-item reveal"><img src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?auto=format&fit=crop&w=900&q=80" alt="Restaurant table setup"><span>Fine Dining Touch</span></div>
        <div class="gallery-item reveal"><img src="https://images.unsplash.com/photo-1515669097368-22e68427d265?auto=format&fit=crop&w=900&q=80" alt="Dessert plating"><span>Curated Desserts</span></div>
        <div class="gallery-item reveal"><img src="https://images.unsplash.com/photo-1521017432531-fbd92d768814?auto=format&fit=crop&w=900&q=80" alt="Elegant drinks"><span>Evening Signatures</span></div>
        <div class="gallery-item reveal"><img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&w=900&q=80" alt="Food"><span>Luxury Dining</span></div>
      </div>
    </div>
  </section>

  <!-- DELIVERY -->
  <section id="delivery">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <small>Fast Service</small>
          <h3>Elegant <em>Delivery</em> at Your Door</h3>
        </div>
        <p>Enjoy BIG 4 from the comfort of your home with premium packaging, stylish presentation, and carefully delivered orders.</p>
      </div>

      <div class="cards">
        <div class="card reveal"><div class="number">01</div><h4>Fast Arrival</h4><p>Freshly prepared items delivered promptly while preserving temperature, presentation, and taste.</p></div>
        <div class="card reveal"><div class="number">02</div><h4>Premium Packaging</h4><p>Luxury-inspired packaging designed to keep your order elegant and intact from our lounge to your table.</p></div>
        <div class="card reveal"><div class="number">03</div><h4>Easy Ordering</h4><p>A seamless experience for coffee, desserts, and signature dishes whenever you want BIG 4 at home.</p></div>
      </div>
    </div>
  </section>

  <!-- EVENTS -->
  <section id="events">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <small>Upcoming Moments</small>
          <h3>Events & <em>Exclusive Nights</em></h3>
        </div>
        <p>Open the donation calendar, pick an event, and leave your rating directly from the event detail page.</p>
      </div>
      <div class="event-list">
        <a class="event event-card-link reveal" href="{{ path('app_client_food_donation_calendar') }}">
          <div class="date">
            <strong>All</strong>
            <span>Calendar</span>
          </div>
          <div>
            <h5>Food Donation Calendar</h5>
            <p>Click anywhere on this card to open the calendar page.</p>
          </div>
        </a>

        {% if donationEvents is defined and donationEvents is not empty %}
          {% for event in donationEvents %}
            {% set eventDate = event.eventDate %}
            {% set eventStatus = event.status ?: 'Scheduled' %}
            {% set eventStatusKey = eventStatus|lower %}
            {% set eventStatusApiClass = eventStatusKey == 'in progress' ? 'in_progress' : eventStatusKey %}
            <div class="event reveal" data-event-id="{{ event.donationEventId }}">
              <div class="date">
                <strong>{{ eventDate ? eventDate|date('d') : '--' }}</strong>
                <span>{{ eventDate ? eventDate|date('M') : 'TBD' }}</span>
              </div>
              <div>
                <h5>{{ event.charityName ?: ('Event #' ~ event.donationEventId) }}</h5>
                <p>
                  {{ eventDate ? eventDate|date('F j, Y H:i') : 'Date to be announced' }}
                  · {{ event.totalQuantity }} items
                  · <span data-registration-count-for="{{ event.donationEventId }}">{{ registrationCounts[event.donationEventId]|default(0) }}</span> registered
                  · <span class="status status-{{ eventStatusApiClass }}" data-event-status>{{ eventStatus }}</span>
                  {% if event.deliveryId %}· Delivery #{{ event.deliveryId }}{% endif %}
                </p>
                {% if isUserLoggedIn is defined and isUserLoggedIn and eventStatusKey == 'scheduled' %}
                  <div class="event-inline-actions" data-register-wrapper data-registered="{{ event.donationEventId in (registeredEventIds|default([])) ? '1' : '0' }}">
                    {% if event.donationEventId in (registeredEventIds|default([])) %}
                      <span class="event-registered-btn">Registered</span>
                    {% else %}
                      <form method="post" action="{{ path('app_client_food_donation_register', {'id': event.donationEventId}) }}" class="js-event-register-form" data-event-id="{{ event.donationEventId }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('register-event' ~ event.donationEventId) }}">
                        <button type="submit" class="event-register-btn-ui">Register</button>
                      </form>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        {% else %}
          <div class="event reveal">
            <div class="date"><strong>--</strong><span>--</span></div>
            <div>
              <h5>No donation events yet</h5>
              <p>New food donation events will appear here as soon as they are created.</p>
            </div>
          </div>
        {% endif %}
      </div>

      {% if isUserLoggedIn is defined and isUserLoggedIn %}
        <div class="my-registered-events-cta">
          <button type="button" class="btn-secondary" id="openMyRegisteredEvents">My Registered Events</button>
        </div>
      {% endif %}
    </div>
  </section>

  <!-- AI RECOMMENDATIONS SECTION -->
  <section class="recommended-events-section" id="ai-recommendations">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <small>Personalized With AI</small>
          <h3><span class="ai-badge">AI Picks For You</span> Recommended <em>Events</em></h3>
        </div>
        <p class="recommended-subtitle">Based on events you have registered for before.</p>
      </div>

      <div
        id="recommendations"
        class="events-container"
        data-authenticated="{{ isUserLoggedIn is defined and isUserLoggedIn ? '1' : '0' }}"
        data-user-role="{{ app.request.session.get('user_role') ?: '' }}"
      >
        {% if isUserLoggedIn is defined and isUserLoggedIn %}
          <div class="loading-spinner">
            <div class="spinner"></div>
            <p>Finding perfect events for you...</p>
          </div>
        {% else %}
          <div class="recommendation-empty">
            Login to see personalized AI event recommendations.
            <div style="margin-top:.65rem;"><a href="{{ path('app_login') }}" class="rec-login-btn">Login to Register</a></div>
          </div>
        {% endif %}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="container">
      <div class="cta-box reveal">
        <h3>Your <span style="color:var(--gold);font-style:italic">Luxury Order</span></h3>
        <p>Add your favorite espresso, desserts, brunch selections, and signature dishes for a premium at-home experience.</p>
        <div class="hero-actions" style="justify-content:center;position:relative;z-index:1">
          <button class="btn-primary" id="openCart2">View Cart</button>
          <a href="#delivery" class="btn-secondary">Track Delivery</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer id="profile">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <h4>BIG 4 Coffee Lounge</h4>
          <p>An elegant destination in Tunis where refined coffee, sophisticated dining, and unforgettable evenings come together.</p>
        </div>
        <div class="footer-col">
          <h6>Navigate</h6>
          <a href="#home">Home</a><br>
          <a href="#about">About</a><br>
          <a href="#menu-section">Menu</a><br>
          <a href="#gallery">Gallery</a>
        </div>
        <div class="footer-col">
          <h6>Experience</h6>
          <a href="#">Reservations</a><br>
          <a href="#events">Events</a><br>
          <a href="#">Private Booking</a><br>
          <a href="#">Loyalty Program</a>
        </div>
        <div class="footer-col">
          <h6>Contact</h6>
          <address>
            Tunis, Tunisia<br>
            info@big4lounge.tn<br>
            +216 XX XXX XXX<br>
            Daily - 8 AM - Midnight
          </address>
        </div>
      </div>
      <div class="footer-bottom">
        <span>&copy; {{ "now"|date("Y") }} BIG 4 Coffee Lounge. All rights reserved.</span>
        <span>Privacy Policy - Terms</span>
      </div>
    </div>
  </footer>

  <!-- BOOKING POPUP -->
  <div class="popup-overlay" id="bookingPopup">
    <div class="popup-box">
      <button class="close-popup" id="closeBooking">&times;</button>
      <h3>Reserve Your Table</h3>
      <p>Book your luxury dining moment at BIG 4. Select your preferred date, time, and guest count.</p>

      <form class="booking-form" id="bookingForm">
        <div class="full">
          <input type="text" placeholder="Full Name" required>
        </div>
        <div>
          <input type="date" required>
        </div>
        <div>
          <input type="time" required>
        </div>
        <div class="full">
          <select required>
            <option value="">Select Guests</option>
            <option>1 Guest</option>
            <option>2 Guests</option>
            <option>3 Guests</option>
            <option>4 Guests</option>
            <option>5 Guests</option>
            <option>6+ Guests</option>
          </select>
        </div>
        <div class="full">
          <button type="submit" class="btn-primary" style="width:100%">Confirm Booking</button>
        </div>
      </form>
    </div>
  </div>

  <!-- PROFILE POPUP -->
  <div class="profile-overlay" id="profilePopup">
    <div class="profile-box">
      <button class="close-popup" id="closeProfile">&times;</button>
      <h3>Your Profile</h3>
      <p>Welcome to BIG 4 Lounge. Your profile can be used for future reservations, loyalty rewards, and personalized dining experiences.</p>

      <form class="booking-form" id="profileForm" method="post" action="{{ path('app_profile_quick_save') }}" data-authenticated="{{ isUserLoggedIn is defined and isUserLoggedIn ? '1' : '0' }}">
        <input type="hidden" name="_token" value="{{ csrf_token('profile_quick_save') }}">
        <div class="full">
          <input type="text" name="full_name" placeholder="Full Name" value="{{ user_name ?: '' }}">
        </div>
        <div>
          <input type="email" name="email" placeholder="Email Address" value="{{ user_email ?: '' }}">
        </div>
        <div>
          <input type="tel" name="phone" placeholder="Phone Number" value="{{ user_phone ?: '' }}">
        </div>
        <div class="full">
          <input type="text" name="address" placeholder="Address (optional)" value="{{ user_address ?: '' }}">
        </div>
        <div class="full">
          <button type="submit" class="btn-primary" style="width:100%">Save Profile</button>
        </div>
      </form>
    </div>
  </div>

  {% if isUserLoggedIn is defined and isUserLoggedIn %}
    <div class="popup-overlay" id="myRegisteredEventsPopup">
      <div class="popup-box my-events-popup-box">
        <div class="my-events-popup-head">
          <div>
            <h3 style="margin:0 0 .25rem;">My Registered Events</h3>
            <p style="margin:0;font-size:.82rem;color:var(--text-2);">Your current donation event registrations.</p>
          </div>
          <button class="close-popup" id="closeMyRegisteredEvents" style="position:static;flex-shrink:0;">&times;</button>
        </div>

        <div class="my-events-grid">
          {% if myRegisteredEvents is defined and myRegisteredEvents is not empty %}
            {% for event in myRegisteredEvents %}
              {% set eventDate = event.eventDate %}
              {% set eventStatus = event.status ?: 'Scheduled' %}
              <article class="my-event-card">
                <span class="my-event-date">{{ eventDate ? eventDate|date('M j, Y H:i') : 'Date TBD' }}</span>
                <h4 class="my-event-title">{{ event.charityName ?: ('Event #' ~ event.donationEventId) }}</h4>
                <p class="my-event-summary">
