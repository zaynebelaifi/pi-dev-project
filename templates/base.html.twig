  <script>
    (function () {
      const setRegistrationCount = (eventId, count) => {
        document.querySelectorAll(`[data-registration-count-for="${eventId}"]`).forEach((node) => {
          node.textContent = String(Number(count || 0));
        });
      };

      const setButtonState = (button, action) => {
        const normalized = action === 'register' ? 'register' : 'unregister';
        button.dataset.action = normalized;
        button.textContent = normalized === 'register' ? 'Register' : 'Unregister';

        if (button.classList.contains('btn-register') || button.classList.contains('btn-unregister')) {
          button.classList.toggle('btn-register', normalized === 'register');
          button.classList.toggle('btn-unregister', normalized !== 'register');
        }
      };

      const replaceEventCardRegisterState = (eventId, isRegistered, registerToken) => {
        const wrapper = document.querySelector(`.event[data-event-id="${eventId}"] [data-register-wrapper]`);
        if (!wrapper) {
          return;
        }

        if (isRegistered) {
          wrapper.dataset.registered = '1';
          wrapper.innerHTML = '<span class="event-registered-btn">Registered</span>';
          return;
        }

        wrapper.dataset.registered = '0';
        wrapper.innerHTML = `
          <form method="post" action="/client/food-donation/event/${eventId}/register" class="js-event-register-form" data-event-id="${eventId}">
            <input type="hidden" name="_token" value="${registerToken}">
            <button type="submit" class="event-register-btn-ui">Register</button>
          </form>
        `;
      };

      const postEventAction = async ({ url, token }) => {
        const formData = new FormData();
        formData.append('_token', token);

        const response = await fetch(url, {
          method: 'POST',
          body: formData,
          headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json',
          },
        });

        const payload = await response.json();
        if (!response.ok || !payload.success) {
          throw new Error(payload.message || 'Request failed.');
        }

        return payload;
      };

      document.addEventListener('submit', async (event) => {
        const form = event.target.closest('.js-event-register-form');
        if (!form) {
          return;
        }

        event.preventDefault();

        const submitButton = form.querySelector('button[type="submit"]');
        if (!submitButton) {
          return;
        }

        const eventId = Number(form.dataset.eventId || 0);
        const registerToken = String(form.querySelector('input[name="_token"]')?.value || '');
        const previousText = submitButton.textContent;

        submitButton.disabled = true;
        submitButton.textContent = 'Loading...';

        try {
          const payload = await postEventAction({
            url: form.action,
            token: registerToken,
          });

          setRegistrationCount(eventId, payload.registration_count ?? 0);
          replaceEventCardRegisterState(eventId, true, registerToken);
        } catch (error) {
          submitButton.disabled = false;
          submitButton.textContent = previousText;
          window.alert(error instanceof Error ? error.message : 'Registration failed. Please try again.');
        }
      });

      document.addEventListener('click', async (event) => {
        const toggleButton = event.target.closest('.js-event-toggle-btn');
        if (!toggleButton) {
          return;
        }

        const eventId = Number(toggleButton.dataset.eventId || 0);
        const action = String(toggleButton.dataset.action || 'unregister').toLowerCase();
        const isRegisterAction = action === 'register';
        const actionUrl = isRegisterAction ? toggleButton.dataset.registerUrl : toggleButton.dataset.unregisterUrl;
        const token = isRegisterAction ? toggleButton.dataset.registerToken : toggleButton.dataset.unregisterToken;
        const previousText = toggleButton.textContent;

        if (!actionUrl || !token) {
          return;
        }

        toggleButton.disabled = true;
        toggleButton.textContent = 'Loading...';

        try {
          const payload = await postEventAction({ url: actionUrl, token });
          const isNowRegistered = Boolean(payload.registered);

          setRegistrationCount(eventId, payload.registration_count ?? 0);
          setButtonState(toggleButton, isNowRegistered ? 'unregister' : 'register');
          replaceEventCardRegisterState(eventId, isNowRegistered, String(toggleButton.dataset.registerToken || ''));

          // If unregistered inside the My Registered Events popup, remove the card
          if (!isNowRegistered) {
            const card = toggleButton.closest('.my-event-card');
            if (card) {
              card.style.transition = 'opacity .25s, transform .25s';
              card.style.opacity = '0';
              card.style.transform = 'scale(.96)';
              setTimeout(() => {
                card.remove();
                const grid = document.querySelector('#myRegisteredEventsPopup .my-events-grid');
                if (grid && !grid.querySelector('.my-event-card')) {
                  // Show empty state
                  let msg = grid.querySelector('.js-no-events-msg');
                  if (!msg) {
                    msg = document.createElement('p');
                    msg.className = 'empty-copy js-no-events-msg';
                    grid.appendChild(msg);
                  }
                  msg.textContent = 'You have no registered events.';
                  // Update the trigger button badge if present
                  const badge = document.querySelector('.my-events-badge');
                  if (badge) badge.textContent = '0';
                }
              }, 270);
            }
          }
        } catch (error) {
          toggleButton.textContent = previousText;
          window.alert(error instanceof Error ? error.message : 'Action failed. Please try again.');
        } finally {
          toggleButton.disabled = false;
        }
      });
    })();
  </script>
  <script>
    (function () {
      const STATUS_ENDPOINT = '/api/refresh-event-statuses';
      const INTERVAL_MS = 30000;

      const prettyLabel = (apiStatus) => {
        const mapping = {
          SCHEDULED: 'Scheduled',
          IN_PROGRESS: 'In Progress',
          ONGOING: 'Ongoing',
          COMPLETED: 'Completed',
          CANCELLED: 'Cancelled',
        };

        return mapping[apiStatus] || 'Scheduled';
      };

      const refreshStatuses = async () => {
        try {
          const response = await fetch(STATUS_ENDPOINT, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
          });

          if (!response.ok) {
            throw new Error('Refresh failed');
          }

          const data = await response.json();
          if (!data || data.success !== true || !Array.isArray(data.events)) {
            return;
          }

          data.events.forEach((eventItem) => {
            const row = document.querySelector(`[data-event-id="${eventItem.id}"]`);
            if (!row) {
              return;
            }

            const apiStatus = String(eventItem.status || 'SCHEDULED').toUpperCase();
            const statusNode = row.querySelector('[data-event-status]');
            if (statusNode) {
              statusNode.textContent = prettyLabel(apiStatus);
              statusNode.className = `status status-${apiStatus.toLowerCase()}`;
            }

            const registerWrapper = row.querySelector('[data-register-wrapper]');
            if (registerWrapper) {
              registerWrapper.style.display = apiStatus === 'SCHEDULED' ? '' : 'none';
            }
          });
        } catch (error) {
          console.error('Home event refresh failed:', error);
        }
      };

      refreshStatuses();
      setInterval(refreshStatuses, INTERVAL_MS);
    })();
  </script>
