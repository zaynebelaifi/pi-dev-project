                  <span data-registration-count-for="{{ event.donationEventId }}">{{ registrationCounts[event.donationEventId]|default(0) }}</span> registered
                </p>
                <div class="event-inline-actions">
                  <a class="event-register-btn-ui" href="{{ path('app_client_food_donation_show', {'id': event.donationEventId}) }}">View Details</a>
                  <button
                    type="button"
                    class="event-register-btn-ui js-event-toggle-btn"
                    data-event-id="{{ event.donationEventId }}"
                    data-action="unregister"
                    data-register-url="{{ path('app_client_food_donation_register', {'id': event.donationEventId}) }}"
                    data-unregister-url="{{ path('app_client_food_donation_unregister', {'id': event.donationEventId}) }}"
                    data-register-token="{{ csrf_token('register-event' ~ event.donationEventId) }}"
                    data-unregister-token="{{ csrf_token('unregister-event' ~ event.donationEventId) }}"
                  >Unregister</button>
                </div>
              </article>
            {% endfor %}
          {% else %}
            <p class="empty-copy js-no-events-msg">You are not registered for any events yet.</p>
          {% endif %}
        </div>
      </div>
    </div>
  {% endif %}

