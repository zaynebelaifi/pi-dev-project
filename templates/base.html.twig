  {% block javascripts %}
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
  // ── BOOKING POPUP ──────────────────────────────────────────
  const bookingPopup = document.getElementById('bookingPopup');
  const openBookingBtn = document.getElementById('openBooking');
  const openBooking2Btn = document.getElementById('openBooking2');
  const closeBookingBtn = document.getElementById('closeBooking');

  function openBookingPopup(e) {
    e.preventDefault();
    if (!bookingPopup) return;
    bookingPopup.classList.add('active');
    document.body.style.overflow='hidden';
  }
  function closeBookingPopup() {
    if (!bookingPopup) return;
    bookingPopup.classList.remove('active');
    document.body.style.overflow='';
    document.getElementById('bookingMsg')?.remove();
  }

  if (openBookingBtn) {
    openBookingBtn.addEventListener('click', openBookingPopup);
  }
  if (openBooking2Btn) {
    openBooking2Btn.addEventListener('click', openBookingPopup);
  }
  if (closeBookingBtn) {
    closeBookingBtn.addEventListener('click', closeBookingPopup);
  }
  if (bookingPopup) {
    bookingPopup.addEventListener('click', e => { if(e.target === bookingPopup) closeBookingPopup(); });
  }

  const bookingForm = document.getElementById('bookingForm');
  const bookingTable = document.getElementById('booking_table');
  const bookingDate = document.getElementById('booking_date');
  const bookingTime = document.getElementById('booking_time');
  const bookingGuests = document.getElementById('booking_guests');
  const bookingSubmitBtn = document.getElementById('bookingSubmitBtn');
  const bookingCapacityHint = document.getElementById('bookingCapacityHint');
  const bookingTableHint = document.getElementById('bookingTableHint');
  const bookingSummaryTable = document.getElementById('bookingSummaryTable');
  const bookingSummaryDate = document.getElementById('bookingSummaryDate');
  const bookingSummaryTime = document.getElementById('bookingSummaryTime');
  const bookingSummaryGuests = document.getElementById('bookingSummaryGuests');
  const bookingSlotButtons = Array.from(document.querySelectorAll('.booking-slot-btn'));

  const bookingElementsReady = bookingForm
    && bookingTable
    && bookingDate
    && bookingTime
    && bookingGuests
    && bookingSubmitBtn
    && bookingCapacityHint
    && bookingTableHint
    && bookingSummaryTable
    && bookingSummaryDate
    && bookingSummaryTime
    && bookingSummaryGuests;

  if (bookingElementsReady) {
    function getSelectedTableCapacity() {
      return parseInt(bookingTable.selectedOptions[0]?.dataset.capacity || 0, 10);
    }

  function formatBookingDate(value) {
    if (!value) {
      return 'Choose a date';
    }

    const date = new Date(`${value}T00:00:00`);
    if (Number.isNaN(date.getTime())) {
      return value;
    }

    return date.toLocaleDateString(undefined, {
      weekday: 'short',
      month: 'short',
      day: 'numeric',
      year: 'numeric',
    });
  }

  function roundTimeToNextSlot(date) {
    const next = new Date(date.getTime());
    next.setSeconds(0, 0);

    const minutes = next.getMinutes();
    const remainder = minutes % 30;

    if (remainder !== 0) {
      next.setMinutes(minutes + (30 - remainder));
    }

    if (next < date) {
      next.setMinutes(next.getMinutes() + 30);
    }

    return `${String(next.getHours()).padStart(2, '0')}:${String(next.getMinutes()).padStart(2, '0')}`;
  }

  function syncGuestOptions() {
    const capacity = getSelectedTableCapacity();
    const currentGuests = parseInt(bookingGuests.value || '0', 10);

    Array.from(bookingGuests.options).forEach(opt => {
      if (!opt.value) {
        return;
      }

      const tooMany = capacity > 0 && parseInt(opt.value, 10) > capacity;
      opt.disabled = tooMany;
      opt.style.color = tooMany ? '#bbb' : '';
    });

    if (capacity > 0) {
      bookingCapacityHint.textContent = `This table seats up to ${capacity} guest${capacity > 1 ? 's' : ''}.`;
      if (currentGuests > capacity) {
        bookingGuests.value = '';
      }
    } else {
      bookingCapacityHint.textContent = 'Select a table to see its seating capacity.';
    }
  }

  function suggestBestFitTable() {
    const guests = parseInt(bookingGuests.value || '0', 10);
    const options = Array.from(bookingTable.options)
      .filter(opt => opt.value)
      .map(opt => ({
        value: opt.value,
        label: opt.textContent.trim(),
        capacity: parseInt(opt.dataset.capacity || '0', 10),
      }))
      .filter(opt => opt.capacity > 0)
      .sort((a, b) => a.capacity - b.capacity);

    if (!guests) {
      bookingTableHint.textContent = 'Choose guests to get a best-fit table.';
      return;
    }

    const bestFit = options.find(opt => opt.capacity >= guests);
    if (!bestFit) {
      bookingTableHint.textContent = 'No table currently fits that party size.';
      return;
    }

    const selectedCapacity = getSelectedTableCapacity();
    if (!bookingTable.value || (selectedCapacity > 0 && selectedCapacity < guests)) {
      bookingTable.value = bestFit.value;
    }

    bookingTableHint.textContent = `Best fit: ${bestFit.label}`;
  }

  function syncTimeConstraints() {
    const today = new Date();
    const selectedDate = bookingDate.value;
    const todayString = today.toISOString().split('T')[0];
    const openingTime = '08:00';
    const closingTime = '23:30';

    bookingTime.min = openingTime;
    bookingTime.max = closingTime;

    if (selectedDate === todayString) {
      const nextAvailable = roundTimeToNextSlot(today);
      bookingTime.min = nextAvailable > openingTime ? nextAvailable : openingTime;
      if (bookingTime.value && bookingTime.value < bookingTime.min) {
        bookingTime.value = bookingTime.min <= closingTime ? bookingTime.min : '';
      }
    }
  }

  function syncTimeSlotState() {
    bookingSlotButtons.forEach(button => {
      button.classList.toggle('active', button.dataset.time === bookingTime.value);
      button.disabled = Boolean(bookingTime.min && button.dataset.time < bookingTime.min);
    });
  }

  function updateBookingSummary() {
    const selectedTableText = bookingTable.selectedOptions[0]?.textContent?.trim() || 'Not selected';
    const guests = bookingGuests.value ? `${bookingGuests.value} guest${bookingGuests.value === '1' ? '' : 's'}` : 'Choose guests';

    bookingSummaryTable.textContent = selectedTableText;
    bookingSummaryDate.textContent = formatBookingDate(bookingDate.value);
    bookingSummaryTime.textContent = bookingTime.value || 'Choose a time';
    bookingSummaryGuests.textContent = guests;
  }

    bookingTable.addEventListener('change', function() {
      syncGuestOptions();
      updateBookingSummary();
    });

    bookingGuests.addEventListener('change', function() {
      suggestBestFitTable();
      syncGuestOptions();
      updateBookingSummary();
    });

    bookingDate.addEventListener('change', function() {
      syncTimeConstraints();
      syncTimeSlotState();
      updateBookingSummary();
    });

    bookingTime.addEventListener('input', function() {
      syncTimeSlotState();
      updateBookingSummary();
    });

    bookingSlotButtons.forEach(button => {
      button.addEventListener('click', function() {
        if (this.disabled) {
          return;
        }

        bookingTime.value = this.dataset.time;
        syncTimeSlotState();
        updateBookingSummary();
      });
    });

    syncTimeConstraints();
    syncGuestOptions();
    syncTimeSlotState();
    updateBookingSummary();

  function showBookingMsg(form, text, isError) {
    document.getElementById('bookingMsg')?.remove();
    const msg = document.createElement('div');
    msg.id = 'bookingMsg';
