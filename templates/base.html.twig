  function tagMatches(item, filter){
    if (filter === 'all') return true;
    if (filter === '5') return (item.rating || 0) >= 5;
    if (filter === '4') return (item.rating || 0) === 4;
    const text = `${item.summary || ''} ${item.review_text || ''}`.toLowerCase();
    if (filter === 'fast') return text.includes('fast') || text.includes('quick');
    if (filter === 'packaging') return text.includes('package') || text.includes('boxing') || text.includes('packaging');
    return true;
  }

  function renderFeedback(){
