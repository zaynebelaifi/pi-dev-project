<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% block title %}BIG 4 - Ultra Luxury Coffee Lounge{% endblock %}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=Jost:wght@300;400;500;600&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <link rel="stylesheet" href="{{ asset('styles/app.css') }}?v=3">
</head>
<body>
  <!-- NAV -->
  <nav id="nav">
    <div class="nav-inner">
      <a href="{{ path('app_home') }}" class="brand">
        <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==" alt="BIG 4 logo" style="display:none">
        <div>
          <h1>BIG 4</h1>
          <span>Coffee Lounge</span>
        </div>
      </a>

      <ul class="nav-links">
        <li><a href="#menu-section">Menu</a></li>
        <li><a href="#delivery">Delivery</a></li>
        <li><a href="#events">Events</a></li>
      </ul>

      {% set user_role = app.request.session.get('user_role') %}
      {% set user_name = app.request.session.get('user_name') %}
      {% set user_email = app.request.session.get('user_email') %}
      {% set user_phone = app.request.session.get('user_phone') %}
      {% set user_address = app.request.session.get('user_address') %}
      <div class="nav-actions">
        <button class="cart-btn" id="openCart">
          Cart <span class="cart-badge" id="cartCount">0</span>
        </button>
        <button class="profile-btn" id="openProfile">Profile</button>
        <a href="#" class="nav-btn" id="openBooking">Book Now</a>
        {% if user_role == 'ROLE_ADMIN' %}
          <a href="{{ path('app_admin_dashboard') }}" class="nav-btn">Admin</a>
          <form method="post" action="{{ path('app_logout') }}" style="display:inline-flex; margin:0;">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
            <button type="submit" class="nav-btn" style="border:none;">Logout</button>
          </form>
        {% elseif user_role == 'ROLE_DELIVERY_MAN' %}
          <a href="{{ path('app_driver_deliveries') }}" class="nav-btn">My Deliveries</a>
          <form method="post" action="{{ path('app_logout') }}" style="display:inline-flex; margin:0;">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
            <button type="submit" class="nav-btn" style="border:none;">Logout</button>
          </form>
        {% elseif user_role == 'ROLE_CLIENT' %}
          <a href="{{ path('app_profile') }}" class="nav-btn">My Profile</a>
          <a href="{{ path('app_client_orders') }}" class="nav-btn">My Orders</a>
          <form method="post" action="{{ path('app_logout') }}" style="display:inline-flex; margin:0;">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
            <button type="submit" class="nav-btn" style="border:none;">Logout</button>
          </form>
        {% else %}
          <a href="{{ path('app_login') }}" class="nav-btn">Login</a>
        {% endif %}
      </div>
    </div>
  </nav>

  <!-- FLASH MESSAGES -->
  {% for message in app.flashes('error') %}
    <div class="flash-message flash-error">
      {{ message }}
    </div>
  {% endfor %}
  {% for message in app.flashes('success') %}
    <div class="flash-message flash-success">
      {{ message }}
    </div>
  {% endfor %}

  {% block body %}
  <!-- HERO -->
  <section class="hero" id="home">
    <div class="container hero-grid">
      <div class="reveal-left show">
        <div class="eyebrow">Tunis - Elevated Dining & Coffee</div>
        <h2>Where Coffee Meets <em>Luxury</em></h2>
        <div class="hero-sub">BIG 4 Coffee Lounge</div>
        <p class="lead">A refined escape for coffee lovers, dinner guests, and late-evening conversations - designed with warmth, elegance, and unforgettable atmosphere.</p>
        <div class="hero-actions">
          <a href="#" class="btn-primary" id="openBooking2">Reserve a Table</a>
          <a href="#gallery" class="btn-secondary">Discover the Space</a>
        </div>
      </div>

      <div class="hero-card reveal-right show">
        <small>Signature Experience</small>
        <h3>Modern Lounge Dining</h3>
        <p>From handcrafted espresso to intimate dinners and curated evenings, BIG 4 blends contemporary luxury with timeless hospitality.</p>
        <div class="hero-stats">
          <div><strong>4.9</strong><span>Guest Rating</span></div>
          <div><strong>48</strong><span>Signature Items</span></div>
          <div><strong>30m</strong><span>Fast Delivery</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about">
    <div class="container about-grid">
      <div class="about-image reveal-left">
        <img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=1200&q=80" alt="Luxury restaurant interior">
      </div>
      <div class="about-panel reveal-right">
        <small class="eyebrow" style="margin-bottom:1rem">Our Story</small>
        <h3 style="font-family:'Cormorant Garamond',serif;font-size:3.2rem;font-weight:300;line-height:1.05;color:var(--espresso)">A Space Crafted for <span style="color:var(--gold);font-style:italic">Taste & Atmosphere</span></h3>
        <p>BIG 4 was imagined as more than a cafe - a destination where refined design, gourmet flavors, and ambient evenings come together. Every detail is curated to feel elegant, intimate, and memorable.</p>
        <div class="stats-grid">
          <div class="stat"><strong>2023</strong><span>Founded in Tunis</span></div>
          <div class="stat"><strong>1.2K+</strong><span>Loyal Guests</span></div>
          <div class="stat"><strong>Midnight</strong><span>Open Until</span></div>
          <div class="stat"><strong>Private</strong><span>Reservations</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="features">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <small>Signature Offerings</small>
          <h3>Curated for a <em>Premium</em> Experience</h3>
        </div>
        <p>Every service is designed to feel polished, elevated, and indulgent - whether you're dining in, reserving for a special night, or ordering from home.</p>
      </div>

      <div class="cards">
        <div class="card reveal">
          <div class="number">01</div>
          <h4>Refined Menu</h4>
          <p>Specialty coffee, elegant desserts, gourmet plates, and signature beverages created to satisfy both daytime cravings and evening indulgence.</p>
        </div>
        <div class="card reveal">
          <div class="number">02</div>
          <h4>Private Reservations</h4>
          <p>Reserve your table for intimate dinners, stylish gatherings, business meetings, or a relaxed evening in a luxurious setting.</p>
        </div>
        <div class="card reveal">
          <div class="number">03</div>
          <h4>Luxury Delivery</h4>
          <p>Enjoy the BIG 4 experience at home with carefully packaged orders, prompt delivery, and presentation that feels premium.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOD MENU -->
  <section id="menu-section">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <small>Luxury Menu</small>
          <h3>Signature <em>Flavours</em> of BIG 4</h3>
        </div>
        <p>A polished menu designed for coffee lovers, brunch guests, and elegant dining moments.</p>
      </div>

      {% if menuSections is defined and menuSections is not empty %}
        {# Count total available dishes across sections #}
        {% set totalDishes = 0 %}
        {% for section in menuSections %}
