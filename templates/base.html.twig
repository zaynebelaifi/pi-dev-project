  async function loadMenuWithoutRefresh(url, options = {}) {
    if (!menuSection) {
      window.location.href = url;
      return;
    }

    const targetUrl = new URL(url, window.location.origin).toString();
    const pushState = options.pushState !== false;

    if (menuRequestController) {
      menuRequestController.abort();
    }

    const controller = new AbortController();
    menuRequestController = controller;
    menuSection.classList.add('is-loading');

    try {
      const response = await fetch(targetUrl, {
        method: 'GET',
        headers: {
          'X-Requested-With': 'XMLHttpRequest',
        },
        signal: controller.signal,
      });

      if (!response.ok) {
        window.location.href = targetUrl;
        return;
      }

      const html = await response.text();
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, 'text/html');
      const incomingArea = doc.querySelector('#menuDynamicArea');
      const currentArea = document.querySelector('#menuDynamicArea');

      if (!incomingArea || !currentArea) {
        window.location.href = targetUrl;
        return;
      }

      currentArea.replaceWith(incomingArea);

      incomingArea.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach((element) => {
        element.classList.add('show');
      });

      if (pushState) {
        window.history.pushState({ menuDynamic: true }, '', targetUrl);
      }

      applyDishImageFallbacks(incomingArea);
      initializeMenuSwipeInteractions();
    } catch (error) {
      if (error.name !== 'AbortError') {
        window.location.href = targetUrl;
      }
    } finally {
      if (menuRequestController === controller) {
        menuRequestController = null;
        menuSection.classList.remove('is-loading');
      }
    }
  }

  function initializeMenuSwipeInteractions() {
    const menuSwipeGrid = document.querySelector('[data-menu-swipe-grid]');
    const menuPagination = document.querySelector('[data-menu-pagination]');

    if (!menuSwipeGrid || !menuPagination || menuSwipeGrid.dataset.swipeBound === '1') {
      return;
    }

    menuSwipeGrid.dataset.swipeBound = '1';

    const pageCount = Math.max(1, parseInt(menuPagination.dataset.pageCount || '1', 10) || 1);
    if (pageCount <= 1) {
      return;
    }

    const swipeThreshold = 56;
    const verticalTolerance = 90;
    let startX = 0;
    let startY = 0;
    let isTrackingSwipe = false;
    let activePointerId = null;
    let touchStartX = 0;
    let touchStartY = 0;
    let touchTracking = false;
    let lastWheelNavigationAt = 0;

    const isInteractiveTarget = (target) => (
      target instanceof Element
      && Boolean(target.closest('a,button,select,input,textarea,label'))
    );

    const getCurrentPage = () => {
      const pageFromData = parseInt(menuPagination.dataset.currentPage || '1', 10);
      if (Number.isInteger(pageFromData) && pageFromData > 0) {
        return Math.min(pageCount, pageFromData);
      }

      const pageFromUrl = parseInt(new URL(window.location.href).searchParams.get('page') || '', 10);
      if (Number.isInteger(pageFromUrl) && pageFromUrl > 0) {
        return Math.min(pageCount, pageFromUrl);
      }

      return 1;
    };

    const goToPage = (page) => {
      if (!Number.isInteger(page) || page < 1 || page > pageCount) {
        return;
      }

      const currentPage = getCurrentPage();
      if (page === currentPage) {
        return;
      }

      const url = new URL(window.location.href);
      const picker = document.getElementById('menuPicker');
      url.searchParams.set('page', String(page));

      if (picker && picker.value) {
        url.searchParams.set('menu', picker.value);
      }

      loadMenuWithoutRefresh(url.toString());
    };

    const navigateByDirection = (direction) => {
      const currentPage = getCurrentPage();
      const targetPage = direction > 0 ? currentPage + 1 : currentPage - 1;
      goToPage(Math.max(1, Math.min(pageCount, targetPage)));
    };

    const processSwipe = (endX, endY, swipeStartX, swipeStartY) => {
      const deltaX = endX - swipeStartX;
      const deltaY = endY - swipeStartY;

      if (
        Math.abs(deltaX) < swipeThreshold
        || Math.abs(deltaY) > verticalTolerance
        || Math.abs(deltaX) <= Math.abs(deltaY)
      ) {
        return;
      }

      navigateByDirection(deltaX < 0 ? 1 : -1);
    };

    const endPointerSwipe = (event) => {
      if (!isTrackingSwipe || event.pointerId !== activePointerId) {
        return;
      }

      isTrackingSwipe = false;
      activePointerId = null;
      menuSwipeGrid.classList.remove('is-page-swiping');
      processSwipe(event.clientX, event.clientY, startX, startY);
    };

    menuSwipeGrid.addEventListener('pointerdown', (event) => {
      if ((event.pointerType === 'mouse' && event.button !== 0) || isInteractiveTarget(event.target)) {
        isTrackingSwipe = false;
        return;
      }

      isTrackingSwipe = true;
      activePointerId = event.pointerId;
      startX = event.clientX;
      startY = event.clientY;
      menuSwipeGrid.classList.add('is-page-swiping');

      if (typeof menuSwipeGrid.setPointerCapture === 'function') {
        try {
          menuSwipeGrid.setPointerCapture(event.pointerId);
        } catch (error) {
          // Ignore pointer-capture failures and keep gesture handling active.
        }
      }
    });

    menuSwipeGrid.addEventListener('pointerup', endPointerSwipe);
    menuSwipeGrid.addEventListener('pointercancel', () => {
      isTrackingSwipe = false;
      activePointerId = null;
      menuSwipeGrid.classList.remove('is-page-swiping');
    });

    if (!window.PointerEvent) {
      menuSwipeGrid.addEventListener('touchstart', (event) => {
        if (isInteractiveTarget(event.target)) {
          touchTracking = false;
          return;
        }

        const touch = event.changedTouches[0];
        if (!touch) {
          touchTracking = false;
          return;
        }

        touchTracking = true;
        touchStartX = touch.clientX;
        touchStartY = touch.clientY;
        menuSwipeGrid.classList.add('is-page-swiping');
      }, { passive: true });

      menuSwipeGrid.addEventListener('touchend', (event) => {
        if (!touchTracking) {
          return;
        }

        touchTracking = false;
        menuSwipeGrid.classList.remove('is-page-swiping');

        const touch = event.changedTouches[0];
        if (!touch) {
          return;
        }

        processSwipe(touch.clientX, touch.clientY, touchStartX, touchStartY);
      }, { passive: true });

      menuSwipeGrid.addEventListener('touchcancel', () => {
        touchTracking = false;
        menuSwipeGrid.classList.remove('is-page-swiping');
      }, { passive: true });
    }

    menuSwipeGrid.addEventListener('wheel', (event) => {
      if (Math.abs(event.deltaX) <= Math.abs(event.deltaY) || Math.abs(event.deltaX) < 24) {
        return;
      }

      const now = Date.now();
      if (now - lastWheelNavigationAt < 420) {
        return;
      }

      lastWheelNavigationAt = now;
      event.preventDefault();
      navigateByDirection(event.deltaX > 0 ? 1 : -1);
    }, { passive: false });
  }

  function applyDishImageFallbacks(scope = document) {
    scope.querySelectorAll('.js-dish-image').forEach((img) => {
      if (img.dataset.fallbackBound === '1') {
        return;
      }

      img.dataset.fallbackBound = '1';

      const resolveDishImage = async () => {
        if (img.dataset.fallbackApplied === '1') {
          return;
        }

        img.dataset.fallbackApplied = '1';
        const dishName = (img.dataset.dishName || '').trim();

        try {
          const apiUrl = `${dishFallbackApiUrl}?name=${encodeURIComponent(dishName)}`;
          const response = await fetch(apiUrl, {
            headers: {
              'X-Requested-With': 'XMLHttpRequest',
            },
          });

          if (!response.ok) {
            throw new Error('Fallback API failed');
          }

          const data = await response.json();
          const imageUrl = typeof data?.imageUrl === 'string' ? data.imageUrl.trim() : '';
          img.src = imageUrl !== '' ? imageUrl : genericDishFallbackUrl;
        } catch (error) {
          img.src = genericDishFallbackUrl;
        }
      };

      img.addEventListener('error', () => {
        resolveDishImage();
      });

      if (img.dataset.hasImage !== '1') {
        resolveDishImage();
      }
    });
  }

