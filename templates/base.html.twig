        alert('Your cart is empty. Add items before selecting delivery.');
        return;
      }

      if (!pendingDeliveryOrderId) {
        const cartItemsInput = document.getElementById('redirectCartItemsInput');
        const orderTotalInput = document.getElementById('redirectCartTotalInput');
        const cartItemsValue = cartItemsInput ? cartItemsInput.value : '';
        const orderTotalValue = orderTotalInput ? orderTotalInput.value : '';
        const url = new URL('{{ path("app_order_create_from_cart") }}', window.location.origin);

        url.searchParams.append('cart_items', cartItemsValue);
        url.searchParams.append('order_total', orderTotalValue);
        url.searchParams.append('order_type', 'DELIVERY');

        try {
          const response = await fetch(url);
          const data = await response.json();

          if (!data.success) {
            alert('❌ Error: ' + (data.message || 'Failed to create delivery order')); 
            return;
          }

          pendingDeliveryOrderId = data.order_id;
          const deliveryOrderIdInput = document.getElementById('deliveryOrderId');
          const deliverySavedOrderIdInput = document.getElementById('deliverySavedOrderIdInput');
          if (deliveryOrderIdInput) {
            deliveryOrderIdInput.value = pendingDeliveryOrderId;
          }
          if (deliverySavedOrderIdInput) {
            deliverySavedOrderIdInput.value = pendingDeliveryOrderId;
          }
          alert('✅ Delivery order saved automatically. Please confirm delivery details. Order ID: #' + pendingDeliveryOrderId);
        } catch (error) {
          console.error('Error creating delivery order:', error);
          alert('❌ Error creating delivery order. Please try again.');
          return;
        }
      }

      if(orderTypeModal){
        orderTypeModal.style.display = 'none';
      }
      const deliveryFormModal = document.getElementById('deliveryFormModal');
      if(deliveryFormModal){
        deliveryFormModal.style.display = 'flex';
      }
    });
  }

  // Handle confirm delivery button
  const confirmDeliveryBtn = document.getElementById('confirmDeliveryBtn');
  if(confirmDeliveryBtn) {
    confirmDeliveryBtn.addEventListener('click', async function() {
      const deliveryOrderInput = document.getElementById('deliveryOrderId');
      const recipientNameInput = document.getElementById('recipientName');
      const recipientPhoneInput = document.getElementById('recipientPhone');
      const deliveryAddressInput = document.getElementById('deliveryAddress');
      const pickupLocationInput = document.getElementById('pickupLocation');
      const deliveryLatitudeInput = document.getElementById('deliveryLatitude');
      const deliveryLongitudeInput = document.getElementById('deliveryLongitude');
      const deliverySaveTokenInput = document.getElementById('deliverySaveToken');

      const orderId = (deliveryOrderInput ? deliveryOrderInput.value.trim() : '') || pendingDeliveryOrderId;
      const recipientName = recipientNameInput ? recipientNameInput.value.trim() : '';
      const recipientPhone = recipientPhoneInput ? recipientPhoneInput.value.trim() : '';
      const deliveryAddress = deliveryAddressInput ? deliveryAddressInput.value.trim() : '';
      const pickupLocation = pickupLocationInput ? pickupLocationInput.value.trim() : '';
      const latitude = deliveryLatitudeInput ? deliveryLatitudeInput.value.trim() : '';
      const longitude = deliveryLongitudeInput ? deliveryLongitudeInput.value.trim() : '';
      const token = deliverySaveTokenInput ? deliverySaveTokenInput.value : '';

      if (!orderId) {
        alert('❌ No delivery order has been created yet. Please select Delivery again.');
        return;
      }

      if (!recipientName || !recipientPhone || !deliveryAddress || !latitude || !longitude) {
        alert('❌ Please fill in all required fields (Name, Phone, Address, Latitude, Longitude)');
        return;
      }

      const payload = new URLSearchParams();
      payload.append('order_id', orderId);
      payload.append('recipient_name', recipientName);
      payload.append('recipient_phone', recipientPhone);
      payload.append('delivery_address', deliveryAddress);
      payload.append('pickup_location', pickupLocation);
      payload.append('current_latitude', latitude);
      payload.append('current_longitude', longitude);
      const redirectCartItemsInput = document.getElementById('redirectCartItemsInput');
      if (redirectCartItemsInput) {
        payload.append('cart_items', redirectCartItemsInput.value || '[]');
      }
      const orderTotalInput = document.getElementById('redirectCartTotalInput');
      if (orderTotalInput) {
        payload.append('order_total', orderTotalInput.value || '0');
      }
      payload.append('_token', token);

      try {
        const response = await fetch('{{ path("app_delivery_save") }}', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: payload.toString(),
        });
        const data = await response.json();

        if (data.success) {
          const deliveryFormModal = document.getElementById('deliveryFormModal');
          if(deliveryFormModal){
            deliveryFormModal.style.display = 'none';
          }
          if(orderTypeModal){
            orderTypeModal.style.display = 'none';
            document.body.style.overflow = '';
          }

          cart = [];
          updateCart();

          const deliveryForm = document.getElementById('deliveryForm');
          if (deliveryForm) {
            deliveryForm.reset();
          }
          pendingDeliveryOrderId = null;
          if (deliveryOrderInput) {
            deliveryOrderInput.value = '';
          }
          const deliverySavedOrderIdInput = document.getElementById('deliverySavedOrderIdInput');
          if (deliverySavedOrderIdInput) {
            deliverySavedOrderIdInput.value = '';
          }

          alert('✅ Your delivery details have been saved successfully!\nOrder ID: #' + orderId + '\nDelivery ID: #' + data.delivery_id);
        } else {
          alert('❌ Error: ' + (data.message || 'Failed to save delivery details'));
        }
      } catch (error) {
        console.error('Error saving delivery:', error);
        alert('❌ Error saving delivery details. Please try again.');
      }
    });
  }

  // Handle get current location button
  const getCurrentLocationBtn = document.getElementById('getCurrentLocation');
  if(getCurrentLocationBtn) {
    getCurrentLocationBtn.addEventListener('click', function() {
      const latitudeInput = document.getElementById('deliveryLatitude');
      const longitudeInput = document.getElementById('deliveryLongitude');
      
      if (navigator.geolocation) {
        getCurrentLocationBtn.textContent = '📍 Getting location...';
        getCurrentLocationBtn.disabled = true;
        
        navigator.geolocation.getCurrentPosition(
          function(position) {
            const latitude = position.coords.latitude.toFixed(6);
            const longitude = position.coords.longitude.toFixed(6);
            
            if (latitudeInput) {
              latitudeInput.value = latitude;
            }
            if (longitudeInput) {
              longitudeInput.value = longitude;
            }
            
            getCurrentLocationBtn.textContent = '📍 Location updated!';
            getCurrentLocationBtn.style.background = '#28a745';
            
            setTimeout(() => {
              getCurrentLocationBtn.textContent = '📍 Get Current Location';
              getCurrentLocationBtn.style.background = '#28a745';
              getCurrentLocationBtn.disabled = false;
            }, 2000);
          },
          function(error) {
            let errorMessage = 'Unable to get your location.';
            switch(error.code) {
              case error.PERMISSION_DENIED:
                errorMessage = 'Location access denied. Please enable location services.';
                break;
              case error.POSITION_UNAVAILABLE:
                errorMessage = 'Location information is unavailable.';
                break;
              case error.TIMEOUT:
                errorMessage = 'Location request timed out.';
                break;
            }
            
            alert('❌ ' + errorMessage);
            getCurrentLocationBtn.textContent = '📍 Get Current Location';
            getCurrentLocationBtn.disabled = false;
          },
          {
            enableHighAccuracy: true,
            timeout: 10000,
            maximumAge: 300000 // 5 minutes
          }
        );
      } else {
        alert('❌ Geolocation is not supported by this browser.');
      }
    });
  }

  if(closeOrderTypeBtn) {
    closeOrderTypeBtn.addEventListener('click', function() {
      if(orderTypeModal){
        orderTypeModal.style.display = 'none';
        document.body.style.overflow = '';
      }
    });
  }

  // Handle close delivery form button
  const closeDeliveryFormBtn = document.getElementById('closeDeliveryForm');
  const deliveryFormModal = document.getElementById('deliveryFormModal');
  if(closeDeliveryFormBtn) {
    closeDeliveryFormBtn.addEventListener('click', function() {
      if(deliveryFormModal){
        deliveryFormModal.style.display = 'none';
      }
      // Show order type modal again
      if(orderTypeModal){
        orderTypeModal.style.display = 'flex';
      }
      // Reset the form
      const deliveryForm = document.getElementById('deliveryForm');
      if (deliveryForm) {
        deliveryForm.reset();
      }
    });
  }

  // Close delivery form by clicking outside
  if(deliveryFormModal) {
    deliveryFormModal.addEventListener('click', function(e) {
      if(e.target === deliveryFormModal) {
        deliveryFormModal.style.display = 'none';
        // Show order type modal again
        if(orderTypeModal){
          orderTypeModal.style.display = 'flex';
        }
        // Reset the form
        const deliveryForm = document.getElementById('deliveryForm');
        if (deliveryForm) {
          deliveryForm.reset();
        }
      }
    });
  }

  if(orderTypeModal) {
    orderTypeModal.addEventListener('click', function(e) {
      if(e.target === orderTypeModal) {
        orderTypeModal.style.display = 'none';
        document.body.style.overflow = '';
      }
    });
  }

  // ── ESC KEY ────────────────────────────────────────────────
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') { 
      closeBookingPopup(); 
      closeCart(); 
      closeProfilePopup();
      if(orderTypeModal) orderTypeModal.style.display = 'none';
    }
  });

  // ── SCROLL REVEAL ──────────────────────────────────────────
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => { if(entry.isIntersecting){ entry.target.classList.add('show'); observer.unobserve(entry.target); }});
  }, { threshold: 0.15 });
  const revealElements = document.querySelectorAll('.reveal, .reveal-left, .reveal-right');
  if (revealElements.length) {
    revealElements.forEach(el => observer.observe(el));
  }

  // ── NAV SCROLL ─────────────────────────────────────────────
  const nav = document.getElementById('nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 40);
    });
  }

  // ── MOOD CHAT ASSISTANT ────────────────────────────────────
  const moodChatToggle = document.getElementById('moodChatToggle');
  const moodChatPanel = document.getElementById('moodChatPanel');
  const moodChatForm = document.getElementById('moodChatForm');
  const moodChatInput = document.getElementById('moodChatInput');
  const moodChatMessages = document.getElementById('moodChatMessages');
  const moodQuickPicks = document.getElementById('moodQuickPicks');
  const moodBudget = document.getElementById('moodBudget');
  const moodChatSubmit = document.getElementById('moodChatSubmit');
  const aiRecoForm = document.getElementById('aiRecoForm');
  const aiRecoInput = document.getElementById('aiRecoInput');
  const aiRecoCategory = document.getElementById('aiRecoCategory');
  const aiRecoBudget = document.getElementById('aiRecoBudget');
  const aiRecoStatus = document.getElementById('aiRecoStatus');
  const aiRecoResults = document.getElementById('aiRecoResults');
  const aiRecoSubmit = document.getElementById('aiRecoSubmit');
  let moodRequestInFlight = false;
  let aiRequestInFlight = false;

  function buildMoodPayload(inputText, options = {}) {
    const source = options.source || 'chat';

    return {
      mood: inputText,
      message: inputText,
      category: aiRecoCategory?.value || 'pasta',
      budget_level: source === 'section' ? (aiRecoBudget?.value || 'medium') : (moodBudget?.value || 'medium'),
      is_vegetarian: 0,
      is_vegan: 0,
      is_gluten_free: 0,
    };
  }

  async function fetchMoodRecommendations(inputText, options = {}) {
    const response = await fetch('{{ path("app_landingpage_mood_recommendations") }}', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(buildMoodPayload(inputText, options)),
    });

    const data = await response.json();
    if (!response.ok || !data.success) {
      throw new Error(data.message || 'I could not generate suggestions right now. Please try again.');
    }

    return data;
  }

  async function fetchWeatherSuggestions() {
    const response = await fetch('{{ path("app_api_weather_order_suggestions") }}', {
      method: 'GET',
      headers: {
        'Content-Type': 'application/json',
      },
    });

    const data = await response.json();
    if (!response.ok || !data.success) {
      throw new Error(data.message || 'I could not load weather-based suggestions right now.');
    }

    return data;
  }

  function appendMoodMessage(role, text, extraClass = '') {
    if (!moodChatMessages || !text) {
      return null;
    }

    const bubble = document.createElement('div');
    bubble.className = `mood-chat-msg ${role === 'user' ? 'user' : 'assistant'}`;
    if (extraClass) {
      bubble.classList.add(extraClass);
    }
    bubble.textContent = text;
    moodChatMessages.appendChild(bubble);
    moodChatMessages.scrollTop = moodChatMessages.scrollHeight;

    return bubble;
  }

  function appendDishCard(dish) {
    if (!moodChatMessages || !dish) {
      return;
    }

    const card = document.createElement('article');
    card.className = 'mood-chat-dish-card';

    const hasIngredients = Array.isArray(dish.ingredients) && dish.ingredients.length > 0;
    const ingredientsText = hasIngredients ? dish.ingredients.join(', ') : '';
    const ingredientsMarkup = hasIngredients
      ? `<p class="dish-ingredients"><strong>Ingredients:</strong> ${ingredientsText}</p>`
      : '';

    const priceText = dish.price || 'Price on request';
    card.innerHTML = `
      <h5>${dish.name || 'Recommended dish'}</h5>
      <p class="dish-desc">${dish.description || ''}</p>
      ${ingredientsMarkup}
      <p class="dish-reason"><strong>Why this fits:</strong> ${dish.reason || 'Good mood match.'}</p>
      <span class="dish-price">${priceText}</span>
    `;

    moodChatMessages.appendChild(card);
    moodChatMessages.scrollTop = moodChatMessages.scrollHeight;
  }

  async function requestMoodRecommendations(inputText) {
    if (moodRequestInFlight) {
      return;
    }

    moodRequestInFlight = true;
    if (moodChatInput) {
      moodChatInput.disabled = true;
    }
    if (moodChatSubmit) {
      moodChatSubmit.disabled = true;
      moodChatSubmit.textContent = 'Working...';
    }
    if (moodQuickPicks) {
      moodQuickPicks.querySelectorAll('button').forEach((button) => {
        button.disabled = true;
      });
    }

    appendMoodMessage('user', inputText);
    const loadingBubble = appendMoodMessage('assistant', 'Analyzing your mood with the AI model...', 'loading');

    try {
      const data = await fetchMoodRecommendations(inputText, { source: 'chat' });
      if (loadingBubble && loadingBubble.isConnected) {
        loadingBubble.remove();
      }

      appendMoodMessage('assistant', data.assistantMessage || 'Here are dishes that match your mood.');

      const picks = (Array.isArray(data.recommendations) ? data.recommendations : []).slice(0, 4);
      if (picks.length === 0) {
        appendMoodMessage('assistant', 'I did not find strong matches, but our menu has fresh options waiting for you.');
        return;
      }

      picks.forEach((dish) => appendDishCard(dish));
    } catch (error) {
      if (loadingBubble && loadingBubble.isConnected) {
        loadingBubble.remove();
      }

      appendMoodMessage('assistant', error?.message || 'Network issue while loading recommendations. Please try once more.');
    } finally {
      moodRequestInFlight = false;
      if (moodChatInput) {
        moodChatInput.disabled = false;
      }
      if (moodChatSubmit) {
        moodChatSubmit.disabled = false;
        moodChatSubmit.textContent = 'Ask AI';
      }
      if (moodQuickPicks) {
        moodQuickPicks.querySelectorAll('button').forEach((button) => {
          button.disabled = false;
        });
      }
    }
  }

  async function requestWeatherRecommendations() {
    if (moodRequestInFlight) {
      return;
    }

    moodRequestInFlight = true;
    if (moodChatInput) {
      moodChatInput.disabled = true;
    }
    if (moodChatSubmit) {
      moodChatSubmit.disabled = true;
      moodChatSubmit.textContent = 'Working...';
    }
    if (moodQuickPicks) {
      moodQuickPicks.querySelectorAll('button').forEach((button) => {
        button.disabled = true;
      });
    }

    const loadingBubble = appendMoodMessage('assistant', 'Checking current weather and matching dishes...', 'loading');

    try {
      const data = await fetchWeatherSuggestions();
      if (loadingBubble && loadingBubble.isConnected) {
        loadingBubble.remove();
      }

      const tempLabel = data?.weather?.temperature !== null && data?.weather?.temperature !== undefined
        ? `${Number(data.weather.temperature).toFixed(1)}°C`
        : 'unavailable temperature';
      const targetMessage = data?.target?.message || 'Weather-based suggestions are ready.';

      appendMoodMessage('assistant', `Weather now: ${tempLabel}. ${targetMessage}`);

      const picks = (Array.isArray(data.suggestions) ? data.suggestions : []).slice(0, 4);
      if (picks.length === 0) {
        appendMoodMessage('assistant', 'No weather suggestions found right now, please try again in a moment.');
        return;
      }

      picks.forEach((dish) => appendDishCard(dish));
    } catch (error) {
      if (loadingBubble && loadingBubble.isConnected) {
        loadingBubble.remove();
      }

      appendMoodMessage('assistant', error?.message || 'Could not load weather suggestions right now.');
    } finally {
      moodRequestInFlight = false;
      if (moodChatInput) {
        moodChatInput.disabled = false;
      }
      if (moodChatSubmit) {
        moodChatSubmit.disabled = false;
        moodChatSubmit.textContent = 'Ask AI';
      }
      if (moodQuickPicks) {
        moodQuickPicks.querySelectorAll('button').forEach((button) => {
          button.disabled = false;
        });
      }
    }
  }

  function renderAiRecoCards(picks) {
    if (!aiRecoResults) {
      return;
    }

    aiRecoResults.innerHTML = '';

    picks.forEach((dish) => {
      const card = document.createElement('article');
      card.className = 'ai-reco-card';

      const hasIngredients = Array.isArray(dish.ingredients) && dish.ingredients.length > 0;
      const ingredientsText = hasIngredients ? dish.ingredients.join(', ') : '';
      const ingredientsMarkup = hasIngredients
        ? `<p><strong>Ingredients:</strong> ${ingredientsText}</p>`
        : '';

      card.innerHTML = `
        <h5>${dish.name || 'Recommended dish'}</h5>
        <p>${dish.description || ''}</p>
        ${ingredientsMarkup}
        <p><strong>Why this fits:</strong> ${dish.reason || 'Good mood match.'}</p>
        <span>${dish.price || 'Price on request'}</span>
      `;

      aiRecoResults.appendChild(card);
    });
  }

  if (aiRecoForm && aiRecoInput) {
    aiRecoForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (aiRequestInFlight) {
        return;
      }

      const inputText = aiRecoInput.value.trim();

      if (!inputText) {
        return;
      }

      aiRequestInFlight = true;
      aiRecoInput.disabled = true;
      if (aiRecoSubmit) {
        aiRecoSubmit.disabled = true;
        aiRecoSubmit.textContent = 'Running...';
      }

      if (aiRecoStatus) {
        aiRecoStatus.dataset.state = 'loading';
        aiRecoStatus.textContent = 'Running model prediction...';
      }

      try {
        const data = await fetchMoodRecommendations(inputText, { source: 'section' });
        const picks = (Array.isArray(data.recommendations) ? data.recommendations : []).slice(0, 4);

        if (picks.length === 0) {
          if (aiRecoStatus) {
            aiRecoStatus.dataset.state = 'error';
            aiRecoStatus.textContent = 'No strong matches found. Try another mood or preference set.';
          }
          if (aiRecoResults) {
            aiRecoResults.innerHTML = '';
          }
          return;
        }

        if (aiRecoStatus) {
          aiRecoStatus.dataset.state = 'success';
          aiRecoStatus.textContent = data.assistantMessage || 'Model recommendations ready.';
        }

        renderAiRecoCards(picks);
      } catch (error) {
        if (aiRecoStatus) {
          aiRecoStatus.dataset.state = 'error';
          aiRecoStatus.textContent = error?.message || 'Could not load AI recommendations right now.';
        }
        if (aiRecoResults) {
          aiRecoResults.innerHTML = '';
        }
      } finally {
        aiRequestInFlight = false;
        aiRecoInput.disabled = false;
        if (aiRecoSubmit) {
          aiRecoSubmit.disabled = false;
          aiRecoSubmit.textContent = 'Run AI Match';
        }
      }
    });
  }

  if (moodChatToggle && moodChatPanel) {
    moodChatToggle.addEventListener('click', () => {
      const expanded = moodChatToggle.getAttribute('aria-expanded') === 'true';
      moodChatToggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      moodChatPanel.hidden = expanded;

      if (!expanded && moodChatInput) {
        moodChatInput.focus();
      }
    });
  }

  if (moodChatForm && moodChatInput) {
    moodChatForm.addEventListener('submit', (event) => {
      event.preventDefault();
      const value = moodChatInput.value.trim();

      if (!value) {
        return;
      }

      requestMoodRecommendations(value);
      moodChatInput.value = '';
    });
  }

  if (moodQuickPicks) {
    moodQuickPicks.addEventListener('click', (event) => {
      const weatherButton = event.target.closest('button[data-weather]');
      if (weatherButton) {
        requestWeatherRecommendations();
        return;
      }

      const button = event.target.closest('button[data-mood]');
      if (!button) {
        return;
      }

      const mood = button.dataset.mood || '';
      if (mood === '') {
        return;
      }

      requestMoodRecommendations(`I feel ${mood} today`);
    });
  }
  </script>
  {% endblock %}

</body>
</html>
