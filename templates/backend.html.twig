.nav-badge.red{background:var(--red);color:white;}

/* NAV GROUP (COLLAPSIBLE) */
.nav-group{display:flex;align-items:center;gap:.7rem;padding:.6rem .75rem;border-radius:6px;text-decoration:none;color:var(--text-2);font-size:.75rem;font-weight:500;letter-spacing:.02em;transition:all .2s;cursor:pointer;border:1px solid transparent;margin-bottom:1px;position:relative;flex-wrap:wrap;}
.nav-group:hover{background:var(--gold-wash);color:var(--brown);border-color:var(--border);}
.nav-group.nav-group-expanded{color:var(--gold);border-color:rgba(184,135,42,.22);background:var(--gold-wash);}
.nav-group-arrow{margin-left:auto;font-size:.5rem;transition:transform .3s;flex-shrink:0;}
.nav-group.nav-group-expanded .nav-group-arrow{transform:rotate(0deg);}
.nav-group-items{display:none;flex-basis:100%;flex-direction:column;gap:2px;margin-top:6px;padding-top:8px;border-top:1px solid rgba(184,135,42,.08);}
.nav-group.nav-group-expanded .nav-group-items{display:flex;}
.nav-subitem{display:flex;align-items:center;gap:.6rem;padding:.55rem .65rem .55rem 1.8rem;border-radius:4px;text-decoration:none;color:var(--text-2);font-size:.7rem;font-weight:400;letter-spacing:.01em;transition:all .15s;border:1px solid transparent;margin:0;}
.nav-subitem:hover{background:var(--gold-wash);color:var(--brown);}
.nav-subitem.active{background:var(--gold-pale);color:var(--gold);font-weight:600;border-color:rgba(184,135,42,.22);}

.sidebar-footer{margin-top:auto;padding:1rem;border-top:1px solid var(--border);}
.admin-card{display:flex;align-items:center;gap:9px;padding:.7rem 1rem;background:var(--ivory-2);border-radius:8px;border:1px solid var(--border);}
.admin-av{width:32px;height:32px;border-radius:50%;background:var(--gold-pale);border:1.5px solid rgba(184,135,42,.3);display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;color:var(--gold);flex-shrink:0;}
.admin-name{font-size:.73rem;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.admin-role{font-size:.58rem;color:var(--text-3);letter-spacing:.08em;}
.admin-dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 5px var(--green);flex-shrink:0;margin-left:auto;}

/* MAIN */
.main-wrap{margin-left:var(--sidebar-w);flex:1;display:flex;flex-direction:column;min-height:100vh;}

/* TOPBAR */
.topbar{height:62px;background:var(--ivory);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 2rem;position:sticky;top:0;z-index:50;box-shadow:0 2px 12px var(--shadow);}
.topbar-title{font-family:'Cormorant Garamond',serif;font-size:1.25rem;color:var(--espresso);font-weight:600;line-height:1;}
.topbar-bc{font-size:.58rem;letter-spacing:.15em;text-transform:uppercase;color:var(--text-3);margin-top:2px;}
.topbar-right{display:flex;align-items:center;gap:.85rem;}
.t-btn{display:flex;align-items:center;gap:.35rem;padding:.42rem .95rem;border:1px solid var(--border-2);background:transparent;color:var(--text-2);font-size:.7rem;font-family:'Jost',sans-serif;font-weight:500;letter-spacing:.06em;cursor:pointer;border-radius:4px;text-decoration:none;transition:all .2s;}
.t-btn:hover{border-color:var(--gold);color:var(--gold);background:var(--gold-wash);}
.t-btn.primary{background:var(--gold);border-color:var(--gold);color:var(--ivory);font-weight:700;}
.t-btn.primary:hover{background:var(--gold-2);border-color:var(--gold-2);color:var(--ivory);}
.t-div{width:1px;height:22px;background:var(--border);}
.notif{position:relative;width:36px;height:36px;display:flex;align-items:center;justify-content:center;border:1px solid var(--border-2);border-radius:6px;background:transparent;color:var(--text-2);cursor:pointer;font-size:1rem;transition:all .2s;}
.notif:hover{border-color:var(--gold);color:var(--gold);}
.notif-dot{position:absolute;top:6px;right:6px;width:6px;height:6px;border-radius:50%;background:var(--red);border:1px solid var(--ivory);}

/* CONTENT */
.content{padding:2rem;flex:1;}
.admin-flash{margin-bottom:.8rem;padding:.75rem 1rem;border-radius:8px;border:1px solid transparent;font-size:.8rem;line-height:1.4;}
.admin-flash-error{background:var(--red-bg);color:var(--red);border-color:rgba(217,64,64,.25);}
.admin-flash-success{background:var(--green-bg);color:var(--green);border-color:rgba(46,158,106,.25);}

/* KPI */
.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:2rem;}
.kpi{background:var(--ivory);border:1px solid var(--border);border-radius:10px;padding:1.3rem 1.5rem;position:relative;overflow:hidden;transition:all .3s;cursor:default;}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--gold),var(--gold-lt));transform:scaleX(0);transform-origin:left;transition:transform .35s;}
.kpi:hover{box-shadow:0 8px 28px var(--shadow-md);border-color:var(--border-2);}
.kpi:hover::before{transform:scaleX(1);}
.kpi-lbl{font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:var(--text-3);margin-bottom:.8rem;display:flex;justify-content:space-between;align-items:center;}
.kpi-icon{font-size:.85rem;}
.kpi-val{font-family:'Cormorant Garamond',serif;font-size:2.1rem;font-weight:600;color:var(--espresso);line-height:1;margin-bottom:.35rem;}
.kpi-chg{font-size:.66rem;display:flex;align-items:center;gap:.25rem;}
.up{color:var(--green);}.down{color:var(--red);}

/* SECTION HEAD */
.sec-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.2rem;}
.sec-head h2{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:600;color:var(--espresso);display:flex;align-items:center;gap:.55rem;}
.sec-head h2::before{content:'';width:3px;height:16px;background:var(--gold);border-radius:2px;flex-shrink:0;}
.view-all{font-size:.62rem;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);text-decoration:none;display:flex;align-items:center;gap:.3rem;transition:gap .2s;}
.view-all:hover{gap:.6rem;}

/* MODULE CARDS */
.mod-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;margin-bottom:2rem;}
.mod-card{background:var(--ivory);border:1px solid var(--border);border-radius:12px;padding:1.7rem 1.6rem;cursor:pointer;position:relative;overflow:hidden;transition:all .38s cubic-bezier(.34,1.4,.64,1);}
.mod-card::after{content:'';position:absolute;inset:0;border-radius:12px;background:radial-gradient(circle at var(--mx,50%) var(--my,50%),rgba(184,135,42,.05),transparent 65%);opacity:0;transition:opacity .3s;pointer-events:none;}
.mod-card:hover{border-color:var(--border-2);transform:translateY(-5px) rotateX(1.5deg) rotateY(-1deg);box-shadow:0 18px 50px var(--shadow-md),0 0 0 1px rgba(184,135,42,.08);}
.mod-card:hover::after{opacity:1;}
.card-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.4rem;}
.c-icon{width:48px;height:48px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;}
.c-icon.gold{background:var(--gold-pale);}
.c-icon.green{background:var(--green-bg);}
.c-icon.red{background:var(--red-bg);}
.c-icon.blue{background:var(--blue-bg);}
.c-icon.amber{background:var(--amber-bg);}
.c-icon.purple{background:var(--purple-bg);}
.c-icon.rose{background:var(--rose-bg);}
.pill{font-size:.57rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;padding:3px 8px;border-radius:20px;}
.p-green{background:var(--green-bg);color:var(--green);border:1px solid rgba(46,158,106,.2);}
.p-amber{background:var(--amber-bg);color:var(--amber);border:1px solid rgba(200,125,32,.2);}
.p-blue{background:var(--blue-bg);color:var(--blue);border:1px solid rgba(58,126,201,.2);}
.p-red{background:var(--red-bg);color:var(--red);border:1px solid rgba(217,64,64,.2);}
.p-purple{background:var(--purple-bg);color:var(--purple);border:1px solid rgba(124,79,196,.2);}
.p-rose{background:var(--rose-bg);color:var(--rose);border:1px solid rgba(201,64,112,.2);}
.c-title{font-family:'Cormorant Garamond',serif;font-size:1.22rem;font-weight:600;color:var(--espresso);margin-bottom:.3rem;}
.c-desc{font-size:.73rem;line-height:1.7;color:var(--text-2);margin-bottom:1.2rem;}
.c-stats{display:flex;gap:1rem;padding-top:1rem;border-top:1px solid var(--border);}
.cs-item{flex:1;}
.cs-num{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:600;color:var(--espresso);line-height:1;}
.cs-lbl{font-size:.58rem;letter-spacing:.1em;text-transform:uppercase;color:var(--text-3);margin-top:2px;}
.c-bar{height:3px;background:var(--ivory-3);border-radius:2px;margin-top:.65rem;overflow:hidden;}
.c-bar-fill{height:100%;border-radius:2px;background:var(--gold);transition:width .8s ease;}
.c-bar-fill.green{background:var(--green);}
.c-bar-fill.blue{background:var(--blue);}
.c-bar-fill.amber{background:var(--amber);}
.c-bar-fill.purple{background:var(--purple);}
.c-bar-fill.rose{background:var(--rose);}
.c-action{display:inline-flex;align-items:center;gap:.35rem;font-size:.65rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);text-decoration:none;margin-top:1rem;transition:gap .22s;}
.mod-card:hover .c-action{gap:.65rem;}

/* TABLE */
.tbl-card{background:var(--ivory);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:2rem;box-shadow:0 2px 16px var(--shadow);}
.tbl-head{padding:1.2rem 1.5rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--ivory);}
.tbl-title{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:600;color:var(--espresso);}
.tbl-filters{display:flex;gap:.4rem;}
.f-btn{padding:.28rem .72rem;font-size:.63rem;font-family:'Jost',sans-serif;letter-spacing:.06em;border:1px solid var(--border-2);background:transparent;color:var(--text-2);border-radius:4px;cursor:pointer;transition:all .2s;}
.f-btn.active,.f-btn:hover{border-color:var(--gold);color:var(--gold);background:var(--gold-wash);}
table{width:100%;border-collapse:collapse;}
thead th{padding:.7rem 1.5rem;font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;color:var(--text-3);text-align:left;background:var(--ivory-2);font-weight:500;border-bottom:1px solid var(--border);}
tbody tr{border-bottom:1px solid rgba(184,135,42,.07);transition:background .2s;}
tbody tr:last-child{border-bottom:none;}
tbody tr:hover{background:var(--gold-wash);}
tbody td{padding:.95rem 1.5rem;font-size:.77rem;}
.ord-id{font-family:'Cormorant Garamond',serif;font-size:.95rem;font-weight:600;color:var(--gold);}
.cust-cell{display:flex;align-items:center;gap:.7rem;}
.av-sm{width:30px;height:30px;border-radius:50%;background:var(--ivory-3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:.62rem;font-weight:700;color:var(--gold);flex-shrink:0;}
.cust-name{font-weight:500;color:var(--espresso);font-size:.77rem;}
.cust-type{font-size:.58rem;color:var(--text-3);}
.sbadge{display:inline-flex;align-items:center;gap:.28rem;padding:3px 10px;border-radius:20px;font-size:.6rem;font-weight:600;letter-spacing:.06em;}
.sbadge::before{content:'';width:5px;height:5px;border-radius:50%;background:currentColor;}
.s-delivered{background:var(--green-bg);color:var(--green);}
.s-preparing{background:var(--amber-bg);color:var(--amber);}
.s-pending{background:var(--blue-bg);color:var(--blue);}
.s-cancelled{background:var(--red-bg);color:var(--red);}
.amount{font-weight:600;color:var(--espresso);}
.dots{color:var(--text-3);font-size:1rem;cursor:pointer;letter-spacing:2px;transition:color .2s;}
tbody tr:hover .dots{color:var(--gold);}

/* BOTTOM */
.bottom-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;margin-bottom:2rem;}
.panel{background:var(--ivory);border:1px solid var(--border);border-radius:12px;overflow:hidden;box-shadow:0 2px 12px var(--shadow);}
.p-head{padding:1.1rem 1.5rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.p-title{font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:600;color:var(--espresso);display:flex;align-items:center;gap:.45rem;}
.p-body{padding:1.1rem 1.5rem;}
.act-item{display:flex;align-items:flex-start;gap:.7rem;padding:.65rem 0;border-bottom:1px solid rgba(184,135,42,.06);}
.act-item:last-child{border-bottom:none;}
.act-dot{width:7px;height:7px;border-radius:50%;margin-top:5px;flex-shrink:0;}
.act-text{font-size:.73rem;color:var(--text-2);line-height:1.5;}
.act-text strong{color:var(--espresso);font-weight:600;}
.act-time{margin-left:auto;font-size:.6rem;color:var(--text-3);white-space:nowrap;padding-left:.8rem;}
.q-grid{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;}
.q-btn{display:flex;flex-direction:column;align-items:flex-start;gap:.25rem;padding:.95rem 1rem;background:var(--ivory-2);border:1px solid var(--border);border-radius:8px;cursor:pointer;transition:all .25s;text-align:left;}
.q-btn:hover{border-color:var(--border-2);background:var(--gold-wash);transform:translateY(-1px);box-shadow:0 4px 16px var(--shadow);}
.q-icon{font-size:1.1rem;}
.q-lbl{font-size:.7rem;font-weight:600;color:var(--espresso);}
.q-sub{font-size:.6rem;color:var(--text-3);}

.stock-chatbot{position:fixed;right:22px;bottom:22px;z-index:1200;font-family:'Jost',sans-serif;}
.stock-chat-launcher{width:58px;height:58px;border:none;border-radius:50%;background:linear-gradient(145deg,var(--gold),#d7a646);color:#fff;font-size:1.4rem;cursor:pointer;box-shadow:0 10px 24px rgba(92,61,30,.24);display:flex;align-items:center;justify-content:center;transition:transform .2s ease,box-shadow .2s ease;}
.stock-chat-launcher:hover{transform:translateY(-2px);box-shadow:0 14px 28px rgba(92,61,30,.3);}
.stock-chat-window{position:absolute;right:0;bottom:70px;width:340px;max-width:88vw;height:460px;background:#fff;border:1px solid var(--border-2);border-radius:14px;display:none;flex-direction:column;overflow:hidden;box-shadow:0 16px 34px rgba(92,61,30,.2);resize:both;}
.stock-chat-window.open{display:flex;}
.stock-chat-window.expanded{width:min(960px,94vw);height:min(760px,88vh);}
.stock-chat-head{padding:.68rem .82rem;background:linear-gradient(90deg,rgba(184,135,42,.22),rgba(184,135,42,.04));border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.stock-chat-title{font-family:'Cormorant Garamond',serif;font-size:1.05rem;color:var(--espresso);}
.stock-chat-head-actions{display:flex;align-items:center;gap:.25rem;}
.stock-chat-expand,.stock-chat-close{border:none;background:transparent;color:var(--text-2);font-size:1rem;cursor:pointer;padding:.1rem .25rem;border-radius:4px;}
.stock-chat-expand:hover,.stock-chat-close:hover{background:rgba(184,135,42,.12);color:var(--espresso);}
.stock-chat-messages{flex:1;padding:.75rem;overflow:auto;background:#fffdf8;display:grid;gap:.52rem;}
.stock-chat-bubble{max-width:86%;padding:.56rem .62rem;border-radius:10px;font-size:.73rem;line-height:1.46;border:1px solid transparent;}
.stock-chat-bubble.user{justify-self:end;background:#f0f9ff;border-color:#bae6fd;color:#0c4a6e;}
.stock-chat-bubble.assistant{justify-self:start;background:#fffbeb;border-color:#fde68a;color:#713f12;}
.stock-chat-bubble pre{margin:0;white-space:pre-wrap;word-break:break-word;font-family:'Jost',sans-serif;font-size:.73rem;}
.stock-chat-table-wrap{overflow:auto;margin-top:.35rem;border:1px solid rgba(113,63,18,.15);border-radius:8px;background:#fffdf8;}
.stock-chat-table{width:100%;border-collapse:collapse;font-size:.68rem;min-width:320px;}
.stock-chat-table th,.stock-chat-table td{padding:.34rem .45rem;border-bottom:1px solid rgba(113,63,18,.12);text-align:left;vertical-align:top;}
.stock-chat-table th{background:rgba(184,135,42,.12);font-weight:600;white-space:nowrap;}
.stock-chat-table td{text-wrap:balance;}
.stock-chat-table tbody tr:last-child td{border-bottom:none;}
.stock-chat-note{font-size:.62rem;color:#92400e;margin-top:.3rem;}
