(() => {
  const chatbot = document.querySelector('.stock-chatbot');
  if (!chatbot) {
    return;
  }

  const endpoint = chatbot.getAttribute('data-chat-endpoint');
  const launcher = document.getElementById('stockChatLauncher');
  const windowEl = document.getElementById('stockChatWindow');
  const closeBtn = document.getElementById('stockChatClose');
  const expandBtn = document.getElementById('stockChatExpand');
  const form = document.getElementById('stockChatForm');
  const input = document.getElementById('stockChatInput');
  const messages = document.getElementById('stockChatMessages');

  const isTableSeparator = (line) => /^\s*\|?[\s:-]+\|[\s|:-]*$/.test(line.trim());

  const parseRowCells = (line) => line
    .trim()
    .replace(/^\|/, '')
    .replace(/\|$/, '')
    .split('|')
    .map(cell => cell.trim());

  const renderMessageContent = (text, bubble) => {
    const normalized = String(text || '').replace(/\r\n/g, '\n');
    const lines = normalized.split('\n');
    let i = 0;

    while (i < lines.length) {
      const headerLine = lines[i] ?? '';
      const separatorLine = lines[i + 1] ?? '';
      const looksLikeTableHeader = headerLine.includes('|') && parseRowCells(headerLine).length >= 2;

      if (looksLikeTableHeader && isTableSeparator(separatorLine)) {
        const wrapper = document.createElement('div');
        wrapper.className = 'stock-chat-table-wrap';
        const table = document.createElement('table');
        table.className = 'stock-chat-table';
        const thead = document.createElement('thead');
        const tbody = document.createElement('tbody');

        const headers = parseRowCells(headerLine);
        const headTr = document.createElement('tr');
        headers.forEach(label => {
          const th = document.createElement('th');
          th.textContent = label;
          headTr.appendChild(th);
        });
        thead.appendChild(headTr);

        i += 2;
        while (i < lines.length && (lines[i] || '').includes('|')) {
          const rowCells = parseRowCells(lines[i]);
          if (rowCells.length > 0) {
            const tr = document.createElement('tr');
            headers.forEach((_, idx) => {
              const td = document.createElement('td');
              td.textContent = rowCells[idx] ?? '';
              tr.appendChild(td);
            });
            tbody.appendChild(tr);
          }
          i += 1;
        }

        table.appendChild(thead);
        table.appendChild(tbody);
        wrapper.appendChild(table);
        bubble.appendChild(wrapper);
        continue;
      }

      const textBlock = [];
      while (i < lines.length) {
        const current = lines[i] ?? '';
        const next = lines[i + 1] ?? '';
        const nextIsTable = current.includes('|') && parseRowCells(current).length >= 2 && isTableSeparator(next);
        if (nextIsTable) {
          break;
        }
        textBlock.push(current);
        i += 1;
      }

      if (textBlock.length > 0) {
        const pre = document.createElement('pre');
        pre.textContent = textBlock.join('\n').trimEnd();
        bubble.appendChild(pre);
      }
    }
  };

  const appendMessage = (text, role, fallbackUsed = false, fallbackReason = '') => {
    const bubble = document.createElement('div');
    bubble.className = 'stock-chat-bubble ' + role;
    renderMessageContent(text, bubble);

    if (fallbackUsed) {
      const note = document.createElement('div');
      note.className = 'stock-chat-note';
      note.textContent = fallbackReason
        ? ('Fallback mode: ' + fallbackReason)
        : 'Fallback mode: local recommendation generated.';
      bubble.appendChild(note);
    }

    messages.appendChild(bubble);
    messages.scrollTop = messages.scrollHeight;
  };

  launcher.addEventListener('click', () => {
    windowEl.classList.toggle('open');
    if (windowEl.classList.contains('open')) {
      input.focus();
    }
  });

  closeBtn.addEventListener('click', () => {
    windowEl.classList.remove('open');
  });

  expandBtn.addEventListener('click', () => {
    windowEl.classList.toggle('expanded');
    expandBtn.textContent = windowEl.classList.contains('expanded') ? '🗗' : '⛶';
    expandBtn.title = windowEl.classList.contains('expanded') ? 'Restore chat size' : 'Expand chat';
  });

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    const question = input.value.trim();
    if (!question) {
      return;
    }

    appendMessage(question, 'user');
    input.value = '';

    try {
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Requested-With': 'XMLHttpRequest',
        },
        body: JSON.stringify({ question }),
      });

      const payload = await response.json();
      if (!response.ok) {
        appendMessage(payload.message || 'Unable to answer right now. Please try again.', 'assistant', true, payload.fallbackReason || 'Request failed');
        return;
      }

      appendMessage(
        payload.answer || 'No answer available.',
        'assistant',
        Boolean(payload.usedFallback),
        payload.fallbackReason || ''
      );
    } catch (error) {
      appendMessage('Network issue while contacting the stock assistant. Please retry.', 'assistant', true);
    }
  });
})();
