    const n = parseFloat(text.replace(/[^0-9.-]+/g,''));
    return Number.isFinite(n) ? n : text.toLowerCase();
  }
  return text.toLowerCase();
}

function sortTableRows(table,key,type,direction){
  const tbody = table.tBodies[0];
  const rows = Array.from(tbody.querySelectorAll('tr')).filter(row => !row.classList.contains('no-results-row'));
  const headers = Array.from(table.querySelectorAll('thead th'));
  const index = headers.findIndex(th => th.querySelector(`[data-sort-key="${key}"]`));
  if(index < 0){return;}
  rows.sort((a,b) => {
    const aVal = getSortValue(a.children[index], type);
    const bVal = getSortValue(b.children[index], type);
    if(aVal < bVal) return direction === 'asc' ? -1 : 1;
    if(aVal > bVal) return direction === 'asc' ? 1 : -1;
    return 0;
  });
  rows.forEach(row => tbody.appendChild(row));
}

function updateSortHeaders(table, activeLink, direction){
  table.querySelectorAll('.sort-trigger').forEach(link => {
    link.classList.remove('sorted-asc','sorted-desc');
    link.dataset.sortDirection = 'asc';
  });
  activeLink.classList.add(direction === 'asc' ? 'sorted-asc' : 'sorted-desc');
  activeLink.dataset.sortDirection = direction;
}

function setupLiveTables(root=document){
  document.querySelectorAll('[data-live-table]').forEach(table => {
    const root = table.closest('.content') || table.closest('.tbl-card')?.parentElement || document;
    const searchInput = root.querySelector('[data-live-search-input]');
    const statusFilter = root.querySelector('[data-live-status-filter]');
    const resetBtn = root.querySelector('[data-live-reset]');
    const filterForm = root.querySelector('.live-filter-form');
    const rows = Array.from(table.querySelectorAll('tbody tr')).filter(row => !row.classList.contains('no-results-row'));
    const noResults = table.querySelector('tbody .no-results');

    const updateFilter = () => {
      const query = searchInput ? searchInput.value.trim().toLowerCase() : '';
      const status = statusFilter ? statusFilter.value : '';
      let visible = 0;
      rows.forEach(row => {
        const text = (row.dataset.search || row.textContent).toLowerCase();
        const matchesQuery = !query || text.includes(query);
        const matchesStatus = !status || row.dataset.status === status;
        const show = matchesQuery && matchesStatus;
        row.style.display = show ? '' : 'none';
        if(show) visible++;
      });
      if(noResults){
        noResults.style.display = visible ? 'none' : '';
      }
    };

    if(searchInput){ searchInput.addEventListener('input', updateFilter); }
    if(statusFilter){ statusFilter.addEventListener('change', updateFilter); }
    if(filterForm){
      filterForm.addEventListener('submit', function(e){
        e.preventDefault();
        updateFilter();
      });
    }
    if(resetBtn){
      resetBtn.addEventListener('click', function(e){
        e.preventDefault();
        if(searchInput) searchInput.value = '';
        if(statusFilter) statusFilter.value = '';
        updateFilter();
      });
    }
    table.querySelectorAll('.sort-trigger').forEach(link => {
      link.addEventListener('click', function(e){
        e.preventDefault();
        const key = this.dataset.sortKey;
        const type = this.dataset.sortType || 'text';
        const current = this.dataset.sortDirection === 'asc' ? 'desc' : 'asc';
        sortTableRows(table, key, type, current);
        updateSortHeaders(table, this, current);
      });
    });
  });
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', setupLiveTables);
} else {
  setupLiveTables();
}
