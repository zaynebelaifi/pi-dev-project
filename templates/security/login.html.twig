{% extends 'base.html.twig' %}

{% block title %}Login - BIG 4{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-card">
        <div class="auth-panel">
            <div class="auth-intro">
                <span class="auth-tag">BIG 4 Coffee Lounge</span>
                <h1>Welcome back</h1>
                <p>Sign in to manage your deliveries, track orders, and keep everything running smoothly.</p>
            </div>
            <div class="auth-side">
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success">{{ message }}</div>
                {% endfor %}

                {% if error %}
                    <div class="alert alert-error">
                        {{ error }}
                    </div>
                {% endif %}

                {{ form_start(form) }}
                    <div class="form-row">{{ form_row(form.email) }}</div>
                    <div class="form-row">{{ form_row(form.password) }}</div>
                    <p class="auth-link-row">
                        <a href="{{ path('app_forgot_password') }}">Forgot password?</a>
                    </p>
                    <button type="submit" class="btn btn-primary">Sign In</button>
                {{ form_end(form) }}

                <div class="auth-divider"><span>or</span></div>
                <button type="button" class="btn btn-faceid" id="faceid-login-btn">Sign In with Face ID</button>
                <p class="faceid-status" id="faceid-login-status" aria-live="polite"></p>

                <p class="auth-footer">
                    Don’t have an account? <a href="{{ path('app_register') }}">Sign Up</a>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
.auth-page {
    min-height: calc(100vh - 120px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background: radial-gradient(circle at top, rgba(255, 244, 214, 0.65), transparent 35%),
                linear-gradient(180deg, #f9f5ec 0%, #fffdf9 100%);
}
.auth-card {
    width: min(100%, 680px);
    background: rgba(255,255,255,0.94);
    border-radius: 32px;
    border: 1px solid rgba(209, 184, 120, 0.18);
    box-shadow: 0 40px 120px rgba(141, 109, 57, 0.12);
    overflow: hidden;
}
.auth-panel {
    display: grid;
    grid-template-columns: 1fr;
}
.auth-intro {
    padding: 2.5rem 2rem 1.75rem;
    background: linear-gradient(135deg, rgba(255, 243, 205, 0.95), rgba(255, 244, 222, 0.9));
    border-bottom: 1px solid rgba(209, 184, 120, 0.22);
}
.auth-tag {
    display: inline-block;
    margin-bottom: 1rem;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    background: rgba(214, 168, 72, 0.14);
    color: var(--brown);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
}
.auth-intro h1 {
    margin: 0;
    font-size: clamp(2rem, 3vw, 2.3rem);
    color: var(--brown);
}
.auth-intro p {
    margin: 1rem 0 0;
    color: var(--text-2);
    line-height: 1.7;
    max-width: 42rem;
}
.auth-side {
    padding: 2rem;
}
.form-row {
    margin-bottom: 1.2rem;
}
.form-row label {
    display: block;
    margin-bottom: 0.45rem;
    color: var(--brown);
    font-weight: 700;
}
.form-row input {
    width: 100%;
    min-height: 48px;
    padding: 0.95rem 1rem;
    border-radius: 16px;
    border: 1px solid rgba(184,135,42,0.22);
    background: #fff;
    color: var(--espresso);
    font-size: 1rem;
}
.form-row input:focus {
    outline: none;
    border-color: var(--gold);
    box-shadow: 0 0 0 4px rgba(255, 222, 143, 0.22);
}
.btn {
    width: 100%;
    padding: 1rem 1.15rem;
    border-radius: 18px;
    border: none;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.18s ease, background 0.18s ease;
}
.btn-primary {
    background: linear-gradient(135deg, #c7972f 0%, #b27a1d 100%);
    color: white;
    box-shadow: 0 12px 24px rgba(178, 122, 29, 0.28);
}
.btn-primary:hover {
    background: linear-gradient(135deg, #b27a1d 0%, #8a5b12 100%);
    transform: translateY(-1px);
}
.btn-faceid {
    width: 100%;
    margin-top: 0.65rem;
    background: linear-gradient(135deg, #2f5ac7 0%, #1e3f9c 100%);
    color: #fff;
    box-shadow: 0 12px 24px rgba(30, 63, 156, 0.25);
}
.btn-faceid:hover {
    background: linear-gradient(135deg, #264aad 0%, #173178 100%);
    transform: translateY(-1px);
}
.btn-faceid:disabled {
    opacity: 0.65;
    cursor: not-allowed;
    transform: none;
}
.auth-divider {
    position: relative;
    margin: 1.2rem 0 0.9rem;
    text-align: center;
}
.auth-divider::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(184, 135, 42, 0.24);
}
.auth-divider span {
    position: relative;
    z-index: 1;
    background: #fff;
    padding: 0 0.8rem;
    color: var(--text-2);
    font-size: 0.9rem;
}
.faceid-status {
    min-height: 1.2rem;
    margin: 0.7rem 0 0;
    color: var(--text-2);
    font-size: 0.9rem;
}
.alert-error {
    background: #fff1f3;
    color: #842029;
    border: 1px solid #f5c2c7;
    padding: 1rem 1.1rem;
    border-radius: 16px;
    margin-bottom: 1.25rem;
}
.alert-success {
    background: #edf8f1;
    color: #1f5e3b;
    border: 1px solid #aad7be;
    padding: 1rem 1.1rem;
    border-radius: 16px;
    margin-bottom: 1.25rem;
}
.auth-footer {
    margin-top: 1.4rem;
    text-align: center;
    color: var(--text-2);
    font-size: 0.97rem;
}
.auth-footer a {
    color: var(--gold);
    font-weight: 700;
    text-decoration: none;
}
.auth-link-row {
    margin: -0.35rem 0 1rem;
    text-align: right;
}
.auth-link-row a {
    color: var(--gold);
    font-weight: 700;
    text-decoration: none;
    font-size: 0.92rem;
}
@media (max-width: 680px) {
    .auth-card {
        border-radius: 26px;
    }
    .auth-intro {
        padding: 2rem 1.5rem 1.5rem;
    }
    .auth-side {
        padding: 1.75rem 1.5rem;
    }
}
</style>

<script src="{{ asset('js/webauthn-auth.js') }}?v=2"></script>
<script>
(() => {
    if (!window.Big4WebauthnAuth) {
        return;
    }

    window.Big4WebauthnAuth.init({
        buttonId: 'faceid-login-btn',
        statusId: 'faceid-login-status',
        emailInputId: 'login_email',
        startUrl: '{{ path('app_webauthn_auth_start') }}',
        completeUrl: '{{ path('app_webauthn_auth_complete') }}'
    });
})();
</script>
{% endblock %}
