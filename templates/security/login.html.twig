{% extends 'base.html.twig' %}

{% block title %}Login - BIG 4{% endblock %}

{% block body %}
<div class="admin-header" style="margin-top:140px; text-align:center;">
    <h1>Sign In</h1>
    <p style="color: var(--text-2);">Use your admin, delivery man, or client credentials to sign in.</p>
</div>

<div class="admin-form" style="margin:auto; max-width: 520px;">
    {% if error %}
        <div style="background: #f8d7da; color: #721c24; padding: 1rem; border-radius: 12px; margin-bottom: 1.25rem;">
            {{ error }}
        </div>
    {% endif %}

    <form method="post" action="{{ path('app_login') }}">
        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required placeholder="admin@big4.test">
        </div>

        <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required placeholder="Enter your password">
        </div>

        <button type="submit" class="form-submit">Sign In</button>
    </form>

    <p style="margin-top: 1rem; color: var(--text-3); font-size: 0.95rem;">Demo credentials:</p>
    <ul style="color: var(--text-3); font-size: 0.95rem;">
        <li>Admin: admin@big4.test / admin123</li>
        <li>Delivery Man: driver@big4.test / driver123</li>
        <li>Client: client@big4.test / client123</li>
    </ul>
</div>
{% endblock %}
