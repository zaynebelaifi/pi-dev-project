{% extends 'base.html.twig' %}

{% block title %}Forgot Password - BIG 4{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-card">
        <div class="auth-panel">
            <div class="auth-intro">
                <span class="auth-tag">BIG 4 Coffee Lounge</span>
                <h1>Forgot password?</h1>
                <p>Enter your email and we will send a secure reset link.</p>
            </div>
            <div class="auth-side">
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="alert alert-error">{{ message }}</div>
                {% endfor %}

                <form id="forgotPasswordForm" class="forgot-form">
                    <div class="form-row">
                        <label for="forgotEmail">Email</label>
                        <input type="email" id="forgotEmail" name="email" required placeholder="you@example.com">
                    </div>
                    <button type="submit" class="btn btn-primary">Send reset link</button>
                </form>

                <p id="forgotPasswordMessage" class="auth-footer" style="display:none"></p>

                <p class="auth-footer">
                    Back to <a href="{{ path('app_login') }}">Sign In</a>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
.auth-page { min-height: calc(100vh - 120px); display: flex; align-items: center; justify-content: center; padding: 2rem 1rem; background: radial-gradient(circle at top, rgba(255, 244, 214, 0.65), transparent 35%), linear-gradient(180deg, #f9f5ec 0%, #fffdf9 100%); }
.auth-card { width: min(100%, 680px); background: rgba(255,255,255,0.94); border-radius: 32px; border: 1px solid rgba(209, 184, 120, 0.18); box-shadow: 0 40px 120px rgba(141, 109, 57, 0.12); overflow: hidden; }
.auth-panel { display: grid; grid-template-columns: 1fr; }
.auth-intro { padding: 2.5rem 2rem 1.75rem; background: linear-gradient(135deg, rgba(255, 243, 205, 0.95), rgba(255, 244, 222, 0.9)); border-bottom: 1px solid rgba(209, 184, 120, 0.22); }
.auth-tag { display: inline-block; margin-bottom: 1rem; padding: 0.45rem 0.9rem; border-radius: 999px; background: rgba(214, 168, 72, 0.14); color: var(--brown); font-size: 0.8rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; }
.auth-intro h1 { margin: 0; font-size: clamp(2rem, 3vw, 2.3rem); color: var(--brown); }
.auth-intro p { margin: 1rem 0 0; color: var(--text-2); line-height: 1.7; }
.auth-side { padding: 2rem; }
.form-row { margin-bottom: 1.2rem; }
.form-row label { display: block; margin-bottom: 0.45rem; color: var(--brown); font-weight: 700; }
.form-row input { width: 100%; min-height: 48px; padding: 0.95rem 1rem; border-radius: 16px; border: 1px solid rgba(184,135,42,0.22); background: #fff; color: var(--espresso); font-size: 1rem; }
.form-row input:focus { outline: none; border-color: var(--gold); box-shadow: 0 0 0 4px rgba(255, 222, 143, 0.22); }
.btn { width: 100%; padding: 1rem 1.15rem; border-radius: 18px; border: none; font-size: 1rem; font-weight: 700; cursor: pointer; transition: transform 0.18s ease, background 0.18s ease; }
.btn-primary { background: linear-gradient(135deg, #c7972f 0%, #b27a1d 100%); color: white; box-shadow: 0 12px 24px rgba(178, 122, 29, 0.28); }
.btn-primary:hover { background: linear-gradient(135deg, #b27a1d 0%, #8a5b12 100%); transform: translateY(-1px); }
.alert { padding: 1rem 1.1rem; border-radius: 16px; margin-bottom: 1rem; }
.alert-success { background: #edf8f1; color: #1f5e3b; border: 1px solid #aad7be; }
.alert-error { background: #fff1f3; color: #842029; border: 1px solid #f5c2c7; }
.auth-footer { margin-top: 1.4rem; text-align: center; color: var(--text-2); font-size: 0.97rem; }
.auth-footer a { color: var(--gold); font-weight: 700; text-decoration: none; }
</style>

<script>
(function () {
    const form = document.getElementById('forgotPasswordForm');
    const messageNode = document.getElementById('forgotPasswordMessage');
    if (!form || !messageNode) {
        return;
    }

    form.addEventListener('submit', async function (event) {
        event.preventDefault();
        const email = document.getElementById('forgotEmail').value.trim();
        if (!email) {
            return;
        }

        try {
            const response = await fetch('{{ path('app_api_forgot_password') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ email })
            });

            const payload = await response.json();
            messageNode.style.display = 'block';
            messageNode.textContent = payload.message || 'An email has been sent with instructions to reset your password.';
            messageNode.style.color = response.ok ? '#1f5e3b' : '#842029';
        } catch (error) {
            messageNode.style.display = 'block';
            messageNode.textContent = 'Unable to send request. Please try again.';
            messageNode.style.color = '#842029';
        }
    });
})();
</script>
{% endblock %}
