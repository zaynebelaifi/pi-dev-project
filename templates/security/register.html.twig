{% extends 'base.html.twig' %}

{% block title %}Register - BIG 4{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Sign Up</h1>
            <p>Create your account and start tracking deliveries.</p>
        </div>

        {{ form_start(form) }}
            <div class="form-row">{{ form_row(form.firstName) }}</div>
            <div class="form-row">{{ form_row(form.lastName) }}</div>
            <div class="form-row">{{ form_row(form.email) }}</div>
            <div class="form-row">{{ form_row(form.phone) }}</div>
            <div class="form-row">{{ form_row(form.password.first) }}</div>
            <div class="form-row">{{ form_row(form.password.second) }}</div>
            <button type="submit" class="btn btn-primary">Sign Up</button>
        {{ form_end(form) }}

        <p class="auth-footer">
            Already have an account? <a href="{{ path('app_login') }}">Sign In</a>
        </p>
    </div>
</div>

<style>
.auth-page {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 120px);
    padding: 2rem 1rem;
    background: linear-gradient(180deg, rgba(250,249,244,1) 0%, rgba(245,239,221,1) 100%);
}
.auth-card {
    width: 100%;
    max-width: 520px;
    background: white;
    padding: 2rem;
    border-radius: 22px;
    box-shadow: 0 30px 80px rgba(72, 60, 48, 0.12);
    border: 1px solid rgba(184,135,42,0.15);
}
.auth-header h1 {
    margin: 0 0 0.5rem;
    color: var(--brown);
}
.auth-header p {
    margin: 0 1rem 1.5rem 0;
    color: var(--text-2);
}
.form-row { margin-bottom: 1rem; }
.btn { width: 100%; }
.auth-footer {
    text-align: center;
    color: var(--text-2);
    margin-top: 1rem;
}
.auth-footer a {
    color: var(--gold);
    text-decoration: none;
    font-weight: 600;
}
</style>
{% endblock %}
