{% extends 'backend.html.twig' %}

{% block title %}Edit Table - BIG 4{% endblock %}
{% block topbar_title %}Edit Table{% endblock %}

{% block body %}
<div class="sec-head">
  <div>
    <h2>Edit Table #{{ table.tableId }}</h2>
    <p class="sec-sub">Update the seating capacity and current availability for this table.</p>
  </div>
  <a href="{{ path('table_index') }}" class="t-btn">Back</a>
</div>

<div class="panel" style="max-width:540px;margin:auto;padding:2rem;border-radius:14px;box-shadow:0 4px 20px rgba(0,0,0,.06);">
  {{ form_start(form, {
      'action': path('table_edit', {id: table.tableId}),
      'method': 'POST',
      'attr': {'novalidate': 'novalidate'}
  }) }}

  <div style="display:flex;flex-direction:column;gap:1.4rem;">
    <div>
      {{ form_label(form.capacity, 'Capacity', {'label_attr': {'style': 'font-size:.75rem;font-weight:600;color:var(--text-3);margin-bottom:.35rem;display:block;'}}) }}
      {{ form_widget(form.capacity, {
        'attr': {
          'placeholder': 'e.g. 4 seats',
          'style': 'width:100%;padding:.6rem .8rem;border:1px solid var(--border-2);border-radius:8px;background:var(--ivory);font-size:.85rem;transition:.2s;'
        }
      }) }}
      <div style="color:var(--red);font-size:.7rem;margin-top:.25rem;">
        {{ form_errors(form.capacity) }}
      </div>
    </div>

    <div>
      {{ form_label(form.status, 'Status', {'label_attr': {'style': 'font-size:.75rem;font-weight:600;color:var(--text-3);margin-bottom:.35rem;display:block;'}}) }}
      {{ form_widget(form.status, {
        'attr': {
          'style': 'width:100%;padding:.6rem .8rem;border:1px solid var(--border-2);border-radius:8px;background:var(--ivory);font-size:.85rem;'
        }
      }) }}
      <div style="color:var(--red);font-size:.7rem;margin-top:.25rem;">
        {{ form_errors(form.status) }}
      </div>
    </div>

    <div style="display:flex;justify-content:space-between;align-items:center;margin-top:1.2rem;">
      <a href="{{ path('table_index') }}" style="font-size:.75rem;color:var(--text-3);text-decoration:none;">
        Cancel
      </a>
      <button class="t-btn primary" style="padding:.5rem 1.2rem;font-size:.75rem;border-radius:8px;">
        Save Changes
      </button>
    </div>
  </div>

  {{ form_end(form) }}
</div>
{% endblock %}
