{% extends 'base.html.twig' %}

{% block title %}Profile - BIG 4{% endblock %}

{% block body %}
<div class="admin-header" style="margin-top:140px; text-align:center;">
    <h1>My Profile</h1>
</div>

<div class="admin-form" style="margin:auto; max-width: 520px;">
    <div class="form-group">
        <label>First Name</label>
        <p>{{ user.firstName }}</p>
    </div>
    <div class="form-group">
        <label>Last Name</label>
        <p>{{ user.lastName }}</p>
    </div>
    <div class="form-group">
        <label>Email</label>
        <p>{{ user.email }}</p>
    </div>
    <div class="form-group">
        <label>Phone</label>
        <p>{{ user.phone }}</p>
    </div>
    <div class="form-group">
        <label>Address</label>
        <p>{{ user.address }}</p>
    </div>

    <a href="{{ path('app_profile_edit') }}" class="form-submit" style="display: inline-block; text-align: center;">Edit Profile</a>
</div>
{% endblock %}
