{% extends 'base.html.twig' %}

{% block title %}Profile - BIG 4{% endblock %}

{% block body %}
<div class="auth-page profile-page">
    <div class="auth-card profile-card">
        <div class="auth-intro">
            <span class="auth-tag">BIG 4 Coffee Lounge</span>
            <h1>Your Profile</h1>
            <p>Welcome to BIG 4 Lounge. Your profile can be used for future reservations, loyalty rewards, and personalized dining experiences.</p>
        </div>

        <div class="profile-grid">
            <div class="profile-item">
                <span>First Name</span>
                <strong>{{ user.firstName }}</strong>
            </div>
            <div class="profile-item">
                <span>Last Name</span>
                <strong>{{ user.lastName }}</strong>
            </div>
            <div class="profile-item">
                <span>Email</span>
                <strong>{{ user.email }}</strong>
            </div>
            <div class="profile-item">
                <span>Phone</span>
                <strong>{{ user.phone ?: 'Not set' }}</strong>
            </div>
            <div class="profile-item profile-fullwidth">
                <span>Address</span>
                <strong>{{ user.address ?: 'Not set' }}</strong>
            </div>
        </div>

        <div class="profile-actions">
            <a href="{{ path('app_profile_edit') }}" class="btn btn-primary">Edit Profile</a>
            <a href="{{ path('app_client_orders') }}" class="btn btn-secondary">My Orders</a>
        </div>
    </div>
</div>

<style>
.profile-page {
    min-height: calc(100vh - 120px);
    padding: 2.5rem 1rem;
    background: linear-gradient(180deg, rgba(249,245,236,0.9) 0%, rgba(255,254,250,1) 100%);
}
.profile-card {
    max-width: 820px;
    margin: 0 auto;
    border-radius: 32px;
    background: white;
    border: 1px solid rgba(209,184,120,0.18);
    box-shadow: 0 40px 120px rgba(141,109,57,0.08);
    overflow: hidden;
}
.auth-intro {
    padding: 2.5rem 2rem 1.75rem;
    background: linear-gradient(135deg, rgba(255,243,205,0.95), rgba(255,244,222,0.9));
    border-bottom: 1px solid rgba(209,184,120,0.22);
}
.auth-intro h1 {
    margin: 0;
    font-size: clamp(2rem, 3vw, 2.4rem);
    color: var(--brown);
}
.auth-intro p {
    margin: 1rem 0 0;
    color: var(--text-2);
    line-height: 1.6;
}
.profile-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    padding: 2rem;
}
.profile-item {
    padding: 1.4rem 1.5rem;
    border-radius: 22px;
    background: #fffaf4;
    border: 1px solid rgba(209,184,120,0.14);
}
.profile-item span {
    display: block;
    color: var(--text-2);
    margin-bottom: 0.65rem;
    font-size: 0.95rem;
}
.profile-item strong {
    display: block;
    color: var(--espresso);
    font-size: 1.05rem;
}
.profile-fullwidth {
    grid-column: 1 / -1;
}
.profile-actions {
    display: flex;
    gap: 1rem;
    padding: 0 2rem 2rem;
    flex-wrap: wrap;
}
.btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 180px;
    padding: 1rem 1.2rem;
    border-radius: 18px;
    border: 1px solid rgba(184,135,42,0.22);
    color: var(--brown);
    background: #fff;
    text-decoration: none;
    font-weight: 700;
}
.btn-secondary:hover {
    background: #fff7eb;
}
@media (max-width: 700px) {
    .profile-grid {
        grid-template-columns: 1fr;
    }
}
</style>
{% endblock %}
