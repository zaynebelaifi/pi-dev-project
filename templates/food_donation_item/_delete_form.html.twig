<form method="post" action="{{ path('app_food_donation_item_delete', {donation_event_id: food_donation_item.donationEventId, item_id: food_donation_item.itemId}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ food_donation_item.donationEventId ~ '_' ~ food_donation_item.itemId) }}">
    <button class="btn-action btn-danger" type="submit">Delete</button>
</form>
