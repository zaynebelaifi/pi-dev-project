{{ form_start(form, {'attr': {'class': 'donation-form'}}) }}
    <div class="donation-form-grid">
        <div class="form-group-pro">
            {{ form_label(form.donation_event_id) }}
            {{ form_widget(form.donation_event_id, {'attr': {'class': 'donation-form-control'}}) }}
            {{ form_errors(form.donation_event_id) }}
        </div>
        <div class="form-group-pro">
            {{ form_label(form.item_id) }}
            {{ form_widget(form.item_id, {'attr': {'class': 'donation-form-control'}}) }}
            {{ form_errors(form.item_id) }}
        </div>
        <div class="form-group-pro">
            {{ form_label(form.quantity) }}
            {{ form_widget(form.quantity, {'attr': {'class': 'donation-form-control', 'min': 1, 'max': 100}}) }}
            {{ form_errors(form.quantity) }}
        </div>
    </div>
    <div class="donation-item-actions">
        <button class="btn-action btn-primary" type="submit">{{ button_label|default('Save') }}</button>
    </div>
{{ form_end(form) }}
