<div class="delivery-table-card">
    <div class="table-header">
        <div>
            <div class="table-title">All Drivers</div>
            <div class="table-count">{{ delivery_men|length }} team members</div>
        </div>
    </div>
    <table class="delivery-table">
        <thead>
            <tr>
                <th>Driver</th>
                <th>Email</th>
                <th>Vehicle</th>
                <th>Status</th>
                <th>Rating</th>
                <th>Join Date</th>
                <th>Salary</th>
                <th style="text-align: center; width: 120px;">Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for delivery_man in delivery_men %}
            <tr>
                <td>
                    <div class="driver-cell">
                        <div class="driver-avatar">{{ delivery_man.name|first }}</div>
                        <div class="driver-info">
                            <div class="driver-name">{{ delivery_man.name }}</div>
                            <div class="driver-phone">{{ delivery_man.phone }}</div>
                        </div>
                    </div>
                </td>
                <td><a href="mailto:{{ delivery_man.email }}" style="color: var(--gold); text-decoration: none;">{{ delivery_man.email }}</a></td>
                <td>
                    <div style="font-weight: 600; color: var(--text);">{{ delivery_man.vehicle_type }}</div>
                    <small style="color: var(--text-3);">{{ delivery_man.vehicle_number }}</small>
                </td>
                <td>
                    <span class="status-badge status-{{ delivery_man.status|lower }}">
                        {% if delivery_man.status == 'ACTIVE' %}✅ Active{% elseif delivery_man.status == 'INACTIVE' %}❌ Inactive{% else %}🟡 {{ delivery_man.status }}{% endif %}
                    </span>
                </td>
                <td>
                    {% if delivery_man.rating %}
                        <div class="rating-badge">⭐ {{ delivery_man.rating }}/5</div>
                    {% else %}
                        <small style="color: var(--text-3);">No ratings yet</small>
                    {% endif %}
                </td>
                <td>{{ delivery_man.date_of_joining ? delivery_man.date_of_joining|date('M d, Y') : '-' }}</td>
                <td><strong class="delivery-id">${{ delivery_man.salary }}</strong></td>
                <td>
                    <div class="action-cell">
                        <a href="{{ path('app_delivery_man_show', {'id': delivery_man.delivery_man_id}) }}" class="action-link" title="View">👁️</a>
                        <a href="{{ path('app_delivery_man_edit', {'id': delivery_man.delivery_man_id}) }}" class="action-link" title="Edit">✏️</a>
                        <form method="post" action="{{ path('app_delivery_man_delete', {'id': delivery_man.delivery_man_id}) }}" style="display:inline;" onsubmit="return confirm('Remove this driver from the system?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ delivery_man.delivery_man_id) }}">
                            <button type="submit" class="action-link action-delete" title="Delete" style="cursor: pointer; border: none; padding: 0; width: 32px; height: 32px;">🗑️</button>
                        </form>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8" class="no-results">
                    <div style="font-size: 3rem; margin-bottom: 1rem;">👥</div>
                    <div style="font-size: 1.1rem; color: var(--text);">No drivers found</div>
                    <small style="color: var(--text-3);">Start by adding a new delivery driver to your team</small>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
