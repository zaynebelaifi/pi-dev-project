{% extends 'base.html.twig' %}

{% block title %}DeliveryMan{% endblock %}

{% block body %}
    <h1>DeliveryMan</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Delivery_man_id</th>
                <td>{{ delivery_man.deliveryManId }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ delivery_man.name }}</td>
            </tr>
            <tr>
                <th>Phone</th>
                <td>{{ delivery_man.phone }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ delivery_man.email }}</td>
            </tr>
            <tr>
                <th>Vehicle_type</th>
                <td>{{ delivery_man.vehicleType }}</td>
            </tr>
            <tr>
                <th>Vehicle_number</th>
                <td>{{ delivery_man.vehicleNumber }}</td>
            </tr>
            <tr>
                <th>Status</th>
                <td>{{ delivery_man.status }}</td>
            </tr>
            <tr>
                <th>Address</th>
                <td>{{ delivery_man.address }}</td>
            </tr>
            <tr>
                <th>Salary</th>
                <td>{{ delivery_man.salary }}</td>
            </tr>
            <tr>
                <th>Date_of_joining</th>
                <td>{{ delivery_man.dateOfJoining ? delivery_man.dateOfJoining|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Rating</th>
                <td>{{ delivery_man.rating }}</td>
            </tr>
            <tr>
                <th>Created_at</th>
                <td>{{ delivery_man.createdAt ? delivery_man.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Updated_at</th>
                <td>{{ delivery_man.updatedAt ? delivery_man.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_delivery_man_index') }}">back to list</a>

    <a href="{{ path('app_delivery_man_edit', {'delivery_man_id': delivery_man.delivery_man_id}) }}">edit</a>

    {{ include('delivery_man/_delete_form.html.twig') }}
{% endblock %}
