<script>
(function(){
  const containerSelector = '[data-live-ajax-container]';
  if (!document.querySelector(containerSelector)) return;
  let activeController = null;
  let requestVersion = 0;
  let lastRequestedUrl = '';

  const buildUrl = params => {
    const url = new URL(window.location.href);
    Object.entries(params).forEach(([key, value]) => {
      if (value === null || value === undefined || value === '') {
        url.searchParams.delete(key);
      } else {
        url.searchParams.set(key, value);
      }
    });
    return url.toString();
  };

  const fetchContent = async url => {
    if (url === lastRequestedUrl) {
      return;
    }
    lastRequestedUrl = url;

    if (activeController) {
      activeController.abort();
    }
    activeController = new AbortController();
    const currentVersion = ++requestVersion;

    try {
      const response = await fetch(url, {
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        signal: activeController.signal,
      });
      if (!response.ok) throw new Error('Request failed');
      const html = await response.text();
      if (currentVersion !== requestVersion) {
        return;
      }
      const doc = new DOMParser().parseFromString(html, 'text/html');
      const newContainer = doc.querySelector(containerSelector);
      const currentContainer = document.querySelector(containerSelector);
      if (newContainer && currentContainer) {
        currentContainer.replaceWith(newContainer);
        bindAjax();
      }
    } catch (error) {
      if (error && error.name === 'AbortError') {
        return;
      }
      console.error('Live event fetch failed', error);
    }
  };

  const submitLiveFilter = () => {
    const form = document.querySelector('.live-filter-form');
    if (!form) return;
    const formData = new FormData(form);
    const params = {
      q: formData.get('q')?.toString() ?? '',
      status: formData.get('status')?.toString() ?? '',
      sort: formData.get('sort')?.toString() ?? '{{ sort }}',
      direction: formData.get('direction')?.toString() ?? '{{ direction }}'
    };
    const url = buildUrl(params);
    fetchContent(url);
    history.replaceState({}, '', url);
  };

  const bindAjax = () => {
    const form = document.querySelector('.live-filter-form');
    if (!form) return;
    let timeout;
    const searchInput = form.querySelector('[name="q"]');
    const statusFilter = form.querySelector('[name="status"]');
    const sortFilter = form.querySelector('[name="sort"]');
    const directionFilter = form.querySelector('[name="direction"]');

    form.addEventListener('submit', event => {
      event.preventDefault();
      submitLiveFilter();
    });

    if (searchInput) {
      searchInput.addEventListener('input', () => {
        clearTimeout(timeout);
        timeout = setTimeout(submitLiveFilter, 180);
      });
    }

    if (statusFilter) {
      statusFilter.addEventListener('change', submitLiveFilter);
    }

    if (sortFilter) {
      sortFilter.addEventListener('change', submitLiveFilter);
    }

    if (directionFilter) {
      directionFilter.addEventListener('change', submitLiveFilter);
    }

    document.querySelectorAll('.sort-trigger').forEach(link => {
      link.addEventListener('click', event => {
        event.preventDefault();
        const url = link.href;
        const parsed = new URL(url, window.location.origin);
        const sortInput = form.querySelector('select[name="sort"]');
        const directionInput = form.querySelector('select[name="direction"]');
        if (sortInput) {
          sortInput.value = parsed.searchParams.get('sort') || sortInput.value;
        }
        if (directionInput) {
          directionInput.value = parsed.searchParams.get('direction') || directionInput.value;
        }
        fetchContent(url);
        history.replaceState({}, '', url);
      });
    });
  };

  bindAjax();
  lastRequestedUrl = window.location.href;
  window.addEventListener('popstate', () => fetchContent(window.location.href));
})();

(function(){
  const closeAllPopups = () => {
    document.querySelectorAll('[data-event-items-popup].is-open').forEach(popup => {
      popup.classList.remove('is-open');
      popup.classList.remove('align-up');
    });
    document.querySelectorAll('[data-event-items-toggle][aria-expanded="true"]').forEach(button => {
      button.setAttribute('aria-expanded', 'false');
    });
  };

  const positionPopup = popup => {
    popup.classList.remove('align-up');
    const rect = popup.getBoundingClientRect();
    if (rect.bottom > window.innerHeight - 16) {
      popup.classList.add('align-up');
    }
  };

  document.addEventListener('click', event => {
    const closeButton = event.target.closest('[data-event-items-close]');
    if (closeButton) {
      closeAllPopups();
      return;
    }

    const toggle = event.target.closest('[data-event-items-toggle]');
    if (toggle) {
      const eventId = toggle.dataset.eventId;
      const popup = eventId ? document.getElementById(`popup-${eventId}`) : null;
      const willOpen = popup && !popup.classList.contains('is-open');
      closeAllPopups();
      if (popup && willOpen) {
        popup.classList.add('is-open');
        positionPopup(popup);
        toggle.setAttribute('aria-expanded', 'true');
      }
      return;
    }

    if (!event.target.closest('[data-event-items-popup]')) {
      closeAllPopups();
    }
  });
})();

(function(){
  const modal = document.getElementById('exportPdfModal');
  if (!modal) return;

  const eventNameNode = document.getElementById('exportEventName');
  const cancelBtn = document.getElementById('exportPdfCancel');
  const confirmBtn = document.getElementById('exportPdfConfirm');

  const showExportNotice = (message) => {
    const notice = document.createElement('div');
    notice.className = 'flash-message flash-success';
    notice.textContent = message;
    document.body.prepend(notice);

    window.setTimeout(() => {
      notice.remove();
    }, 2200);
  };

  const closeModal = () => {
    modal.classList.remove('active');
    modal.setAttribute('aria-hidden', 'true');
    if (confirmBtn) {
      confirmBtn.href = '#';
    }
  };

  const openModal = (eventName, exportUrl) => {
    if (eventNameNode) {
      eventNameNode.textContent = eventName || 'Unnamed event';
    }
    if (confirmBtn) {
      confirmBtn.href = exportUrl || '#';
    }
    modal.classList.add('active');
    modal.setAttribute('aria-hidden', 'false');
  };

  if (cancelBtn) {
    cancelBtn.addEventListener('click', closeModal);
  }

  modal.addEventListener('click', event => {
    if (event.target === modal) {
      closeModal();
    }
  });

  document.addEventListener('click', event => {
    const trigger = event.target.closest('[data-export-pdf-open]');
    if (!trigger) {
      return;
    }

    const eventName = trigger.getAttribute('data-event-name') || 'Unnamed event';
    const exportUrl = trigger.getAttribute('data-export-url') || '#';
    openModal(eventName, exportUrl);
  });

  if (confirmBtn) {
    confirmBtn.addEventListener('click', event => {
      const downloadUrl = confirmBtn.getAttribute('href') || '#';
      event.preventDefault();
      closeModal();
      if (downloadUrl && downloadUrl !== '#') {
        showExportNotice('Preparing PDF export...');
        window.location.href = downloadUrl;
      }
    });
  }
})();

(function(){
  const modal = document.getElementById('assignItemsModal');
  if (!modal) return;

  const form = document.getElementById('assignItemsForm');
  const closeBtn = document.getElementById('assignItemsClose');
  const skipBtn = document.getElementById('assignItemsSkip');
  const qsEventId = Number.parseInt(new URLSearchParams(window.location.search).get('newEventId') || '0', 10);
  const modalEventId = Number.parseInt(modal.dataset.newEventId || '0', 10);
  const eventId = qsEventId > 0 ? qsEventId : modalEventId;

  const closeModal = () => {
    modal.classList.remove('active');
    modal.setAttribute('aria-hidden', 'true');
    const url = new URL(window.location.href);
    url.searchParams.delete('newEventId');
    history.replaceState({}, '', url.toString());
  };

  const syncRows = () => {
    modal.querySelectorAll('.assign-item-row').forEach((row) => {
      const check = row.querySelector('[data-assign-check]');
      const qty = row.querySelector('[data-assign-qty]');
      if (!check || !qty) return;
      qty.disabled = !check.checked;
    });
  };

  modal.addEventListener('change', (event) => {
    if (event.target && event.target.matches('[data-assign-check]')) {
      syncRows();
    }
  });

  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  if (skipBtn) skipBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', (event) => {
    if (event.target === modal) {
      closeModal();
    }
  });

  if (form) {
    form.addEventListener('submit', () => {
      form.querySelectorAll('[data-assign-qty]').forEach((qtyInput) => {
        const row = qtyInput.closest('.assign-item-row');
        const check = row ? row.querySelector('[data-assign-check]') : null;
        if (!check || !check.checked) {
          qtyInput.disabled = true;
        }
      });
    });
  }

  if (eventId > 0 && form) {
    const actionTemplate = modal.dataset.actionTemplate || '';
    if (actionTemplate.includes('__ID__')) {
      form.action = actionTemplate.replace('__ID__', String(eventId));
    }
    syncRows();
    modal.classList.add('active');
    modal.setAttribute('aria-hidden', 'false');
  }
})();

(function(){
  const modal = document.getElementById('adminCommentsModal');
  const closeBtn = document.getElementById('adminCommentsClose');
  const subtitle = document.getElementById('adminCommentsSubtitle');
  const body = document.getElementById('adminCommentsBody');
  if (!modal || !closeBtn || !subtitle || !body) return;

  const flashHolder = document.createElement('div');
  flashHolder.className = 'comments-flash-holder';
  document.body.appendChild(flashHolder);

  const showFlash = (message, type = 'success') => {
    const node = document.createElement('div');
    node.className = `comments-flash ${type}`;
    node.textContent = message;
    flashHolder.appendChild(node);
    window.setTimeout(() => node.remove(), 2400);
  };

  let activeEventId = null;
  let activeCommentsUrl = null;

  const closeModal = () => {
    modal.classList.remove('active');
    modal.setAttribute('aria-hidden', 'true');
    body.innerHTML = '<div class="comments-loading">Loading comments...</div>';
    activeEventId = null;
    activeCommentsUrl = null;
  };

  const openModal = () => {
    modal.classList.add('active');
    modal.setAttribute('aria-hidden', 'false');
  };

  const escapeHtml = (value) => {
    return String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  };

  const renderComments = (comments) => {
    if (!Array.isArray(comments) || comments.length === 0) {
      body.innerHTML = '<div class="comments-empty">No reviews found for this event.</div>';
      return;
    }

    body.innerHTML = comments.map(comment => `
      <article class="comment-card" data-admin-comment-id="${comment.id}">
        <div class="comment-card-head">
          <div>
            <div class="comment-user">${escapeHtml(comment.userName)}</div>
            <div class="comment-date">${escapeHtml(comment.date)}</div>
          </div>
          <button
            type="button"
            class="comment-delete-btn"
            data-admin-comment-delete
            data-review-id="${comment.id}"
            data-delete-token="${escapeHtml(comment.deleteToken)}"
          >
            Delete
          </button>
        </div>
        <div class="comment-meta">
          <span>Event ${comment.eventRating !== null ? escapeHtml(comment.eventRating + '/5') : 'N/A'}</span>
          <span>Food ${comment.foodRating !== null ? escapeHtml(comment.foodRating + '/5') : 'N/A'}</span>
        </div>
        <p class="comment-text">${escapeHtml(comment.comment || 'No comment provided.')}</p>
      </article>
    `).join('');
  };

  const loadComments = async () => {
    if (!activeCommentsUrl) {
      return;
    }

    body.innerHTML = '<div class="comments-loading">Loading comments...</div>';
    try {
      const response = await fetch(activeCommentsUrl, {
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
      });
      const payload = await response.json();
      if (!response.ok || !payload.success) {
        body.innerHTML = `<div class="comments-empty">${escapeHtml(payload.message || 'Unable to load comments.')}</div>`;
        showFlash(payload.message || 'Unable to load comments.', 'error');
        return;
      }

      renderComments(payload.comments || []);
    } catch (error) {
      console.error(error);
      body.innerHTML = '<div class="comments-empty">Network error while loading comments.</div>';
      showFlash('Network error while loading comments.', 'error');
    }
  };

  const deleteComment = async (reviewId, token) => {
    if (!activeEventId || !reviewId) {
      return;
    }

    const confirmed = window.confirm('Delete this review?');
    if (!confirmed) {
      return;
    }

    try {
      const deleteUrl = `/admin/event/${activeEventId}/review/${reviewId}/delete`;
      const payload = new URLSearchParams();
      payload.set('_token', token || '');

      const response = await fetch(deleteUrl, {
        method: 'POST',
        headers: {
          'X-Requested-With': 'XMLHttpRequest',
          'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
        },
        body: payload.toString(),
      });
      const result = await response.json();
      if (!response.ok || !result.success) {
        showFlash(result.message || 'Unable to delete review.', 'error');
        return;
      }

      const node = body.querySelector(`[data-admin-comment-id="${reviewId}"]`);
      if (node) {
        node.remove();
      }

      if (!body.querySelector('[data-admin-comment-id]')) {
        body.innerHTML = '<div class="comments-empty">No reviews found for this event.</div>';
      }

      showFlash(result.message || 'Review deleted successfully', 'success');
    } catch (error) {
      console.error(error);
      showFlash('Network error while deleting review.', 'error');
    }
  };

  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', event => {
    if (event.target === modal) {
      closeModal();
    }
  });

  document.addEventListener('click', event => {
    const openTrigger = event.target.closest('[data-admin-comments-open]');
    if (openTrigger) {
      activeEventId = Number.parseInt(openTrigger.getAttribute('data-event-id') || '0', 10);
      activeCommentsUrl = openTrigger.getAttribute('data-comments-url') || null;
      const eventName = openTrigger.getAttribute('data-event-name') || `Event #${activeEventId}`;
      subtitle.textContent = `Manage customer reviews for ${eventName}.`;
      openModal();
      loadComments();
      return;
    }

    const deleteTrigger = event.target.closest('[data-admin-comment-delete]');
    if (deleteTrigger) {
      const reviewId = deleteTrigger.getAttribute('data-review-id');
      const token = deleteTrigger.getAttribute('data-delete-token');
      deleteComment(reviewId, token);
    }
  });
})();

(function(){
  const STATUS_ENDPOINT = '/api/refresh-event-statuses';
  const INTERVAL_MS = 60000;

  const refreshStatuses = async () => {
    try {
      const response = await fetch(STATUS_ENDPOINT, {
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
      });

      if (!response.ok) {
        throw new Error('Refresh failed');
      }

      const data = await response.json();
      if (!data || data.success !== true || !Array.isArray(data.events)) {
        return;
      }

      data.events.forEach((eventItem) => {
        const row = document.querySelector(`[data-event-id="${eventItem.id}"]`);
        if (!row) {
          return;
        }

        const statusBadge = row.querySelector('.status');
        if (statusBadge) {
          const apiStatus = String(eventItem.status || 'SCHEDULED').toUpperCase();
          statusBadge.textContent = apiStatus;
          statusBadge.className = `event-status-badge status status-${apiStatus.toLowerCase()}`;
        }
      });
    } catch (error) {
      console.error('Refresh failed:', error);
    }
  };

  refreshStatuses();
  setInterval(refreshStatuses, INTERVAL_MS);
})();
</script>
