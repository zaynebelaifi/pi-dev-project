{% extends 'backend.html.twig' %}

{% block title %}New Menu · BIG 4 Admin{% endblock %}
{% block topbar_title %}Menu Manager{% endblock %}

{% block body %}
  <div class="sec-head">
    <div>
      <h2>Create Menu</h2>
      <p class="sec-sub">Define a menu group such as Brunch, Desserts, or Signature Cocktails.</p>
    </div>
  </div>

  <div class="menu-form-card">
    {{ form_start(form, {'attr': {'class': 'admin-form', 'novalidate': 'novalidate'}}) }}
      <div class="menu-form-grid">
        <div class="form-group">
          {{ form_label(form.title) }}
          {{ form_widget(form.title) }}
          {{ form_errors(form.title) }}
        </div>
        <div class="form-group">
          {{ form_label(form.description) }}
          {{ form_widget(form.description) }}
          {{ form_errors(form.description) }}
        </div>
        <div class="form-group toggle-group">
          {{ form_row(form.isActive) }}
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" class="t-btn primary">Create Menu</button>
      </div>
    {{ form_end(form) }}
  </div>

  <style>
    .menu-form-card {
      margin-top: 1.5rem;
      background: var(--ivory);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.75rem 2rem;
      box-shadow: 0 4px 16px var(--shadow);
      max-width: 720px;
    }
    .menu-form-grid {
      display: grid;
      grid-template-columns: 1.5fr 2fr;
      gap: 1.25rem 2rem;
      align-items: flex-start;
    }
    .menu-form-card .form-group label {
      display: block;
      font-size: .8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .12em;
      color: var(--text-3);
      margin-bottom: .4rem;
    }
    .menu-form-card .form-group textarea,
    .menu-form-card .form-group input[type="text"] {
      width: 100%;
      padding: .7rem .9rem;
      border-radius: 8px;
      border: 1px solid var(--border-2);
      background: #fff;
      font-size: .9rem;
      font-family: 'Jost', sans-serif;
    }
    .menu-form-card .form-group textarea {
      min-height: 90px;
      resize: vertical;
    }
    .menu-form-card .toggle-group {
      grid-column: 1 / -1;
      display: flex;
      align-items: center;
      gap: .6rem;
      margin-top: .5rem;
    }
    .menu-form-card .toggle-group label {
      margin: 0;
      text-transform: none;
      letter-spacing: 0;
      font-weight: 500;
      color: var(--text-2);
    }
    .menu-form-card .form-actions {
      margin-top: 1.5rem;
      display: flex;
      justify-content: flex-end;
    }
    @media (max-width: 900px) {
      .menu-form-card { padding: 1.25rem 1.3rem; }
      .menu-form-grid { grid-template-columns: 1fr; }
    }
  </style>
{% endblock %}
