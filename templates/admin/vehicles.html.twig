{% extends 'backend.html.twig' %}

{% block title %}Manage Vehicles - BIG 4 Admin{% endblock %}

{% block topbar_title %}Fleet Vehicle Management{% endblock %}

{% block body %}
<style>
    .vehicles-header { margin-bottom: 2rem; }
    .vehicles-header h2 { font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; color: var(--espresso); margin-bottom: 0.5rem; }
    .vehicles-header p { color: var(--text-2); font-size: 0.9rem; }
    
    .vehicles-actions {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }
    .btn-primary {
        padding: 0.8rem 1.5rem;
        background: var(--gold);
        color: var(--ivory);
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-block;
    }
    .btn-primary:hover {
        background: var(--gold-dark);
    }
    
    .filter-section { 
        background: var(--ivory); 
        border: 1px solid var(--border); 
        border-radius: 12px; 
        padding: 1.5rem; 
        margin-bottom: 2rem;
        box-shadow: 0 2px 8px var(--shadow);
    }
    .filter-controls { 
        display: flex; 
        gap: 1rem; 
        align-items: flex-end; 
        flex-wrap: wrap;
    }
    .filter-group { 
        display: flex; 
        flex-direction: column; 
        gap: 0.5rem;
        flex: 1;
        min-width: 200px;
    }
    .filter-label { 
        font-size: 0.7rem; 
        text-transform: uppercase; 
        letter-spacing: 0.1em; 
        color: var(--text-3); 
        font-weight: 600;
    }
    .filter-input, .filter-select { 
        padding: 0.8rem 1.2rem; 
        border: 1.5px solid var(--border-2); 
        border-radius: 8px; 
        font-family: 'Jost', sans-serif;
        font-size: 0.85rem;
        color: var(--text);
        background: var(--ivory-2);
        transition: all 0.2s;
    }
    .filter-btn {
        padding: 0.8rem 2rem;
        background: var(--gold);
        border: none;
        border-radius: 8px;
        color: var(--ivory);
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }
    .filter-btn:hover {
        background: var(--gold-dark);
    }
    
    .table-wrapper {
        overflow-x: auto;
        background: var(--ivory);
        border: 1px solid var(--border);
        border-radius: 12px;
        box-shadow: 0 2px 8px var(--shadow);
    }
    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
    }
    th {
        background: var(--espresso);
        color: var(--ivory);
        padding: 1.2rem;
        text-align: left;
        font-weight: 600;
        border-bottom: 2px solid var(--border);
    }
    td {
        padding: 1.2rem;
        border-bottom: 1px solid var(--border);
    }
    tr:hover {
        background: rgba(218, 174, 105, 0.1);
    }
    
    .action-buttons {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .btn-small {
        padding: 0.4rem 0.8rem;
        border: none;
        border-radius: 6px;
        font-size: 0.75rem;
        cursor: pointer;
        transition: all 0.2s;
    }
    .btn-assign {
        background: var(--gold);
        color: var(--ivory);
        font-weight: 600;
    }
    .btn-assign:hover {
        background: var(--gold-dark);
    }
    .btn-unassign {
        background: #dc3545;
        color: white;
    }
    .btn-unassign:hover {
        background: #c82333;
    }
    .btn-edit {
        background: #0d6efd;
        color: white;
    }
    .btn-edit:hover {
        background: #0b5ed7;
    }
    .btn-delete {
        background: #6c757d;
        color: white;
    }
    .btn-delete:hover {
        background: #5c636a;
    }
    
    .driver-badge {
        display: inline-block;
        padding: 0.4rem 0.8rem;
        border-radius: 6px;
        background: var(--gold);
        color: var(--ivory);
        font-weight: 600;
        font-size: 0.75rem;
    }
    .unassigned {
        color: var(--text-3);
        font-style: italic;
    }
    
    .flash-message {
        padding: 1rem 1.5rem;
        border-radius: 8px;
        margin-bottom: 2rem;
    }
    .flash-success {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }
    .flash-error {
        background: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }
    
    .assignment-form {
        display: inline-block;
        margin: 0;
    }
    .assignment-form select {
        padding: 0.4rem;
        font-size: 0.75rem;
        border: 1.5px solid var(--border-2);
        border-radius: 6px;
        margin-right: 0.5rem;
    }
</style>

<div class="vehicles-header">
    <h2>Fleet Vehicle Management</h2>
    <p>Manage vehicles, assign drivers, and track fleet assignments</p>
</div>

<div class="vehicles-actions">
    <a href="{{ path('app_fleet_car_new') }}" class="btn-primary">+ Add New Vehicle</a>
</div>

{% for type, messages in app.flashes() %}
    {% for message in messages %}
        <div class="flash-message flash-{{ type }}">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

<!-- Filter Section -->
<div class="filter-section">
    <form method="GET" action="{{ path('app_admin_vehicles') }}" class="filter-controls" id="vehiclesFilterForm" data-live-filters="true">
        <div class="filter-group">
            <label class="filter-label">Search Vehicles</label>
            <input type="text" name="search" class="filter-input" placeholder="Make, Model, License Plate, Type..." value="{{ search }}">
        </div>
        <div class="filter-group">
            <label class="filter-label">Sort By</label>
            <select name="sort" class="filter-select">
                <option value="car_id" {% if sort == 'car_id' %}selected{% endif %}>Created</option>
                <option value="make" {% if sort == 'make' %}selected{% endif %}>Make</option>
                <option value="model" {% if sort == 'model' %}selected{% endif %}>Model</option>
                <option value="license_plate" {% if sort == 'license_plate' %}selected{% endif %}>License Plate</option>
                <option value="vehicle_type" {% if sort == 'vehicle_type' %}selected{% endif %}>Vehicle Type</option>
            </select>
        </div>
        <div class="filter-group">
            <label class="filter-label">Direction</label>
            <select name="direction" class="filter-select">
                <option value="DESC" {% if direction == 'DESC' %}selected{% endif %}>Descending</option>
                <option value="ASC" {% if direction == 'ASC' %}selected{% endif %}>Ascending</option>
            </select>
        </div>
        <button type="submit" class="filter-btn">Apply</button>
        <button type="button" class="filter-btn" id="vehiclesResetBtn" style="background: #ffffff; color: var(--espresso); border: 1.5px solid var(--border-2);">Reset</button>
    </form>
</div>

<!-- Vehicles Table -->
<div id="vehiclesResults">
    {% include 'admin/_vehicles_results.html.twig' with {
        vehicles: vehicles,
        deliveryMen: deliveryMen,
        search: search,
        sort: sort,
        direction: direction
    } %}
</div>

<script>
(() => {
    const form = document.getElementById('vehiclesFilterForm');
    const resultsContainer = document.getElementById('vehiclesResults');
    const resetButton = document.getElementById('vehiclesResetBtn');
    if (!form || !resultsContainer) {
        return;
    }

    const searchInput = form.querySelector('input[name="search"]');
    const sortInput = form.querySelector('select[name="sort"]');
    const directionInput = form.querySelector('select[name="direction"]');
    let debounceTimer = null;

    const refreshResults = async () => {
        const params = new URLSearchParams(new FormData(form));
        const query = params.toString();

        try {
            const response = await fetch(`${form.action}?${query}`, {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json'
                }
            });

            if (!response.ok) {
                throw new Error('Failed to load vehicles.');
            }

            const payload = await response.json();
            if (!payload.success || typeof payload.resultsHtml !== 'string') {
                throw new Error('Invalid vehicles payload.');
            }

            resultsContainer.innerHTML = payload.resultsHtml;
            window.history.replaceState({}, '', `${form.action}?${query}`);
        } catch (error) {
            console.error('Vehicles live filter failed:', error);
        }
    };

    form.addEventListener('submit', (event) => {
        event.preventDefault();
        refreshResults();
    });

    if (searchInput) {
        searchInput.addEventListener('input', () => {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(refreshResults, 300);
        });
    }

    if (sortInput) {
        sortInput.addEventListener('change', refreshResults);
    }

    if (directionInput) {
        directionInput.addEventListener('change', refreshResults);
    }

    if (resetButton) {
        resetButton.addEventListener('click', () => {
            if (searchInput) searchInput.value = '';
            if (sortInput) sortInput.value = 'car_id';
            if (directionInput) directionInput.value = 'DESC';
            refreshResults();
        });
    }
})();
</script>

{% endblock %}
