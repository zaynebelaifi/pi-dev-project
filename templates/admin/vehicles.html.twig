{% extends 'backend.html.twig' %}

{% block title %}Manage Vehicles - BIG 4 Admin{% endblock %}

{% block topbar_title %}Fleet Vehicle Management{% endblock %}

{% block body %}
<style>
    .vehicles-header { margin-bottom: 2rem; }
    .vehicles-header h2 { font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; color: var(--espresso); margin-bottom: 0.5rem; }
    .vehicles-header p { color: var(--text-2); font-size: 0.9rem; }
    
    .vehicles-actions {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }
    .btn-primary {
        padding: 0.8rem 1.5rem;
        background: var(--gold);
        color: var(--ivory);
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-block;
    }
    .btn-primary:hover {
        background: var(--gold-dark);
    }
    
    .filter-section { 
        background: var(--ivory); 
        border: 1px solid var(--border); 
        border-radius: 12px; 
        padding: 1.5rem; 
        margin-bottom: 2rem;
        box-shadow: 0 2px 8px var(--shadow);
    }
    .filter-controls { 
        display: flex; 
        gap: 1rem; 
        align-items: flex-end; 
        flex-wrap: wrap;
    }
    .filter-group { 
        display: flex; 
        flex-direction: column; 
        gap: 0.5rem;
        flex: 1;
        min-width: 200px;
    }
    .filter-label { 
        font-size: 0.7rem; 
        text-transform: uppercase; 
        letter-spacing: 0.1em; 
        color: var(--text-3); 
        font-weight: 600;
    }
    .filter-input, .filter-select { 
        padding: 0.8rem 1.2rem; 
        border: 1.5px solid var(--border-2); 
        border-radius: 8px; 
        font-family: 'Jost', sans-serif;
        font-size: 0.85rem;
        color: var(--text);
        background: var(--ivory-2);
        transition: all 0.2s;
    }
    .filter-btn {
        padding: 0.8rem 2rem;
        background: var(--gold);
        border: none;
        border-radius: 8px;
        color: var(--ivory);
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }
    .filter-btn:hover {
        background: var(--gold-dark);
    }
    
    .table-wrapper {
        overflow-x: auto;
        background: var(--ivory);
        border: 1px solid var(--border);
        border-radius: 12px;
        box-shadow: 0 2px 8px var(--shadow);
    }
    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
    }
    th {
        background: var(--espresso);
        color: var(--ivory);
        padding: 1.2rem;
        text-align: left;
        font-weight: 600;
        border-bottom: 2px solid var(--border);
    }
    td {
        padding: 1.2rem;
        border-bottom: 1px solid var(--border);
    }
    tr:hover {
        background: rgba(218, 174, 105, 0.1);
    }
    
    .action-buttons {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .btn-small {
        padding: 0.4rem 0.8rem;
        border: none;
        border-radius: 6px;
        font-size: 0.75rem;
        cursor: pointer;
        transition: all 0.2s;
    }
    .btn-assign {
        background: var(--gold);
        color: var(--ivory);
        font-weight: 600;
    }
    .btn-assign:hover {
        background: var(--gold-dark);
    }
    .btn-unassign {
        background: #dc3545;
        color: white;
    }
    .btn-unassign:hover {
        background: #c82333;
    }
    .btn-edit {
        background: #0d6efd;
        color: white;
    }
    .btn-edit:hover {
        background: #0b5ed7;
    }
    .btn-delete {
        background: #6c757d;
        color: white;
    }
    .btn-delete:hover {
        background: #5c636a;
    }
    
    .driver-badge {
        display: inline-block;
        padding: 0.4rem 0.8rem;
        border-radius: 6px;
        background: var(--gold);
        color: var(--ivory);
        font-weight: 600;
        font-size: 0.75rem;
    }
    .unassigned {
        color: var(--text-3);
        font-style: italic;
    }
    
    .flash-message {
        padding: 1rem 1.5rem;
        border-radius: 8px;
        margin-bottom: 2rem;
    }
    .flash-success {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }
    .flash-error {
        background: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }
    
    .assignment-form {
        display: inline-block;
        margin: 0;
    }
    .assignment-form select {
        padding: 0.4rem;
        font-size: 0.75rem;
        border: 1.5px solid var(--border-2);
        border-radius: 6px;
        margin-right: 0.5rem;
    }
</style>

<div class="vehicles-header">
    <h2>Fleet Vehicle Management</h2>
    <p>Manage vehicles, assign drivers, and track fleet assignments</p>
</div>

<div class="vehicles-actions">
    <a href="{{ path('app_fleet_car_new') }}" class="btn-primary">+ Add New Vehicle</a>
</div>

{% for type, messages in app.flashes() %}
    {% for message in messages %}
        <div class="flash-message flash-{{ type }}">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

<!-- Filter Section -->
<div class="filter-section">
    <form method="GET" class="filter-controls">
        <div class="filter-group">
            <label class="filter-label">Search Vehicles</label>
            <input type="text" name="search" class="filter-input" placeholder="Make, Model, License Plate, Type..." value="{{ search }}">
        </div>
        <button type="submit" class="filter-btn">Search</button>
    </form>
</div>

<!-- Vehicles Table -->
{% if vehicles|length > 0 %}
<div class="table-wrapper">
    <table>
        <thead>
            <tr>
                <th>Make & Model</th>
                <th>License Plate</th>
                <th>Vehicle Type</th>
                <th>Assigned Driver</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for vehicle in vehicles %}
            <tr>
                <td><strong>{{ vehicle.make }} {{ vehicle.model }}</strong></td>
                <td><code>{{ vehicle.licensePlate }}</code></td>
                <td>{{ vehicle.vehicleType|capitalize }}</td>
                <td>
                    {% set assigned_driver = null %}
                    {% for driver in deliveryMen %}
                        {% if driver.delivery_man_id == vehicle.delivery_man_id %}
                            {% set assigned_driver = driver %}
                        {% endif %}
                    {% endfor %}
                    
                    {% if assigned_driver %}
                        <div style="display:flex;flex-direction:column;gap:0.25rem;">
                            <span class="driver-badge">{{ assigned_driver.name }}</span>
                            <small style="color: var(--text-3);">{{ assigned_driver.vehicle_type ? assigned_driver.vehicle_type|capitalize : 'No vehicle type' }} {{ assigned_driver.vehicle_number ? '• ' ~ assigned_driver.vehicle_number : '' }}</small>
                        </div>
                    {% else %}
                        <span class="unassigned">— Not assigned</span>
                    {% endif %}
                </td>
                <td>
                    <div class="action-buttons">
                        {% if vehicle.delivery_man_id %}
                        <!-- Unassign Button -->
                        <form method="POST" action="{{ path('app_admin_unassign_driver', {'id': vehicle.car_id}) }}" style="display: inline;">
                            <button type="submit" class="btn-small btn-unassign" onclick="return confirm('Unassign this vehicle?');">Unassign</button>
                        </form>
                        {% else %}
                        <!-- Assign Dropdown -->
                        <form method="POST" action="{{ path('app_admin_assign_driver', {'id': vehicle.car_id}) }}" class="assignment-form">
                            <select name="driver_id" required onchange="this.form.submit();">
                                <option value="">Assign Driver</option>
                                {% for driver in deliveryMen %}
                                    <option value="{{ driver.delivery_man_id }}">{{ driver.name }}</option>
                                {% endfor %}
                            </select>
                        </form>
                        {% endif %}
                        
                        <!-- Edit Button -->
                        <a href="{{ path('app_fleet_car_edit', {'car_id': vehicle.car_id}) }}" class="btn-small btn-edit">Edit</a>
                        
                        <!-- Delete Button -->
                        <form method="POST" action="{{ path('app_fleet_car_delete', {'car_id': vehicle.car_id}) }}" style="display: inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ vehicle.car_id) }}">
                            <button type="submit" class="btn-small btn-delete" onclick="return confirm('Delete this vehicle?');">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% else %}
<div style="text-align: center; padding: 3rem; background: var(--ivory); border-radius: 12px; color: var(--text-3);">
    <p>No vehicles found. <a href="{{ path('app_fleet_car_new') }}" style="color: var(--gold); font-weight: 600;">Add your first vehicle</a></p>
</div>
{% endif %}

{% endblock %}
