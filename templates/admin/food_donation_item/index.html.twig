{% extends 'backend.html.twig' %}

{% block title %}Donation Items · BIG 4 Admin{% endblock %}
{% block topbar_title %}Donation Items{% endblock %}
{% block topbar_breadcrumb %}Big 4 · Admin · Donations · Items{% endblock %}

{% block body %}
  {% set totalItemsQty = 0 %}
  {% for row in food_donation_items %}
    {% set totalItemsQty = totalItemsQty + (row.quantity ?? 0) %}
  {% endfor %}

  <style>
    .don-card {
      background: var(--ivory);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1rem 1.1rem;
      box-shadow: 0 6px 20px rgba(92, 61, 30, 0.08);
    }
    .don-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: .8rem;
      margin-bottom: 1rem;
    }
    .don-stat {
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: .9rem 1rem;
      background: linear-gradient(145deg, rgba(250,246,239,.95), rgba(244,237,224,.85));
    }
    .don-stat-lbl {
      font-size: .58rem;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: var(--text-3);
      margin-bottom: .35rem;
    }
    .don-stat-val {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.55rem;
      line-height: 1;
      color: var(--espresso);
    }
    .list-filters .search-input {
      box-shadow: inset 0 1px 3px rgba(92, 61, 30, .06);
      transition: border-color .2s, box-shadow .2s;
    }
    .list-filters .search-input:focus {
      border-color: var(--gold);
      box-shadow: 0 0 0 3px rgba(184, 135, 42, .12);
      outline: none;
    }
    .item-chip,
    .event-chip {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: 4px 10px;
      font-size: .63rem;
      font-weight: 700;
      letter-spacing: .08em;
      border: 1px solid transparent;
      text-transform: uppercase;
    }
    .event-chip {
      background: rgba(124, 79, 196, .12);
      border-color: rgba(124, 79, 196, .24);
      color: #6a42ad;
    }
    .item-chip {
      background: rgba(58,126,201,.12);
      border-color: rgba(58,126,201,.24);
      color: #2762a8;
    }
    .qty-chip {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.05rem;
      color: var(--espresso);
      font-weight: 700;
    }
    .table-actions {
      display: flex;
      align-items: center;
      gap: .45rem;
      flex-wrap: wrap;
    }
    .mini-action {
      text-decoration: none;
      border: 1px solid var(--border-2);
      color: var(--text-2);
      padding: .28rem .65rem;
      border-radius: 8px;
      font-size: .63rem;
      font-weight: 600;
      letter-spacing: .04em;
      background: rgba(255,255,255,.6);
      transition: all .2s;
    }
    .mini-action:hover {
      color: var(--gold);
      border-color: var(--gold);
      background: var(--gold-wash);
    }
    @media (max-width: 1100px) {
      .don-grid { grid-template-columns: 1fr; }
    }
  </style>

  <div class="sec-head">
    <div>
      <h2>Donation Items</h2>
      <p>Manage items assigned to donation events, quantities, and reference IDs.</p>
    </div>
    <a href="{{ path('app_food_donation_item_new') }}" class="t-btn primary">+ Add Item</a>
  </div>

  <div class="don-grid">
    <div class="don-stat">
      <div class="don-stat-lbl">Total Item Links</div>
      <div class="don-stat-val">{{ food_donation_items|length }}</div>
    </div>
    <div class="don-stat">
      <div class="don-stat-lbl">Total Quantity</div>
      <div class="don-stat-val">{{ totalItemsQty }}</div>
    </div>
    <div class="don-stat">
      <div class="don-stat-lbl">Current Search</div>
      <div class="don-stat-val" style="font-size:1.1rem;line-height:1.2">{{ search ? search : 'All items' }}</div>
    </div>
  </div>

  {% set hasFilters = search or sort != 'donation_event_id' or direction != 'asc' %}
  <form method="get" class="list-filters don-card" data-live-search="true" style="display:flex;flex-wrap:wrap;gap:.85rem;margin-bottom:1.3rem;align-items:center;">
    <input type="text" name="q" value="{{ search }}" placeholder="Search donation items" class="search-input" style="flex:1;min-width:240px;padding:.9rem 1rem;border:1px solid var(--border-2);border-radius:12px;background:var(--ivory);">
    <select name="sort" style="padding:.9rem 1rem;border:1px solid var(--border-2);border-radius:12px;background:var(--ivory);color:var(--text);">
      <option value="donation_event_id" {{ sort == 'donation_event_id' ? 'selected' : '' }}>Sort: Event</option>
      <option value="item_id" {{ sort == 'item_id' ? 'selected' : '' }}>Sort: Item ID</option>
      <option value="quantity" {{ sort == 'quantity' ? 'selected' : '' }}>Sort: Quantity</option>
    </select>
    <select name="direction" style="padding:.9rem 1rem;border:1px solid var(--border-2);border-radius:12px;background:var(--ivory);color:var(--text);">
      <option value="asc" {{ direction == 'asc' ? 'selected' : '' }}>Asc</option>
      <option value="desc" {{ direction == 'desc' ? 'selected' : '' }}>Desc</option>
    </select>
    {% if hasFilters %}<a href="{{ path('app_food_donation_item_index') }}" class="t-btn">Reset</a>{% endif %}
  </form>

  <div class="tbl-card">
    <div class="tbl-head">
      <div class="tbl-title">All Donation Items</div>
      <div>{{ food_donation_items|length }} items</div>
    </div>
    <table>
      <thead>
        <tr>
          <th><a href="{{ path('app_food_donation_item_index', {q: search, sort: 'donation_event_id', direction: sort == 'donation_event_id' and direction == 'asc' ? 'desc' : 'asc'}) }}" class="sort-link">Donation Event{% if sort == 'donation_event_id' %} {{ direction == 'asc' ? '▲' : '▼' }}{% endif %}</a></th>
          <th><a href="{{ path('app_food_donation_item_index', {q: search, sort: 'item_id', direction: sort == 'item_id' and direction == 'asc' ? 'desc' : 'asc'}) }}" class="sort-link">Item ID{% if sort == 'item_id' %} {{ direction == 'asc' ? '▲' : '▼' }}{% endif %}</a></th>
          <th>Item Name</th>
          <th><a href="{{ path('app_food_donation_item_index', {q: search, sort: 'quantity', direction: sort == 'quantity' and direction == 'asc' ? 'desc' : 'asc'}) }}" class="sort-link">Quantity{% if sort == 'quantity' %} {{ direction == 'asc' ? '▲' : '▼' }}{% endif %}</a></th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for item in food_donation_items %}
          <tr>
            <td><span class="event-chip">Event #{{ item.donation_event_id }}</span></td>
            <td><span class="item-chip">Item #{{ item.item_id }}</span></td>
            <td>{{ dish_names[item.item_id] ?? 'Unknown' }}</td>
            <td><span class="qty-chip">{{ item.quantity }}</span></td>
            <td class="table-actions">
              <a class="mini-action" href="{{ path('app_food_donation_item_edit', {donation_event_id: item.donation_event_id, item_id: item.item_id}) }}">Edit</a>
              <a class="mini-action" href="{{ path('app_food_donation_item_show', {donation_event_id: item.donation_event_id, item_id: item.item_id}) }}">View</a>
            </td>
          </tr>
        {% else %}
          <tr class="no-results-row">
            <td colspan="4" class="no-results">No donation items found. Add an item to link it to a donation event.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endblock %}
