{% extends 'backend.html.twig' %}

{% block title %}Add Donation Item · BIG 4 Admin{% endblock %}
{% block topbar_title %}Donation Items{% endblock %}

{% block body %}
  <div class="sec-head">
    <div>
      <h2>Add Donation Item</h2>
      <p>Assign an item to a donation event and set the quantity to donate.</p>
    </div>
  </div>

  <div class="menu-form-card">
    {{ form_start(form, {'attr': {'class': 'admin-form', 'novalidate': 'novalidate'}}) }}
      {{ form_errors(form) }}
      {% if ingredient is defined and ingredient %}
        <div class="form-note" style="margin-bottom:1rem;padding:.9rem 1rem;background:rgba(232,196,114,.12);border:1px solid rgba(184,135,42,.2);border-radius:10px;color:var(--text-2);">
          Creating a donation item for wasted ingredient: <strong>{{ ingredient.name }}</strong>. Select the matching item and event, then set quantity.
        </div>
      {% endif %}
      <div class="menu-form-grid">
        <div class="form-group">
          {{ form_label(form.donation_event_id) }}
          {{ form_widget(form.donation_event_id) }}
          {{ form_errors(form.donation_event_id) }}
        </div>
        <div class="form-group">
          {{ form_label(form.item_id) }}
          {{ form_widget(form.item_id) }}
          {{ form_errors(form.item_id) }}
        </div>
        <div class="form-group">
          {{ form_label(form.quantity) }}
          {{ form_widget(form.quantity) }}
          {{ form_errors(form.quantity) }}
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" class="t-btn primary">Create Item</button>
      </div>
    {{ form_end(form) }}
  </div>
{% endblock %}
