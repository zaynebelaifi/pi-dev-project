{% extends 'backend.html.twig' %}

{% block title %}Donation Item Details · BIG 4 Admin{% endblock %}
{% block topbar_title %}Donation Item Profile{% endblock %}
{% block topbar_breadcrumb %}BIG 4 · Admin · Donation Items · Details{% endblock %}

{% block body %}
{% set eventName = event and event.charityName ? event.charityName : 'Unknown Event' %}
{% set eventDate = event and event.eventDate ? event.eventDate|date('M j, Y') : 'N/A' %}
{% set eventTime = event and event.eventDate ? event.eventDate|date('g:i A') : 'N/A' %}
{% set eventStatus = event and event.status ? event.status : 'N/A' %}

<div class="admin-container">
    <div class="admin-header">
        <h1>{{ eventName }}</h1>
        <p>Event Assignment Overview for Event #{{ eventId }}</p>
    </div>

    <div class="delivery-details">
        <div class="detail-section">
            <h3>Event Summary</h3>
            <table class="admin-table">
                <tbody>
                    <tr>
                        <td><strong>Event Name</strong></td>
                        <td>{{ eventName }}</td>
                    </tr>
                    <tr>
                        <td><strong>Charity Name</strong></td>
                        <td><span class="status-badge status-charity">{{ eventName }}</span></td>
                    </tr>
                    <tr>
                        <td><strong>Event Date/Time</strong></td>
                        <td>{{ eventDate }} at {{ eventTime }}</td>
                    </tr>
                    <tr>
                        <td><strong>Status</strong></td>
                        <td><span class="status-badge status-type">{{ eventStatus }}</span></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="detail-section">
            <h3>Assigned Items</h3>
            <table class="admin-table assigned-items-table">
                <thead>
                    <tr>
                        <th>Item Name</th>
                        <th>Item ID</th>
                        <th>Quantity</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in assignedItems %}
                        <tr>
                            <td>{{ row.name }}</td>
                            <td>#{{ row.itemId }}</td>
                            <td><span class="status-badge status-quantity">{{ row.quantity }} units</span></td>
                            <td>
                                <a class="mini-link" href="{{ path('donation_item_edit', {id: eventId}) }}">Edit</a>
                                <form method="post" action="{{ path('donation_item_remove', {id: eventId, assignmentId: row.assignmentId}) }}" class="inline-form" onsubmit="return confirm('Remove this assigned item?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('remove_item_' ~ row.assignmentId) }}">
                                    <button type="submit" class="mini-link mini-link-danger">Remove</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="empty-row">No items assigned to this event yet.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="detail-section">
            <h3>Summary Stats</h3>
            <table class="admin-table">
                <tbody>
                    <tr>
                        <td><strong>Total items assigned</strong></td>
                        <td>{{ totalItems }}</td>
                    </tr>
                    <tr>
                        <td><strong>Total quantity</strong></td>
                        <td>{{ totalQuantity }}</td>
                    </tr>
                </tbody>
            </table>
            <div class="section-actions">
                <a href="{{ path('donation_item_edit', {id: eventId}) }}" class="btn btn-primary">Edit All</a>
            </div>
        </div>
    </div>

    <div class="admin-actions">
        <a href="{{ path('app_food_donation_event_index') }}" class="btn btn-secondary">Back to Events</a>
        <a href="{{ path('donation_item_edit', {id: eventId}) }}" class="btn btn-primary">Edit All Items</a>
        <a href="{{ path('donation_item_edit', {id: eventId}) }}" class="btn btn-primary">Add More Items</a>
    </div>
</div>

<style>
.admin-container { max-width: 980px; margin: 0 auto; padding: 1.5rem; }
.admin-header { margin-bottom: 1.8rem; }
.admin-header h1 { font-family: 'Cormorant Garamond', serif; font-size: 2.1rem; font-weight: 700; color: var(--espresso); margin: 0 0 .3rem; }
.admin-header p { font-size: .85rem; color: var(--text-3); letter-spacing: .06em; }
.delivery-details { display: grid; gap: 1.5rem; }
.detail-section { background: var(--ivory, #fdf8f0); border: 1.5px solid rgba(184,135,42,.38); border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,.06); }
.detail-section h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.15rem; font-weight: 700; color: var(--gold, #b8872a); margin: 0 0 1.1rem; padding-bottom: .65rem; border-bottom: 1px solid rgba(184,135,42,.2); }
.admin-table { width: 100%; border-collapse: collapse; }
.admin-table td, .admin-table th { padding: .75rem .5rem; font-size: .88rem; color: var(--text, #1a1a1a); border-bottom: 1px solid rgba(0,0,0,.05); text-align: left; }
.admin-table tr:last-child td { border-bottom: none; }
.admin-table td:first-child { width: 35%; color: var(--text-2, #5a5a5a); font-weight: 600; }
.status-badge { display: inline-flex; align-items: center; gap: .3rem; padding: .28rem .75rem; border-radius: 99px; font-size: .76rem; font-weight: 700; letter-spacing: .05em; }
.status-charity { background: rgba(184,135,42,.14); color: #7a5a15; border: 1.5px solid rgba(184,135,42,.3); }
.status-quantity { background: rgba(30,120,60,.10); color: #1a5c30; border: 1.5px solid rgba(30,120,60,.25); }
.status-type { background: rgba(60,90,170,.10); color: #1e3a8a; border: 1.5px solid rgba(60,90,170,.25); }
.admin-actions, .section-actions { display: flex; gap: .9rem; margin-top: 1rem; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: .4rem; padding: .7rem 1.4rem; border: none; border-radius: 8px; text-decoration: none; font-size: .875rem; font-weight: 700; cursor: pointer; transition: all .25s; }
.btn-primary { background: var(--gold, #b8872a); color: white; }
.btn-primary:hover { background: #9a7122; }
.btn-secondary { background: transparent; color: var(--espresso); border: 1.5px solid rgba(184,135,42,.38); }
.btn-secondary:hover { background: rgba(184,135,42,.1); border-color: rgba(184,135,42,.6); }
.mini-link { display: inline-block; margin-right: .5rem; color: var(--gold, #b8872a); font-weight: 600; text-decoration: none; }
.mini-link-danger { background: none; border: none; cursor: pointer; color: #a62626; padding: 0; font: inherit; }
.inline-form { display: inline; }
.empty-row { color: var(--text-3, #7a7a7a); }
@media (max-width: 800px) {
    .assigned-items-table thead { display: none; }
    .assigned-items-table tr { display: block; border-bottom: 1px solid rgba(0,0,0,.08); padding: .5rem 0; }
    .assigned-items-table td { display: flex; justify-content: space-between; width: 100%; border-bottom: none; }
}
</style>
{% endblock %}