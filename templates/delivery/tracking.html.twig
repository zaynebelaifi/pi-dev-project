{% extends 'base.html.twig' %}

{% block title %}Track Your Delivery{% endblock %}

{% block body %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<div class="admin-container">
    <div class="admin-header">
        <h1>Track Your Delivery</h1>
        <p>Order #{{ delivery.order_id }}</p>
    </div>

    <div class="tracking-container">
        <div class="tracking-left">
            <div class="tracking-info">
            <div class="info-card">
                <h3>Delivery Details</h3>
                <table class="admin-table">
                    <tbody>
                        <tr>
                            <td><strong>Order Number:</strong></td>
                            <td>{{ delivery.order_id }}</td>
                        </tr>
                        <tr>
                            <td><strong>Status:</strong></td>
                            <td><span class="status-badge status-{{ delivery.status|lower }}">{{ delivery.status }}</span></td>
                        </tr>
                        <tr>
                            <td><strong>Estimated Time:</strong></td>
                            <td>{{ delivery.estimated_time }} minutes</td>
                        </tr>
                        <tr>
                            <td><strong>Delivery Address:</strong></td>
                            <td>{{ delivery.delivery_address }}</td>
                        </tr>
                        <tr>
                            <td><strong>Recipient:</strong></td>
                            <td>{{ delivery.recipient_name }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            {% if delivery.deliveryMan %}
            <div class="info-card">
                <h3>Your Delivery Person</h3>
                <table class="admin-table">
                    <tbody>
                        <tr>
                            <td><strong>Name:</strong></td>
                            <td>{{ delivery.deliveryMan.name }}</td>
                        </tr>
                        <tr>
                            <td><strong>Phone:</strong></td>
                            <td>{{ delivery.deliveryMan.phone }}</td>
                        </tr>
                        <tr>
                            <td><strong>Vehicle:</strong></td>
                            <td>{{ delivery.deliveryMan.vehicle_type }}</td>
                        </tr>
                        {% if delivery.deliveryMan.rating %}
                        <tr>
                            <td><strong>Rating:</strong></td>
                            <td>{{ delivery.deliveryMan.rating }}/5 ⭐</td>
                        </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
            {% endif %}

            {% if delivery.cart_items %}
            <div class="info-card">
                <h3>Ordered Items</h3>
                <div class="order-items">
                    {% set items = delivery.cart_items ? delivery.cart_items|split('\n') : [] %}
                    <ul style="list-style:none;padding:0;margin:0;">
                        {% for it in items %}
                            {% if it is not empty %}
                            <li style="padding:.45rem 0;border-bottom:1px dashed rgba(44,26,14,.04);display:flex;justify-content:space-between;align-items:center;font-weight:600;color:var(--brown)">
                                <span style="font-weight:600;color:var(--espresso)">{{ it }}</span>
                            </li>
                            {% endif %}
                        {% endfor %}
                    </ul>
                </div>
                <p class="order-total"><strong>Total:</strong> {{ delivery.order_total }} TND</p>
            </div>
            {% endif %}
            </div>
        </div>

        <div class="tracking-right">
            <div class="tracking-timeline">
            <h3>Delivery Progress</h3>
            <div class="timeline">
                <div class="timeline-item {% if delivery.status in ['PENDING', 'ASSIGNED', 'PICKED_UP', 'IN_TRANSIT', 'DELIVERED'] %}active{% endif %}">
                    <div class="timeline-marker"></div>
                    <div class="timeline-content">
                        <h4>Order Placed</h4>
                        <p>Your order has been received and is being processed.</p>
                        {% if delivery.created_at %}
                        <small>{{ delivery.created_at|date('M j, Y g:i A') }}</small>
                        {% endif %}
                    </div>
                </div>

                <div class="timeline-item {% if delivery.status in ['ASSIGNED', 'PICKED_UP', 'IN_TRANSIT', 'DELIVERED'] %}active{% endif %}">
                    <div class="timeline-marker"></div>
                    <div class="timeline-content">
                        <h4>Delivery Assigned</h4>
                        <p>A delivery person has been assigned to your order.</p>
                        {% if delivery.deliveryMan %}
                        <p><strong>{{ delivery.deliveryMan.name }}</strong> will deliver your order.</p>
                        {% endif %}
                    </div>
                </div>

                <div class="timeline-item {% if delivery.status in ['PICKED_UP', 'IN_TRANSIT', 'DELIVERED'] %}active{% endif %}">
                    <div class="timeline-marker"></div>
                    <div class="timeline-content">
                        <h4>Order Picked Up</h4>
                        <p>Your order has been picked up and is on the way.</p>
                    </div>
                </div>

                <div class="timeline-item {% if delivery.status in ['IN_TRANSIT', 'DELIVERED'] %}active{% endif %}">
                    <div class="timeline-marker"></div>
                    <div class="timeline-content">
                        <h4>Out for Delivery</h4>
                        <p>Your order is currently being delivered.</p>
                    </div>
                </div>

                <div class="timeline-item {% if delivery.status == 'DELIVERED' %}active{% endif %}">
                    <div class="timeline-marker"></div>
                    <div class="timeline-content">
                        <h4>Delivered</h4>
                        <p>Your order has been successfully delivered.</p>
                        {% if delivery.actual_delivery_date %}
                        <small>{{ delivery.actual_delivery_date|date('M j, Y g:i A') }}</small>
                        {% endif %}
                    </div>
                </div>
            </div>
            </div>

            <div class="map-card info-card">
                <h3>Live Map</h3>
                <div
                    id="deliveryMap"
                    class="map-shell"
                    data-delivery-id="{{ delivery.delivery_id }}"
                    data-client-lat="{{ delivery.currentLatitude|default('') }}"
                    data-client-lon="{{ delivery.currentLongitude|default('') }}"
                    data-driver-lat="{{ delivery.driverLatitude|default('') }}"
                    data-driver-lon="{{ delivery.driverLongitude|default('') }}"
                        data-location-url="{{ path('app_delivery_update_location', {'id': delivery.delivery_id}) }}"
                        data-stream-url="{{ path('app_delivery_location_stream', {'id': delivery.delivery_id}) }}"
                        data-ws-url="ws://127.0.0.1:8080"
                >
                    <div>
                        <strong>Map unavailable</strong>
                        <div>Enable location services or open in Maps</div>
                    </div>
                </div>
                <p style="margin-top:.6rem;text-align:center;">
                    <a id="deliveryMapLink" href="#" target="_blank" class="btn btn-secondary" style="pointer-events:none;opacity:.6;">Open in Maps</a>
                </p>
                <div style="display:flex;gap:.5rem;align-items:center;justify-content:center;margin-top:.45rem;flex-direction:column;">
                    <div id="distanceLabel" class="distance-label" style="display:none;">Distance: --</div>
                    <div id="etaLabel" class="eta-label" style="display:none;">ETA: --</div>
                    <div id="statusLabel" class="status-label" style="display:none;">Status: --</div>
                </div>
            </div>
        </div>

        {% if delivery.status == 'DELIVERED' %}
        <div class="rating-section">
            <h3>Rate Your Delivery Experience</h3>
            {% for label in ['success', 'error'] %}
                {% for msg in app.flashes(label) %}
                    <div class="alert alert-{{ label }}">{{ msg }}</div>
                {% endfor %}
            {% endfor %}

            <form method="post" class="rating-form">
                <div class="rating-block">
                    <h4>Rate your delivery man</h4>
                    <div class="rating-stars" role="group" aria-label="Delivery man rating">
                        {% for value in 5..1 %}
                        <input type="radio" id="dm-star{{ value }}" name="delivery_man_rating" value="{{ value }}" {% if delivery.rating == value %}checked{% endif %}>
                        <label for="dm-star{{ value }}">★</label>
                        {% endfor %}
                    </div>
                    {% if delivery.rating %}
                        <p class="current-rating">Your rating: <strong>{{ delivery.rating }}/5</strong></p>
                    {% endif %}
                </div>

                <div class="rating-block">
                    <h4>Rate the restaurant &amp; order</h4>
                    <div class="rating-stars" role="group" aria-label="Restaurant rating">
                        {% for value in 5..1 %}
                        <input type="radio" id="rest-star{{ value }}" name="restaurant_rating" value="{{ value }}" {% if delivery.restaurant_rating == value %}checked{% endif %}>
                        <label for="rest-star{{ value }}">★</label>
                        {% endfor %}
                    </div>
                    {% if delivery.restaurant_rating %}
                        <p class="current-rating">Your rating: <strong>{{ delivery.restaurant_rating }}/5</strong></p>
                    {% endif %}
                </div>

                <div class="rating-block" style="margin-top:1.5rem;">
                    <h4>Share a short review</h4>
                    <textarea name="review_text" rows="4" placeholder="Tell us what you loved or what could be better" style="width:100%;padding:.85rem 1rem;border-radius:14px;border:1px solid rgba(184,135,42,.18);font-family:'Jost',sans-serif;resize:vertical;"></textarea>
                    <input type="email" name="review_email" placeholder="Email (optional)" style="width:100%;margin-top:.7rem;padding:.75rem 1rem;border-radius:14px;border:1px solid rgba(184,135,42,.18);font-family:'Jost',sans-serif;">
                    <p style="margin-top:.6rem;color:var(--text-3);font-size:.9rem;">Positive reviews may appear on our homepage with an AI-verified badge.</p>
                </div>

                <button type="submit" class="btn btn-primary">Submit Ratings</button>
            </form>
        </div>
        {% endif %}
    </div>

    <div class="admin-actions">
        <a href="{{ path('app_home') }}" class="btn btn-secondary">Back to Home</a>
    </div>
</div>

<style>

.tracking-container {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 2rem;
    margin-top: 2rem;
}

.tracking-left{display:block}
.tracking-right{display:flex;flex-direction:column;gap:1rem}

.tracking-info {
    display: block;
    gap: 1rem;
}

.info-card {
    background: var(--ivory);
    border: 1px solid rgba(184,135,42,.12);
    border-radius: 12px;
    padding: 1.25rem;
    box-shadow: 0 6px 18px rgba(44,26,14,0.04);
}

.info-card h3 {
    color: var(--gold);
    margin-bottom: .75rem;
    font-size: 1.05rem;
    letter-spacing:.02em;
}

.status-badge{
    display:inline-block;padding:.35rem .6rem;border-radius:999px;font-weight:700;font-size:.85rem;letter-spacing:.06em;color:#fff;background:rgba(44,26,14,.08);
}
.status-pending{background:#F4C95A;color:#5a3b00}
.status-assigned{background:#6CC2A2;color:#043522}
.status-picked_up{background:#e6c273;color:#4a2a00}
.status-in_transit{background:#d9a441;color:#3a2200}
.status-delivered{background:#2E9E6A;color:#fff}

.map-card.info-card {
    padding: 1.4rem;
}

.map-shell {
    width: 100%;
    height: 260px;
    border-radius: 16px;
    background:
        radial-gradient(circle at 30% 20%, rgba(184,135,42,.18), transparent 45%),
        linear-gradient(180deg, #fbf6ec 0%, #f6efe1 100%);
    border: 1px dashed rgba(184,135,42,.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-3);
    text-align: center;
    padding: 1.2rem;
}

.map-shell strong{
    color: var(--brown);
    display: block;
    margin-bottom: .35rem;
}

.tracking-timeline {
    grid-column: 1 / -1;
}

.timeline {
    position: relative;
    padding-left: 2.6rem;
}

.timeline::before {
    content: '';
    position: absolute;
    left: 1.6rem;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, rgba(184,135,42,0.9), rgba(184,135,42,0.6));
    border-radius:2px;
}

.timeline-item {
    position: relative;
    margin-bottom: 1.6rem;
    opacity: 0.45;
    transition: opacity .25s ease, transform .25s ease;
}

.timeline-item.active {
    opacity: 1;
    transform: translateY(-2px);
}

.timeline-marker {
    position: absolute;
    left: -1.2rem;
    top: 0.25rem;
    width: 1.2rem;
    height: 1.2rem;
    border-radius: 50%;
    background: #fff;
    border: 4px solid rgba(184,135,42,0.95);
    box-shadow: 0 4px 10px rgba(44,26,14,0.06);
}

.timeline-item.active .timeline-marker {
    background: rgba(255,255,255,1);
}

.timeline-item.active .timeline-marker::after{
    content:'';position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:26px;height:26px;border-radius:50%;border:2px solid rgba(184,135,42,.18);animation:pulse 1.6s infinite;
}

@keyframes pulse{0%{transform:translate(-50%,-50%) scale(.7);opacity:.9}70%{transform:translate(-50%,-50%) scale(1.3);opacity:0}100%{opacity:0}}

.timeline-content h4 {
    margin: 0 0 0.35rem 0;
    color: var(--gold);
    font-size:1.05rem;
}

.timeline-content p {
    margin: 0 0 0.4rem 0;
    color: var(--text-2);
    font-size:.975rem;
}

.timeline-content small {
    color: var(--text-3);
    font-size: 0.875rem;
}

.rating-section {
    grid-column: 1 / -1;
    background: var(--ivory);
    border: 1px solid rgba(184,135,42,.12);
    border-radius: 10px;
    padding: 1.25rem;
    text-align: center;
}

.rating-form {
    margin-top: 1rem;
}

.rating-stars {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
}

.rating-stars input[type="radio"] {
    display: none;
}

.rating-stars label {
    font-size: 1.9rem;
    cursor: pointer;
    transition: color 0.18s ease, transform .12s ease;
    color: var(--text-3);
    margin: 0 0.12rem;
}

.rating-stars input[type="radio"]:checked + label,
.rating-stars input[type="radio"]:checked + label ~ label,
.rating-stars label:hover,
.rating-stars label:hover ~ label {
    color: var(--gold);
}

.rating-block {
    margin-bottom: 1.75rem;
}

.rating-block h4 {
    margin-bottom: 1rem;
    color: var(--espresso);
    font-size: 1rem;
}

.rating-stars {
    display: flex;
    justify-content: center;
    gap: 0.4rem;
}

.current-rating {
    margin-top: 0.75rem;
    color: var(--text-2);
}

.current-rating {
    margin-top: 1rem;
}

.alert {
    padding: 1rem;
    border-radius: 4px;
    margin-bottom: 1rem;
}

.alert-success {
    background: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
}

.btn {
    display: inline-block;
    padding: 0.6rem 1.1rem;
    border: none;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
    text-align: center;
    cursor: pointer;
    transition: all 0.18s ease;
    font-size:.95rem;
}

.btn-primary {
    background: linear-gradient(180deg,var(--gold),var(--gold-2));
    color: var(--espresso);
}

.btn-primary:hover {
    filter:brightness(.92);
}

.btn-secondary {
    background: rgba(184,135,42,.08);
    color: var(--brown);
    border:1px solid rgba(184,135,42,.24);
}
.admin-actions {
    margin-top: 1.5rem;
    display: flex;
    justify-content: flex-start;
}

.btn-secondary:hover {filter:brightness(.98)}

@media (max-width: 768px) {
    .tracking-container {
        grid-template-columns: 1fr;
    }
    .tracking-right{order:2}
    .tracking-left{order:1}
    .tracking-right .map-card{order:3}
}
</style>
<script>
document.addEventListener('DOMContentLoaded', function(){
    const active = document.querySelector('.timeline-item.active');
    if(active){
        active.scrollIntoView({behavior:'smooth', block:'center'});
    }

    // Make rating stars clickable by forwarding clicks to hidden inputs
    document.querySelectorAll('.rating-stars label').forEach(lbl => {
        lbl.addEventListener('click', () => {
            const forId = lbl.getAttribute('for');
            const el = document.getElementById(forId);
            if(el) el.checked = true;
        });
    });

    const mapShell = document.getElementById('deliveryMap');
    const mapLink = document.getElementById('deliveryMapLink');
    const distanceLabel = document.getElementById('distanceLabel');
    const locationUrl = mapShell ? mapShell.dataset.locationUrl : null;
    let lastCoords = null;
    let mapInstance = null;
    let driverMarker = null;
    let clientMarker = null;
    let routeLine = null;
    let mapLinkUrl = '';
    let prevDriver = null;
    let prevDriverTime = null;
    const speedSamples = [];

    const ensureMap = (lat, lon) => {
        if (!mapShell || mapInstance) return;
        mapShell.innerHTML = '';
        mapInstance = L.map(mapShell, { zoomControl: true }).setView([lat, lon], 14);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(mapInstance);
    };

    const toNumber = (value) => {
        const num = parseFloat(value);
        return Number.isFinite(num) ? num : null;
    };

    const renderMap = (clientLat, clientLon, driverLat, driverLon) => {
        if (!mapShell) return;
        const cLat = toNumber(clientLat);
        const cLon = toNumber(clientLon);
        const dLat = toNumber(driverLat);
        const dLon = toNumber(driverLon);
        if (cLat === null || cLon === null) {
            mapShell.innerHTML = '<div><strong>Map unavailable</strong><div>Enable location services or open in Maps</div></div>';
            mapInstance = null;
            driverMarker = null;
            clientMarker = null;
            routeLine = null;
            if (distanceLabel) {
                distanceLabel.style.display = 'none';
            }
            if (mapLink) {
                mapLink.href = '#';
                mapLink.style.pointerEvents = 'none';
                mapLink.style.opacity = '0.6';
            }
            return;
        }

        ensureMap(cLat, cLon);
        if (mapInstance) {
            const driverIcon = L.divIcon({
                className: 'driver-marker',
                html: `<div class="driver-label">Driver</div><div class="driver-dot"></div>`,
                iconSize: [60, 40],
                iconAnchor: [30, 34]
            });
            const clientIcon = L.divIcon({
                className: 'client-marker',
                html: `<div class="client-label">You</div><div class="client-dot"></div>`,
                iconSize: [46, 36],
                iconAnchor: [23, 32]
            });

            if (!clientMarker) {
                clientMarker = L.marker([cLat, cLon], { icon: clientIcon }).addTo(mapInstance);
            } else {
                clientMarker.setLatLng([cLat, cLon]);
            }

            if (dLat !== null && dLon !== null) {
                if (!driverMarker) {
                    driverMarker = L.marker([dLat, dLon], { icon: driverIcon }).addTo(mapInstance);
                } else {
                    driverMarker.setLatLng([dLat, dLon]);
                }
                const linePoints = [
                    [cLat, cLon],
                    [dLat, dLon]
                ];
                if (!routeLine) {
                    // create polyline; color will be set/updated based on distance below
                    routeLine = L.polyline(linePoints, { color: '#2f6fe4', weight: 3, opacity: 0.95, dashArray: '6 8' }).addTo(mapInstance);
                } else {
                    routeLine.setLatLngs(linePoints);
                }
                mapInstance.fitBounds(linePoints, { padding: [30, 30] });

                if (distanceLabel) {
                    const meters = mapInstance.distance([cLat, cLon], [dLat, dLon]);
                    // color the line according to distance: green (near), orange (medium), red (far)
                    let color = '#2f6fe4';
                    if (meters < 500) color = '#2ecc71'; // green
                    else if (meters < 2000) color = '#f39c12'; // orange
                    else color = '#e74c3c'; // red
                    routeLine.setStyle({ color: color, weight: 3, opacity: 0.95, dashArray: '6 8' });

                    const label = meters >= 1000
                        ? `${(meters / 1000).toFixed(2)} km away`
                        : `${Math.round(meters)} m away`;
                    distanceLabel.textContent = `Distance: ${label}`;
                    distanceLabel.style.display = 'block';
                }
            } else {
                if (routeLine) {
                    mapInstance.removeLayer(routeLine);
                    routeLine = null;
                }
                mapInstance.setView([cLat, cLon], 14);
                if (distanceLabel) {
                    distanceLabel.style.display = 'none';
                }
            }
        }
        if (mapLink) {
            // If driver position exists, create a directions link from driver -> client.
            if (dLat !== null && dLon !== null) {
                mapLinkUrl = `https://www.google.com/maps/dir/?api=1&origin=${dLat},${dLon}&destination=${cLat},${cLon}&travelmode=driving`;
            } else {
                const linkLat = cLat;
                const linkLon = cLon;
                mapLinkUrl = `https://www.google.com/maps/search/?api=1&query=${linkLat},${linkLon}`;
            }
            mapLink.href = mapLinkUrl;
            mapLink.style.pointerEvents = 'auto';
            mapLink.style.opacity = '1';
        }
        return {
            meters: (mapInstance && dLat !== null && dLon !== null) ? mapInstance.distance([cLat, cLon], [dLat, dLon]) : null
        };
    };

    let clientLat = '';
    let clientLon = '';
    if (mapShell) {
        clientLat = mapShell.dataset.clientLat || '';
        clientLon = mapShell.dataset.clientLon || '';
        const initialDriverLat = mapShell.dataset.driverLat || '';
        const initialDriverLon = mapShell.dataset.driverLon || '';
        if (clientLat && clientLon) {
            lastCoords = initialDriverLat && initialDriverLon ? `${initialDriverLat},${initialDriverLon}` : '';
            renderMap(clientLat, clientLon, initialDriverLat, initialDriverLon);
        }
    }

    // haversine in meters (fallback when mapInstance not ready)
    const haversine = (lat1, lon1, lat2, lon2) => {
        const toRad = (v) => v * Math.PI / 180;
        const R = 6371000;
        const dLat = toRad(lat2 - lat1);
        const dLon = toRad(lon2 - lon1);
        const a = Math.sin(dLat/2) * Math.sin(dLat/2) + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon/2) * Math.sin(dLon/2);
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
        return R * c;
    };

    const pollLocation = async () => {
        if (!locationUrl) return;
        try {
            const resp = await fetch(locationUrl, { credentials: 'same-origin' });
            if (!resp.ok) return;
            const data = await resp.json();
            const driverLat = data.driver_latitude ? String(data.driver_latitude) : '';
            const driverLon = data.driver_longitude ? String(data.driver_longitude) : '';
            const key = driverLat && driverLon ? `${driverLat},${driverLon}` : '';
            if (key !== lastCoords) {
                const now = Date.now();
                // compute speed based on previous driver position if available
                if (prevDriver && prevDriver.lat && driverLat && driverLon && prevDriverTime) {
                    const dt = Math.max((now - prevDriverTime) / 1000, 0.001);
                    const moved = mapInstance ? mapInstance.distance([prevDriver.lat, prevDriver.lon], [driverLat, driverLon]) : haversine(prevDriver.lat, prevDriver.lon, driverLat, driverLon);
                    const instSpeed = moved / dt; // m/s
                    if (Number.isFinite(instSpeed) && instSpeed >= 0) {
                        speedSamples.push(instSpeed);
                        if (speedSamples.length > 6) speedSamples.shift();
                    }
                }
                prevDriver = { lat: driverLat, lon: driverLon };
                prevDriverTime = now;
                lastCoords = key;
                const info = renderMap(clientLat, clientLon, driverLat, driverLon);
                // update ETA and status using averaged speed
                if (info && info.meters !== null) {
                    const meters = info.meters;
                    const avgSpeed = speedSamples.length ? (speedSamples.reduce((a,b)=>a+b,0)/speedSamples.length) : 6; // default 6 m/s
                    const safeSpeed = avgSpeed < 0.5 ? 6 : avgSpeed;
                    const etaSec = safeSpeed > 0 ? Math.max(0, Math.round(meters / safeSpeed)) : null;
                    if (etaSec !== null) {
                        let etaText = '';
                        if (etaSec < 60) etaText = `${etaSec}s`;
                        else if (etaSec < 3600) etaText = `${Math.round(etaSec/60)} min`;
                        else etaText = `${Math.round(etaSec/3600)} h`;
                        if (distanceLabel) distanceLabel.textContent = `Distance: ${meters >= 1000 ? (meters/1000).toFixed(2)+' km' : Math.round(meters)+' m'}`;
                        if (etaLabel) { etaLabel.textContent = `ETA: ${etaText}`; etaLabel.style.display = 'block'; }
                        if (statusLabel) {
                            let status = 'On the way';
                            let statusColor = '#2f6fe4';
                            if (meters < 50) { status = 'Arriving now'; statusColor = '#2ecc71'; }
                            else if (meters < 500) { status = 'Nearly there'; statusColor = '#f39c12'; }
                            statusLabel.textContent = status;
                            statusLabel.style.color = statusColor;
                            statusLabel.style.display = 'block';
                        }
                    }
                }
            }
        } catch (err) {
            // Ignore transient errors
        }
    };

    pollLocation();
    const pollIntervalId = setInterval(pollLocation, 5000);

    // Try WebSocket first, then SSE, fallback to polling.
    const wsUrl = mapShell ? mapShell.dataset.wsUrl : null;
    const streamUrl = mapShell ? mapShell.dataset.streamUrl : null;
    let es = null;
    let ws = null;

    const setupWS = () => {
        if (!wsUrl || typeof WebSocket === 'undefined') return false;
        try {
            ws = new WebSocket(wsUrl);
            ws.addEventListener('open', () => {
                try { ws.send(JSON.stringify({ action: 'subscribe', delivery_id: mapShell.dataset.deliveryId })); } catch (err) {}
                if (pollIntervalId) clearInterval(pollIntervalId);
                if (es) { try { es.close(); } catch (err) {} es = null; }
            });
            ws.addEventListener('message', (ev) => {
                try {
                    const data = JSON.parse(ev.data);
                    const driverLat = data.driver_latitude ? String(data.driver_latitude) : '';
                    const driverLon = data.driver_longitude ? String(data.driver_longitude) : '';
                    const key = driverLat && driverLon ? `${driverLat},${driverLon}` : '';
                    const now = Date.now();
                    if (key && key !== lastCoords) {
                        if (prevDriver && prevDriver.lat && driverLat && driverLon && prevDriverTime) {
                            const dt = Math.max((now - prevDriverTime) / 1000, 0.001);
                            const moved = mapInstance ? mapInstance.distance([prevDriver.lat, prevDriver.lon], [driverLat, driverLon]) : haversine(prevDriver.lat, prevDriver.lon, driverLat, driverLon);
                            const instSpeed = moved / dt;
                            if (Number.isFinite(instSpeed) && instSpeed >= 0) {
                                speedSamples.push(instSpeed);
                                if (speedSamples.length > 6) speedSamples.shift();
                            }
                        }
                        prevDriver = { lat: driverLat, lon: driverLon };
                        prevDriverTime = now;
                        lastCoords = key;
                        const info = renderMap(clientLat, clientLon, driverLat, driverLon);
                        if (info && info.meters !== null) {
                            const meters = info.meters;
                            const avgSpeed = speedSamples.length ? (speedSamples.reduce((a,b)=>a+b,0)/speedSamples.length) : 6;
                            const safeSpeed = avgSpeed < 0.5 ? 6 : avgSpeed;
                            const etaSec = safeSpeed > 0 ? Math.max(0, Math.round(meters / safeSpeed)) : null;
                            if (etaSec !== null) {
                                let etaText = '';
                                if (etaSec < 60) etaText = `${etaSec}s`;
                                else if (etaSec < 3600) etaText = `${Math.round(etaSec/60)} min`;
                                else etaText = `${Math.round(etaSec/3600)} h`;
                                if (distanceLabel) distanceLabel.textContent = `Distance: ${meters >= 1000 ? (meters/1000).toFixed(2)+' km' : Math.round(meters)+' m'}`;
                                if (etaLabel) { etaLabel.textContent = `ETA: ${etaText}`; etaLabel.style.display = 'block'; }
                                if (statusLabel) {
                                    let status = 'On the way';
                                    let statusColor = '#2f6fe4';
                                    if (meters < 50) { status = 'Arriving now'; statusColor = '#2ecc71'; }
                                    else if (meters < 500) { status = 'Nearly there'; statusColor = '#f39c12'; }
                                    statusLabel.textContent = status; statusLabel.style.color = statusColor; statusLabel.style.display = 'block';
                                }
                            }
                        }
                    }
                } catch (err) {
                    // ignore parse errors
                }
            });
            ws.addEventListener('error', () => {
                try { ws.close(); } catch (err) {}
                ws = null;
            });
            return true;
        } catch (err) {
            ws = null;
            return false;
        }
    };

    const wsConnected = setupWS();
    if (!wsConnected && streamUrl && typeof EventSource !== 'undefined') {
        try {
            es = new EventSource(streamUrl, { withCredentials: true });
            es.addEventListener('open', () => {
                if (pollIntervalId) clearInterval(pollIntervalId);
            });
            es.addEventListener('message', (ev) => {
                try {
                    const data = JSON.parse(ev.data);
                    const driverLat = data.driver_latitude ? String(data.driver_latitude) : '';
                    const driverLon = data.driver_longitude ? String(data.driver_longitude) : '';
                    const key = driverLat && driverLon ? `${driverLat},${driverLon}` : '';
                    const now = Date.now();
                    if (key && key !== lastCoords) {
                        if (prevDriver && prevDriver.lat && driverLat && driverLon && prevDriverTime) {
                            const dt = Math.max((now - prevDriverTime) / 1000, 0.001);
                            const moved = mapInstance ? mapInstance.distance([prevDriver.lat, prevDriver.lon], [driverLat, driverLon]) : haversine(prevDriver.lat, prevDriver.lon, driverLat, driverLon);
                            const instSpeed = moved / dt;
                            if (Number.isFinite(instSpeed) && instSpeed >= 0) {
                                speedSamples.push(instSpeed);
                                if (speedSamples.length > 6) speedSamples.shift();
                            }
                        }
                        prevDriver = { lat: driverLat, lon: driverLon };
                        prevDriverTime = now;
                        lastCoords = key;
                        const info = renderMap(clientLat, clientLon, driverLat, driverLon);
                        if (info && info.meters !== null) {
                            const meters = info.meters;
                            const avgSpeed = speedSamples.length ? (speedSamples.reduce((a,b)=>a+b,0)/speedSamples.length) : 6;
                            const safeSpeed = avgSpeed < 0.5 ? 6 : avgSpeed;
                            const etaSec = safeSpeed > 0 ? Math.max(0, Math.round(meters / safeSpeed)) : null;
                            if (etaSec !== null) {
                                let etaText = '';
                                if (etaSec < 60) etaText = `${etaSec}s`;
                                else if (etaSec < 3600) etaText = `${Math.round(etaSec/60)} min`;
                                else etaText = `${Math.round(etaSec/3600)} h`;
                                if (distanceLabel) distanceLabel.textContent = `Distance: ${meters >= 1000 ? (meters/1000).toFixed(2)+' km' : Math.round(meters)+' m'}`;
                                if (etaLabel) { etaLabel.textContent = `ETA: ${etaText}`; etaLabel.style.display = 'block'; }
                                if (statusLabel) {
                                    let status = 'On the way';
                                    let statusColor = '#2f6fe4';
                                    if (meters < 50) { status = 'Arriving now'; statusColor = '#2ecc71'; }
                                    else if (meters < 500) { status = 'Nearly there'; statusColor = '#f39c12'; }
                                    statusLabel.textContent = status; statusLabel.style.color = statusColor; statusLabel.style.display = 'block';
                                }
                            }
                        }
                    }
                } catch (err) {
                    // ignore parse errors
                }
            });
            es.addEventListener('error', (e) => {
                try { es.close(); } catch (err) {}
                es = null;
                if (!pollIntervalId) setInterval(pollLocation, 5000);
            });
        } catch (err) {
            es = null;
        }
    }

    // When opening external Maps, the page can lose focus or be hidden on mobile.
    // Revalidate the Leaflet map size when visibility/focus changes so it doesn't disappear.
    const revalidateMap = () => {
        try {
            if (mapInstance) {
                mapInstance.invalidateSize();
                // force a small re-render using current markers
                if (clientMarker && clientMarker.getLatLng && clientMarker.getLatLng()) {
                    const cl = clientMarker.getLatLng();
                    clientMarker.setLatLng(cl);
                }
                if (driverMarker && driverMarker.getLatLng && driverMarker.getLatLng()) {
                    const dl = driverMarker.getLatLng();
                    driverMarker.setLatLng(dl);
                }
                if (routeLine && routeLine.getLatLngs) routeLine.redraw();
            }
        } catch (err) {
            // ignore
        }
    };

    document.addEventListener('visibilitychange', () => {
        if (!document.hidden) revalidateMap();
    });
    window.addEventListener('focus', revalidateMap);

    if (mapLink) {
        mapLink.addEventListener('click', (e) => {
            if (!mapLinkUrl) return;
            // open maps in a new tab/window — don't navigate away from this page
            e.preventDefault();
            window.open(mapLinkUrl, '_blank', 'noopener');
            // give the browser a moment, then revalidate in case the OS opened an external app
            setTimeout(revalidateMap, 600);
        });
    }
});
</script>
