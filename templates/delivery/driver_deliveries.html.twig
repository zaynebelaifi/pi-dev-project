{% extends 'base.html.twig' %}

{% block title %}My Deliveries - BIG 4{% endblock %}

{% block body %}
<div class="page-header" style="margin-top:140px; padding: 0 1rem;">
    <h1>My Deliveries</h1>
    <p style="color: var(--text-2); max-width: 900px;">Review your assigned deliveries and update the status quickly as you move orders through pickup, transit, and final delivery.</p>
</div>

<div class="delivery-page" style="padding: 0 1rem 4rem; max-width: 1180px; margin: 0 auto;">
    {% if deliveries is empty %}
        <div class="empty-state-card">
            <h2>No deliveries assigned to you yet.</h2>
            <p>Once orders are allocated, they will appear here with actions to mark them in transit, delivered, or canceled.</p>
            <a href="{{ path('app_home') }}" class="btn-primary">Back to Home</a>
        </div>
    {% else %}
        <div class="table-overflow">
            <table class="driver-table">
                <thead>
                    <tr>
                        <th>Order</th>
                        <th>Client</th>
                        <th>Address</th>
                        <th>Status</th>
                        <th>Pickup</th>
                        <th>Total</th>
                        <th>Assigned At</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for delivery in deliveries %}
                    <tr>
                        <td>{{ delivery.order_id }}</td>
                        <td>{{ delivery.recipient_name }}<br><span class="meta-text">{{ delivery.recipient_phone }}</span></td>
                        <td>{{ delivery.delivery_address }}</td>
                        <td>{{ delivery.status }}</td>
                        <td>{{ delivery.pickup_location }}</td>
                        <td>{{ delivery.order_total }} TND</td>
                        <td>{{ delivery.created_at ? delivery.created_at|date('Y-m-d H:i') : '-' }}</td>
                        <td class="action-cell">
                            <form method="post" action="{{ path('app_delivery_driver_status', {'id': delivery.delivery_id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('driver_status' ~ delivery.delivery_id) }}">
                                <button type="submit" name="action" value="in_transit" class="btn-action">In Transit</button>
                                <button type="button" data-url="{{ path('app_delivery_mark_delivered', {'id': delivery.delivery_id}) }}" data-delivery-id="{{ delivery.delivery_id }}" class="btn-action btn-success mark-delivered-btn">Delivered</button>
                                <button type="submit" name="action" value="cancel" class="btn-action btn-danger">Cancel</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>

<style>
    .delivery-page {
        width: 100%;
    }
    .empty-state-card {
        background: rgba(255,255,255,.96);
        border: 1px solid rgba(184,135,42,.15);
        border-radius: 24px;
        box-shadow: 0 24px 60px rgba(92,61,30,.08);
        padding: 2.5rem;
        text-align: center;
        margin: 1.5rem auto;
    }
    .empty-state-card h2 {
        margin-bottom: 1rem;
        font-size: 1.9rem;
        color: var(--brown);
    }
    .empty-state-card p {
        margin-bottom: 1.75rem;
        color: var(--text-2);
        max-width: 680px;
        margin-left: auto;
        margin-right: auto;
    }
    .table-overflow {
        width: 100%;
        overflow-x: auto;
        background: rgba(255,255,255,.96);
        border: 1px solid rgba(184,135,42,.16);
        border-radius: 28px;
        box-shadow: 0 20px 70px rgba(92,61,30,.08);
        padding: 1rem;
    }
    .driver-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 0.8rem;
        min-width: 960px;
    }
    .driver-table th,
    .driver-table td {
        padding: 1rem 1.15rem;
        vertical-align: middle;
        text-align: left;
        color: var(--brown);
    }
    .driver-table th {
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text-2);
        background: rgba(184,135,42,.08);
        border: none;
    }
    .driver-table td {
        background: rgba(255,255,255,.98);
        border: 1px solid rgba(184,135,42,.12);
    }
    .driver-table tr td:first-child {
        border-top-left-radius: 18px;
        border-bottom-left-radius: 18px;
    }
    .driver-table tr td:last-child {
        border-top-right-radius: 18px;
        border-bottom-right-radius: 18px;
    }
    .meta-text {
        display: block;
        color: var(--text-2);
        font-size: 0.95rem;
        margin-top: 0.35rem;
    }
    .action-cell form {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    .btn-action {
        border: none;
        border-radius: 999px;
        padding: 0.65rem 0.95rem;
        font-weight: 600;
        color: #fff;
        background: var(--gold);
        cursor: pointer;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
    }
    .btn-action:hover {
        transform: translateY(-1px);
        box-shadow: 0 12px 24px rgba(184,135,42,.18);
    }
    .btn-success {
        background: #2f7f4f;
    }
    .btn-danger {
        background: #b02a2a;
    }
    @media (max-width: 1024px) {
        .delivery-page { padding: 0 0.75rem 3rem; }
        .driver-table { min-width: 800px; }
    }
    @media (max-width: 760px) {
        .driver-table th,
        .driver-table td { padding: 0.85rem 0.9rem; }
        .driver-table { min-width: 720px; }
        .action-cell form { flex-direction: column; align-items: stretch; }
    }
</style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const buttons = document.querySelectorAll('.mark-delivered-btn');
            if (!buttons.length) return;

            buttons.forEach(function (btn) {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();

                    const url = btn.dataset.url;
                    if (!url) {
                        alert('Missing endpoint');
                        return;
                    }

                    const originalText = btn.textContent;
                    btn.disabled = true;
                    btn.textContent = 'Getting location...';

                    if (!navigator.geolocation) {
                        alert('Location access is required to confirm delivery');
                        btn.disabled = false;
                        btn.textContent = originalText;
                        return;
                    }

                    navigator.geolocation.getCurrentPosition(async function (pos) {
                        try {
                            const resp = await fetch(url, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                credentials: 'same-origin',
                                body: JSON.stringify({
                                    latitude: pos.coords.latitude,
                                    longitude: pos.coords.longitude
                                })
                            });
                            const data = await resp.json();

                            if (!resp.ok || !data.success) {
                                alert(data.message || 'Failed to confirm delivery');
                                btn.disabled = false;
                                btn.textContent = originalText;
                                return;
                            }

                            location.reload();
                        } catch (err) {
                            console.error(err);
                            alert('Failed to confirm delivery');
                            btn.disabled = false;
                            btn.textContent = originalText;
                        }
                    }, function () {
                        alert('Location access is required to confirm delivery');
                        btn.disabled = false;
                        btn.textContent = originalText;
                    }, { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 });
                });
            });
        });
    </script>
{% endblock %}
