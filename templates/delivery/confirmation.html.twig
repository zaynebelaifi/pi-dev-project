{% extends 'base.html.twig' %}

{% block title %}Delivery Confirmation{% endblock %}

{% block body %}
<div class="page-shell">
    <section class="confirmation-panel">
        <header class="page-header">
            <div>
                <p class="eyebrow">Delivery Confirmed</p>
                <h1>Order #{{ delivery.order_id }} is on its way</h1>
                <p class="subtitle">Your delivery has been accepted and assigned to a driver. Track it below or return home.</p>
            </div>

            <div class="page-actions">
                <a href="{{ path('app_delivery_tracking', {'id': delivery.delivery_id}) }}" class="btn btn-primary">Track Delivery</a>
                <a href="{{ path('app_home') }}" class="btn btn-secondary">Back to Home</a>
            </div>
        </header>

        <div class="summary-grid">
            <article class="detail-card">
                <h2>Delivery Summary</h2>
                <table class="detail-table">
                    <tbody>
                        <tr>
                            <td>Order Number</td>
                            <td>{{ delivery.order_id }}</td>
                        </tr>
                        <tr>
                            <td>Status</td>
                            <td><span class="status-badge status-{{ delivery.status|lower }}">{{ delivery.status }}</span></td>
                        </tr>
                        <tr>
                            <td>ETA</td>
                            <td>{{ delivery.estimated_time }} min</td>
                        </tr>
                        <tr>
                            <td>Address</td>
                            <td>{{ delivery.delivery_address }}</td>
                        </tr>
                        <tr>
                            <td>Recipient</td>
                            <td>{{ delivery.recipient_name }}<br><span class="muted">{{ delivery.recipient_phone }}</span></td>
                        </tr>
                        <tr>
                            <td>Pickup Location</td>
                            <td>{{ delivery.pickup_location }}</td>
                        </tr>
                        <tr>
                            <td>Order Total</td>
                            <td>{{ delivery.order_total }} TND</td>
                        </tr>
                    </tbody>
                </table>
            </article>

            {% if delivery.deliveryMan %}
            <article class="detail-card overview-card">
                <h2>Delivery Person</h2>
                <div class="profile-block">
                    <p><strong>{{ delivery.deliveryMan.name }}</strong></p>
                    <p class="muted">{{ delivery.deliveryMan.vehicle_type|capitalize }} • {{ delivery.deliveryMan.vehicle_number }}</p>
                    <p class="rating">Rating: {{ delivery.deliveryMan.rating }}/5 ⭐</p>
                    <p><strong>Phone:</strong> {{ delivery.deliveryMan.phone }}</p>
                </div>
            </article>
            {% endif %}
        </div>

        <div class="card-stack">
            {% if delivery.cart_items %}
            <article class="detail-card">
                <h2>Order Items</h2>
                <div class="order-items">
                    {{ delivery.cart_items|nl2br }}
                </div>
            </article>
            {% endif %}

            {% if delivery.delivery_notes %}
            <article class="detail-card">
                <h2>Delivery Notes</h2>
                <p>{{ delivery.delivery_notes }}</p>
            </article>
            {% endif %}
        </div>
    </section>
</div>

<style>
.page-shell {
    max-width: 1180px;
    margin: 0 auto;
    padding: 2rem 1rem;
}

.page-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.eyebrow {
    display: inline-block;
    margin-bottom: 0.5rem;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.85rem;
}

.subtitle {
    color: var(--text-2);
    max-width: 620px;
}

.page-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
}

.summary-grid {
    display: grid;
    grid-template-columns: 1.4fr 0.8fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
}

.card-stack {
    display: grid;
    gap: 1.5rem;
}

.detail-card {
    background: var(--ivory);
    border: 1px solid var(--gold);
    border-radius: 16px;
    padding: 1.75rem;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.05);
}

.detail-card h2 {
    margin-top: 0;
    color: var(--gold);
    font-size: 1.2rem;
    margin-bottom: 1rem;
}

.detail-table {
    width: 100%;
    border-collapse: collapse;
}

.detail-table td {
    padding: 0.75rem 0;
    vertical-align: top;
    color: var(--text-2);
}

.detail-table td:first-child {
    width: 35%;
    font-weight: 700;
    color: var(--text);
}

.profile-block p {
    margin: 0.5rem 0;
}

.rating {
    margin-top: 1rem;
    font-weight: 700;
}

.order-items {
    padding: 1rem;
    background: rgba(255, 250, 240, 0.9);
    border-radius: 12px;
    line-height: 1.7;
}

.status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
}

.status-pending { background: #fff4cd; color: #856404; }
.status-assigned { background: #dbeafe; color: #1d4ed8; }
.status-picked_up, .status-in_transit { background: #d1fae5; color: #166534; }
.status-delivered { background: #d1fae5; color: #166534; }

.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

@media (max-width: 900px) {
    .summary-grid {
        grid-template-columns: 1fr;
    }
}
</style>
{% endblock %}
