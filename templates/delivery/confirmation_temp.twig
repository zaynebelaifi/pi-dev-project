{% extends 'base.html.twig' %}

{% block title %}Delivery Confirmation{% endblock %}

{% block body %}
<div class="container">
    <div class="confirmation-header">
        <h1>Delivery Order Confirmed!</h1>
        <p>Your delivery has been successfully created and assigned.</p>
    </div>

    <div class="confirmation-actions">
        <a href="{{ path('app_delivery_tracking', {'id': delivery.delivery_id}) }}" class="btn btn-primary">Track Your Order</a>
        <a href="{{ path('app_home') }}" class="btn btn-secondary">Back to Home</a>
    </div>

    <div class="confirmation-details">
        <div class="detail-card">
            <h3>Order Details</h3>
            <table class="confirmation-table">
                <tbody>
                    <tr>
                        <td><strong>Order Number:</strong></td>
                        <td>{{ delivery.order_id }}</td>
                    </tr>
                    <tr>
                        <td><strong>Estimated Delivery Time:</strong></td>
                        <td>{{ delivery.estimated_time }} minutes</td>
                    </tr>
                    <tr>
                        <td><strong>Status:</strong></td>
                        <td><span class="status-badge status-{{ delivery.status|lower }}">{{ delivery.status }}</span></td>
                    </tr>
                    <tr>
                        <td><strong>Delivery Address:</strong></td>
                        <td>{{ delivery.delivery_address }}</td>
                    </tr>
                    <tr>
                        <td><strong>Recipient:</strong></td>
                        <td>{{ delivery.recipient_name }} - {{ delivery.recipient_phone }}</td>
                    </tr>
                    <tr>
                        <td><strong>Pickup Location:</strong></td>
                        <td>{{ delivery.pickup_location }}</td>
                    </tr>
                    <tr>
                        <td><strong>Order Total:</strong></td>
                        <td>{{ delivery.order_total }} TND</td>
                    </tr>
                </tbody>
            </table>
        </div>

        {% if delivery.cart_items %}
        <div class="detail-card">
            <h3>Selected Items</h3>
            <div class="order-items">
                {{ delivery.cart_items|nl2br }}
            </div>
        </div>
        {% endif %}

        {% if delivery.deliveryMan %}
        <div class="detail-card">
            <h3>Assigned Delivery Person</h3>
            <table class="confirmation-table">
                <tbody>
                    <tr>
                        <td><strong>Name:</strong></td>
                        <td>{{ delivery.deliveryMan.name }}</td>
                    </tr>
                    <tr>
                        <td><strong>Phone:</strong></td>
                        <td>{{ delivery.deliveryMan.phone }}</td>
                    </tr>
                    <tr>
                        <td><strong>Vehicle:</strong></td>
                        <td>{{ delivery.deliveryMan.vehicle_type }} - {{ delivery.deliveryMan.vehicle_number }}</td>
                    </tr>
                    <tr>
                        <td><strong>Rating:</strong></td>
                        <td>{{ delivery.deliveryMan.rating }}/5 ⭐</td>
                    </tr>
                </tbody>
            </table>
        </div>
        {% endif %}

        {% if delivery.delivery_notes %}
        <div class="detail-card">
            <h3>Delivery Notes</h3>
            <p>{{ delivery.delivery_notes }}</p>
        </div>
        {% endif %}
    </div>
</div>

{% endblock %}
