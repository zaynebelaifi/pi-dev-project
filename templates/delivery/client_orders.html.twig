{% extends 'base.html.twig' %}

{% block title %}My Orders{% endblock %}

{% block body %}
<div class="page-header" style="margin-top:140px; padding: 0 1rem;">
    <h1>My Orders</h1>
    {% if recipientName %}
        <p>Welcome back, {{ recipientName }}. Here are your current deliveries and order history.</p>
    {% else %}
        <p>After checkout, your delivery orders will appear here so you can track the progress.</p>
    {% endif %}
</div>

<div class="client-orders-page" style="padding: 0 1rem 4rem; max-width: 1180px; margin: 0 auto;">
    {% if recipientPhone and (liveOrders is not empty or historyOrders is not empty) %}
        <section class="order-section">
            <div class="section-header">
                <h2>Current Deliveries</h2>
            </div>

            {% if liveOrders is empty %}
                <div class="empty-state-card">
                    <p>No active deliveries yet. Once you place an order, it will appear here.</p>
                </div>
            {% else %}
                <div class="order-grid">
                    {% for delivery in liveOrders %}
                        <article class="order-card">
                            <div class="order-card-top">
                                <span class="order-badge">Order #{{ delivery.order_id }}</span>
                                <span class="status-pill">{{ delivery.status }}</span>
                            </div>
                            <div class="order-card-body">
                                <p><strong>Address</strong><br>{{ delivery.delivery_address }}</p>
                                <p><strong>Pickup</strong><br>{{ delivery.pickup_location }}</p>
                                <p><strong>Items</strong><br>{{ delivery.cart_items|nl2br }}</p>
                                <p><strong>Total</strong><br>{{ delivery.order_total }} TND</p>
                            </div>
                            <div class="order-card-footer">
                                <a href="{{ path('app_delivery_tracking', {'id': delivery.delivery_id}) }}" class="btn btn-primary">Track Order</a>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </section>

        <section class="order-section">
            <div class="section-header">
                <h2>Delivery History</h2>
            </div>

            {% if historyOrders is empty %}
                <div class="empty-state-card">
                    <p>No completed deliveries yet. Your finished orders will show up here.</p>
                </div>
            {% else %}
                <div class="order-grid">
                    {% for delivery in historyOrders %}
                        <article class="order-card order-card-secondary">
                            <div class="order-card-top">
                                <span class="order-badge">Order #{{ delivery.order_id }}</span>
                                <span class="status-pill status-completed">Completed</span>
                            </div>
                            <div class="order-card-body">
                                <p><strong>Delivered</strong><br>{{ delivery.actual_delivery_date ? delivery.actual_delivery_date|date('M j, Y') : 'Completed' }}</p>
                                <p><strong>Items</strong><br>{{ delivery.cart_items|nl2br }}</p>
                                <p><strong>Total</strong><br>{{ delivery.order_total }} TND</p>
                            </div>
                            <div class="order-card-footer">
                                <a href="{{ path('app_delivery_tracking', {'id': delivery.delivery_id}) }}" class="btn btn-secondary">View Details</a>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </section>
    {% else %}
        <div class="empty-state-card empty-state-center">
            <p>Place an order using the cart checkout first, then return here to see your live deliveries and delivery history.</p>
            <a href="{{ path('app_home') }}" class="btn btn-primary">Back to Home</a>
        </div>
    {% endif %}
</div>

<style>
.page-header h1 {
    font-size: clamp(2.2rem, 3vw, 3rem);
    margin-bottom: 0.6rem;
    color: var(--brown);
}
.page-header p {
    color: var(--text-2);
    max-width: 720px;
    line-height: 1.8;
}

.order-section {
    margin-top: 2.5rem;
}

.section-header h2 {
    font-size: 1.55rem;
    margin-bottom: 1rem;
    color: var(--brown);
}

.order-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
}

.order-card {
    background: rgba(255,255,255,0.95);
    border: 1px solid rgba(184,135,42,0.18);
    border-radius: 24px;
    padding: 1.5rem;
    box-shadow: 0 24px 60px rgba(92,61,30,0.08);
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.order-card-secondary {
    background: #fbf6ef;
}

.order-card-top {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
}

.order-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    background: rgba(184,135,42,0.14);
    font-weight: 700;
    color: var(--brown);
}

.status-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.85rem;
    border-radius: 999px;
    background: rgba(92,61,30,0.08);
    color: var(--brown);
    font-size: 0.95rem;
    font-weight: 600;
}

.status-completed {
    background: rgba(47,127,79,0.14);
    color: #2f7f4f;
}

.order-card-body p {
    margin: 0.85rem 0;
    color: var(--text-2);
    line-height: 1.7;
}

.order-card-footer {
    margin-top: auto;
}

.empty-state-card {
    background: rgba(255,255,255,0.95);
    border: 1px solid rgba(184,135,42,0.16);
    border-radius: 24px;
    padding: 2rem;
    box-shadow: 0 24px 60px rgba(92,61,30,0.08);
    color: var(--text-2);
}

.empty-state-center {
    text-align: center;
}

.empty-state-card p {
    margin-bottom: 1.5rem;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.8;
}

.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.25rem;
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.btn:hover {
    transform: translateY(-1px);
}

.btn-primary {
    background: var(--gold);
    color: #fff;
}

.btn-secondary {
    background: #f2efea;
    color: var(--brown);
}

@media (max-width: 980px) {
    .order-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 680px) {
    .page-header,
    .client-orders-page {
        padding: 0 0.85rem;
    }
}
</style>
{% endblock %}