{% extends 'base.html.twig' %}

{% block title %}Dish{% endblock %}

{% block body %}
    <h1>Dish</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ dish.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ dish.name }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ dish.description }}</td>
            </tr>
            <tr>
                <th>Base_price</th>
                <td>{{ dish.basePrice }}</td>
            </tr>
            <tr>
                <th>Available</th>
                <td>{{ dish.available ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Stock_quantity</th>
                <td>{{ dish.stockQuantity }}</td>
            </tr>
            <tr>
                <th>Image_url</th>
                <td>{{ dish.imageUrl }}</td>
            </tr>
            <tr>
                <th>Created_at</th>
                <td>{{ dish.createdAt ? dish.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Updated_at</th>
                <td>{{ dish.updatedAt ? dish.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_dish_index') }}">back to list</a>

    <a href="{{ path('app_dish_edit', {'id': dish.id}) }}">edit</a>

    {{ include('dish/_delete_form.html.twig') }}
{% endblock %}
